{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/plan-relay-run-v1.schema.json",
  "title": "PlanRelayRun v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "plan_id", "plan_sha256", "acceptance_sha256", "repository_binding_sha256", "repository_fingerprint", "control_fingerprint", "relay_profile", "relay_topology", "launcher_thread_id", "requested_effort", "revision", "status", "current_generation"],
  "properties": {
    "schema_version": {"const": "sys4ai.plan-relay-run.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "acceptance_sha256": {"$ref": "#/$defs/sha256"},
    "repository_binding_sha256": {"$ref": "#/$defs/sha256"},
    "repository_fingerprint": {"type": "string", "minLength": 1},
    "control_fingerprint": {"type": "string", "minLength": 1},
    "relay_profile": {"const": "recursive_chain_v1"},
    "relay_topology": {"const": "recursive_chain_v1"},
    "launcher_thread_id": {"type": "string", "minLength": 1},
    "requested_effort": {"type": "string", "minLength": 1},
    "revision": {"type": "integer", "minimum": 1},
    "status": {"enum": ["active", "human_gate", "integrity_stop", "validation_failed", "capability_blocked", "invocation_unknown", "cancelled", "plan_complete"]},
    "current_generation": {"type": "integer", "minimum": 1},
    "completion_report_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
