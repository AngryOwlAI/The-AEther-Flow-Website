{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/plan-completion-report-v2.schema.json",
  "title": "PlanCompletionReport v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "plan_id", "plan_sha256", "repository_fingerprint", "control_fingerprint", "relay_profile", "relay_topology", "task_count", "receipt_count", "completed_task_ids", "missing_task_ids", "open_intent_count", "terminal_proof", "receipt_sha256s", "report_content_sha256"],
  "properties": {
    "schema_version": {"const": "sys4ai.plan-completion-report.v2"},
    "run_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "repository_fingerprint": {"type": "string", "minLength": 1},
    "control_fingerprint": {"type": "string", "minLength": 1},
    "relay_profile": {"const": "recursive_chain_v1"},
    "relay_topology": {"const": "recursive_chain_v1"},
    "task_count": {"type": "integer", "minimum": 1},
    "receipt_count": {"type": "integer", "minimum": 0},
    "completed_task_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "missing_task_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "open_intent_count": {"type": "integer", "minimum": 0},
    "terminal_proof": {"type": "boolean"},
    "receipt_sha256s": {"type": "array", "items": {"$ref": "#/$defs/sha256"}, "uniqueItems": true},
    "report_content_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
