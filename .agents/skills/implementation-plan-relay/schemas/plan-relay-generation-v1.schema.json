{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/plan-relay-generation-v1.schema.json",
  "title": "PlanRelayGeneration v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "generation", "task_id", "task_sha256", "predecessor_thread_id", "predecessor_receipt_sha256", "worker_thread_id", "requested_effort", "effective_effort", "status", "handoff_token_sha256", "envelope_sha256", "invocation_count", "receipt_sha256", "successor_generation"],
  "properties": {
    "schema_version": {"const": "sys4ai.plan-relay-generation.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "generation": {"type": "integer", "minimum": 1},
    "task_id": {"type": "string", "minLength": 1},
    "task_sha256": {"$ref": "#/$defs/sha256"},
    "predecessor_thread_id": {"type": "string", "minLength": 1},
    "predecessor_receipt_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "worker_thread_id": {"type": ["string", "null"]},
    "requested_effort": {"type": "string", "minLength": 1},
    "effective_effort": {"type": ["string", "null"]},
    "status": {"enum": ["dispatch_pending", "reserved", "claimed", "consumed", "returned", "invocation_unknown", "receipt_finalized", "successor_reserved", "human_gate", "integrity_stop", "validation_failed", "capability_blocked", "cancelled"]},
    "handoff_token_sha256": {"$ref": "#/$defs/sha256"},
    "envelope_sha256": {"$ref": "#/$defs/sha256"},
    "invocation_count": {"type": "integer", "minimum": 0, "maximum": 1},
    "receipt_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "successor_generation": {"type": ["integer", "null"], "minimum": 2}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
