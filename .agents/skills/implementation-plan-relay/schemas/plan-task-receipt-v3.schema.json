{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/plan-task-receipt-v3.schema.json",
  "title": "PlanTaskReceipt v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "run_id", "plan_id", "plan_sha256", "generation", "task_id", "task_sha256", "worker_thread_id", "result_sha256", "disposition", "evidence", "repository_fingerprint", "control_fingerprint", "relay_profile", "relay_topology", "invocation_count", "successor_count", "created_at"],
  "properties": {
    "schema_version": {"const": "sys4ai.plan-task-receipt.v3"},
    "receipt_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "plan_sha256": {"$ref": "#/$defs/sha256"},
    "generation": {"type": "integer", "minimum": 1},
    "task_id": {"type": "string", "minLength": 1},
    "task_sha256": {"$ref": "#/$defs/sha256"},
    "worker_thread_id": {"type": "string", "minLength": 1},
    "result_sha256": {"$ref": "#/$defs/sha256"},
    "disposition": {"enum": ["completed", "superseded", "validation_failed", "human_gate", "cancelled"]},
    "evidence": {"type": "object"},
    "repository_fingerprint": {"type": "string", "minLength": 1},
    "control_fingerprint": {"type": "string", "minLength": 1},
    "relay_profile": {"const": "recursive_chain_v1"},
    "relay_topology": {"const": "recursive_chain_v1"},
    "invocation_count": {"const": 1},
    "successor_count": {"type": "integer", "minimum": 0, "maximum": 1},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
