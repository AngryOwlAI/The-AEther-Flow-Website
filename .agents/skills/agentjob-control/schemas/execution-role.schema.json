{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/execution-role.schema.json",
  "title": "Portable Execution-Role Binding",
  "type": "object",
  "required": [
    "schema_version", "execution_role_id", "job_id", "task_id", "binding_type",
    "role_id", "role_version", "responsibilities", "may_not", "source_role_ref",
    "task_overlay", "authority_delta", "provisional_role", "requires_human_gate",
    "human_gate_refs", "expires_after", "activated_at", "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.execution-role.v1"},
    "execution_role_id": {"$ref": "common.schema.json#/$defs/id"},
    "job_id": {"$ref": "common.schema.json#/$defs/id"},
    "task_id": {"$ref": "common.schema.json#/$defs/id"},
    "binding_type": {"enum": ["registered_role", "task_overlay", "one_job_provisional_role", "compact_embedded"]},
    "role_id": {"$ref": "common.schema.json#/$defs/id"},
    "role_version": {"$ref": "common.schema.json#/$defs/semver"},
    "responsibilities": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "may_not": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "source_role_ref": {"oneOf": [{"$ref": "common.schema.json#/$defs/relativePath"}, {"type": "null"}]},
    "task_overlay": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["added_constraints", "removed_permissions", "expanded_permissions", "justification"],
          "properties": {
            "added_constraints": {"$ref": "common.schema.json#/$defs/stringList"},
            "removed_permissions": {"$ref": "common.schema.json#/$defs/stringList"},
            "expanded_permissions": {"$ref": "common.schema.json#/$defs/stringList"},
            "justification": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
          },
          "additionalProperties": false
        }
      ]
    },
    "authority_delta": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "provisional_role": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["justification", "reusable", "registration_prohibited_by_completion"],
          "properties": {
            "justification": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
            "reusable": {"const": false},
            "registration_prohibited_by_completion": {"const": true}
          },
          "additionalProperties": false
        }
      ]
    },
    "requires_human_gate": {"type": "boolean"},
    "human_gate_refs": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/humanGateRef"}, "uniqueItems": true},
    "expires_after": {"$ref": "common.schema.json#/$defs/id"},
    "activated_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {"properties": {"binding_type": {"const": "task_overlay"}}, "required": ["binding_type"]},
      "then": {"properties": {"task_overlay": {"type": "object"}}}
    },
    {
      "if": {"properties": {"binding_type": {"const": "one_job_provisional_role"}}, "required": ["binding_type"]},
      "then": {"properties": {"provisional_role": {"type": "object"}}}
    }
  ]
}
