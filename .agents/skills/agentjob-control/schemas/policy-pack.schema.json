{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/policy-pack.schema.json",
  "title": "Portable AgentJob Policy Pack",
  "type": "object",
  "required": [
    "schema_version", "policy_id", "version", "protocol_range", "namespace_owner",
    "roles", "protected_actions", "human_gate_rules", "source_classes",
    "validator_defaults", "claim_rules", "extension_schemas", "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.policy-pack.v1"},
    "policy_id": {"$ref": "common.schema.json#/$defs/id"},
    "version": {"$ref": "common.schema.json#/$defs/semver"},
    "protocol_range": {"$ref": "common.schema.json#/$defs/protocolRange"},
    "namespace_owner": {"$ref": "common.schema.json#/$defs/id"},
    "roles": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "protected_actions": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "human_gate_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "required"],
        "properties": {
          "action": {"$ref": "common.schema.json#/$defs/id"},
          "required": {"type": "boolean"}
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    },
    "source_classes": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "validator_defaults": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "claim_rules": {
      "type": "object",
      "required": ["process_validation_does_not_imply_domain_truth"],
      "properties": {"process_validation_does_not_imply_domain_truth": {"const": true}},
      "additionalProperties": true
    },
    "extension_schemas": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"},
      "additionalProperties": {
        "type": "object",
        "required": ["owner", "version", "protocol_range", "required", "schema_ref"],
        "properties": {
          "owner": {"$ref": "common.schema.json#/$defs/id"},
          "version": {"$ref": "common.schema.json#/$defs/semver"},
          "protocol_range": {"$ref": "common.schema.json#/$defs/protocolRange"},
          "required": {"type": "boolean"},
          "schema_ref": {"$ref": "common.schema.json#/$defs/relativePath"}
        },
        "additionalProperties": false
      }
    },
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false
}
