{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/control-config.schema.json",
  "title": "Portable Governed Continuation Configuration",
  "type": "object",
  "required": ["schema_version", "project", "runtime", "control", "goal_relay", "repository", "roles", "policy", "validation", "checkpoint", "security", "human_gates"],
  "properties": {
    "schema_version": {"const": "sys4ai.continuation-config.v1"},
    "project": {
      "type": "object",
      "required": ["id", "root", "control_namespace"],
      "properties": {
        "id": {"$ref": "common.schema.json#/$defs/id"},
        "root": {"$ref": "common.schema.json#/$defs/relativePath"},
        "control_namespace": {"$ref": "common.schema.json#/$defs/id"}
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": ["harness", "surfaces"],
      "properties": {
        "harness": {"$ref": "common.schema.json#/$defs/id"},
        "surfaces": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1}
      },
      "additionalProperties": false
    },
    "control": {
      "type": "object",
      "required": ["profile", "root", "adapter", "one_agentjob_per_continue", "immutable_after_activation", "supersession_required"],
      "properties": {
        "profile": {"enum": ["portable_registered", "portable_compact", "existing_control_adapter", "aether_compatibility"]},
        "root": {"$ref": "common.schema.json#/$defs/relativePath"},
        "adapter": {"$ref": "common.schema.json#/$defs/id"},
        "one_agentjob_per_continue": {"const": true},
        "immutable_after_activation": {"const": true},
        "supersession_required": {"const": true}
      },
      "additionalProperties": false
    },
    "goal_relay": {
      "type": "object",
      "required": ["state_backend", "local_root", "thread_provider", "thread_strategy", "native_goal_mirror", "at_most_once_consumption", "max_live_continuations"],
      "properties": {
        "state_backend": {"enum": ["sqlite", "file_journal"]},
        "local_root": {"$ref": "common.schema.json#/$defs/relativePath"},
        "thread_provider": {"$ref": "common.schema.json#/$defs/id"},
        "thread_strategy": {"enum": ["fresh_summary", "fork_history", "manual_new_thread"]},
        "native_goal_mirror": {"type": "boolean"},
        "at_most_once_consumption": {"const": true},
        "max_live_continuations": {"const": 1}
      },
      "additionalProperties": false
    },
    "repository": {
      "type": "object",
      "required": ["provider", "default_branch_policy", "dirty_state_policy", "fingerprint_provider"],
      "properties": {
        "provider": {"enum": ["git", "filesystem_only", "test_fake"]},
        "default_branch_policy": {"enum": ["allow", "warn", "deny"]},
        "dirty_state_policy": {"enum": ["deny", "job_specific", "allow_read_only"]},
        "fingerprint_provider": {"$ref": "common.schema.json#/$defs/id"}
      },
      "additionalProperties": false
    },
    "roles": {
      "type": "object",
      "required": ["catalog", "allow_task_overlays", "allow_one_job_provisional_roles"],
      "properties": {
        "catalog": {"$ref": "common.schema.json#/$defs/pathList", "minItems": 1},
        "allow_task_overlays": {"type": "boolean"},
        "allow_one_job_provisional_roles": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": ["packs", "strict_extensions"],
      "properties": {
        "packs": {"$ref": "common.schema.json#/$defs/pathList", "minItems": 1},
        "strict_extensions": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["pre_execution", "post_write"],
      "properties": {
        "pre_execution": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
        "post_write": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1}
      },
      "additionalProperties": false
    },
    "checkpoint": {
      "type": "object",
      "required": ["provider", "auto_commit"],
      "properties": {
        "provider": {"enum": ["none", "git_status", "git_commit", "project_command", "external_system"]},
        "auto_commit": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "security": {
      "type": "object",
      "required": ["default_network_access", "reject_goal_secrets", "reject_symlink_state_paths", "reject_hardlink_aliases", "allow_environment_fields"],
      "properties": {
        "default_network_access": {"const": false},
        "reject_goal_secrets": {"const": true},
        "reject_symlink_state_paths": {"const": true},
        "reject_hardlink_aliases": {"const": true},
        "allow_environment_fields": {"$ref": "common.schema.json#/$defs/stringList"}
      },
      "additionalProperties": false
    },
    "human_gates": {
      "type": "object",
      "required": ["protected_actions"],
      "properties": {"protected_actions": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1}},
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
