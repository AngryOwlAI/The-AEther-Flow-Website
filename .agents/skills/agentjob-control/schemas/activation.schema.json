{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/activation.schema.json",
  "title": "Portable Activation Manifest",
  "type": "object",
  "required": ["schema_version", "activation_id", "packet_type", "records", "activated_at", "activation_revision", "prior_control_revision", "extensions"],
  "properties": {
    "schema_version": {"const": "sys4ai.activation.v1"},
    "activation_id": {"$ref": "common.schema.json#/$defs/id"},
    "packet_type": {"enum": ["director_job_packet", "supersession_packet", "completion_packet", "recovery_packet"]},
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order", "path", "record_id", "record_type", "sha256"],
        "properties": {
          "order": {"type": "integer", "minimum": 1},
          "path": {"$ref": "common.schema.json#/$defs/relativePath"},
          "record_id": {"$ref": "common.schema.json#/$defs/id"},
          "record_type": {"enum": ["task", "director_decision", "agent_job", "execution_role", "completion", "handoff", "supersession", "approval", "recovery_event"]},
          "sha256": {"$ref": "common.schema.json#/$defs/sha256"}
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    },
    "activated_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "activation_revision": {"type": "integer", "minimum": 1},
    "prior_control_revision": {"type": "integer", "minimum": 0},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false
}
