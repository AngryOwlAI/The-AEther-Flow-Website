{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/director-decision.schema.json",
  "title": "Portable Director Decision Record",
  "type": "object",
  "required": [
    "schema_version", "decision_id", "task_id", "decision_authority",
    "decision_type", "decision_mode", "status", "evidence", "candidates",
    "selected", "rejected_alternatives", "requires_human_gate",
    "human_gate_refs", "claim_boundary", "supersedes_decision_id",
    "rule_id", "rejected_illegal_routes", "created_at", "activated_at",
    "completed_at", "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.director-decision.v1"},
    "decision_id": {"$ref": "common.schema.json#/$defs/id"},
    "task_id": {"$ref": "common.schema.json#/$defs/id"},
    "decision_authority": {
      "type": "object",
      "required": ["kind", "actor_ref", "policy_refs"],
      "properties": {
        "kind": {"enum": ["system_director", "project_director", "human_authority"]},
        "actor_ref": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
        "policy_refs": {"$ref": "common.schema.json#/$defs/pathList", "minItems": 1}
      },
      "additionalProperties": false
    },
    "decision_type": {"enum": ["create_job", "reuse_job", "supersede_job", "human_gate_required", "repair_control_state", "no_action", "close_task", "split_task", "cancel_task"]},
    "decision_mode": {"enum": ["deliberative", "deterministic"]},
    "status": {"enum": ["draft", "activated", "superseded", "completed", "cancelled"]},
    "evidence": {
      "type": "object",
      "required": ["state_snapshot_ref", "state_snapshot_sha256", "handoff_refs", "source_refs"],
      "properties": {
        "state_snapshot_ref": {"$ref": "common.schema.json#/$defs/relativePath"},
        "state_snapshot_sha256": {"$ref": "common.schema.json#/$defs/sha256"},
        "handoff_refs": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/id"}, "uniqueItems": true},
        "source_refs": {"$ref": "common.schema.json#/$defs/pathList"}
      },
      "additionalProperties": false
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["route_id", "role_id", "assessment", "reason"],
        "properties": {
          "route_id": {"$ref": "common.schema.json#/$defs/id"},
          "role_id": {"$ref": "common.schema.json#/$defs/id"},
          "assessment": {"enum": ["accepted", "rejected", "blocked"]},
          "reason": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
        },
        "additionalProperties": false
      }
    },
    "selected": {
      "type": "object",
      "required": ["route_id", "role_id", "role_version", "agent_job_id", "rationale"],
      "properties": {
        "route_id": {"$ref": "common.schema.json#/$defs/id"},
        "role_id": {"$ref": "common.schema.json#/$defs/id"},
        "role_version": {"$ref": "common.schema.json#/$defs/semver"},
        "agent_job_id": {"oneOf": [{"$ref": "common.schema.json#/$defs/id"}, {"type": "null"}]},
        "rationale": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "rejected_alternatives": {"$ref": "common.schema.json#/$defs/stringList"},
    "requires_human_gate": {"type": "boolean"},
    "human_gate_refs": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/humanGateRef"}, "uniqueItems": true},
    "claim_boundary": {"$ref": "common.schema.json#/$defs/claimBoundary"},
    "supersedes_decision_id": {"oneOf": [{"$ref": "common.schema.json#/$defs/id"}, {"type": "null"}]},
    "rule_id": {"type": ["string", "null"]},
    "rejected_illegal_routes": {"$ref": "common.schema.json#/$defs/stringList"},
    "created_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "activated_at": {"oneOf": [{"$ref": "common.schema.json#/$defs/timestamp"}, {"type": "null"}]},
    "completed_at": {"oneOf": [{"$ref": "common.schema.json#/$defs/timestamp"}, {"type": "null"}]},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {"properties": {"decision_mode": {"const": "deliberative"}}, "required": ["decision_mode"]},
      "then": {"properties": {"rejected_alternatives": {"minItems": 1}}}
    },
    {
      "if": {"properties": {"decision_mode": {"const": "deterministic"}}, "required": ["decision_mode"]},
      "then": {
        "properties": {
          "rule_id": {"type": "string", "minLength": 1},
          "rejected_illegal_routes": {"minItems": 1}
        }
      }
    },
    {
      "if": {"properties": {"status": {"const": "activated"}}, "required": ["status"]},
      "then": {"properties": {"activated_at": {"$ref": "common.schema.json#/$defs/timestamp"}}}
    }
  ]
}
