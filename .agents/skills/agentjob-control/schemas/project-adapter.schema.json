{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/project-adapter.schema.json",
  "title": "Portable Project Adapter Declaration",
  "type": "object",
  "required": [
    "schema_version", "adapter_id", "version", "protocol_range", "profile",
    "capabilities", "canonical_source_roots", "record_mappings", "role_mappings",
    "validators", "checkpoint_provider", "extension_schema_refs",
    "unsupported_features", "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.project-adapter.v1"},
    "adapter_id": {"$ref": "common.schema.json#/$defs/id"},
    "version": {"$ref": "common.schema.json#/$defs/semver"},
    "protocol_range": {"$ref": "common.schema.json#/$defs/protocolRange"},
    "profile": {"enum": ["portable_registered", "portable_compact", "existing_control_adapter", "aether_compatibility"]},
    "capabilities": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "canonical_source_roots": {"$ref": "common.schema.json#/$defs/pathList", "minItems": 1},
    "record_mappings": {
      "type": "object",
      "required": ["task", "director_decision", "agent_job", "execution_role", "completion", "handoff"],
      "properties": {
        "task": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
        "director_decision": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
        "agent_job": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
        "execution_role": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
        "completion": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
        "handoff": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "role_mappings": {"type": "object", "additionalProperties": {"$ref": "common.schema.json#/$defs/id"}},
    "validators": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "checkpoint_provider": {"$ref": "common.schema.json#/$defs/id"},
    "extension_schema_refs": {"$ref": "common.schema.json#/$defs/pathList"},
    "unsupported_features": {"$ref": "common.schema.json#/$defs/stringList"},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false
}
