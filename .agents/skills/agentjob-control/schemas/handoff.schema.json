{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/handoff.schema.json",
  "title": "Portable Handoff",
  "type": "object",
  "required": [
    "schema_version", "handoff_id", "predecessor", "predecessor_handoff_ids",
    "summary", "progress", "next_action", "constraints_to_preserve",
    "human_gates", "grants_execution_authority", "created_at", "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.handoff.v1"},
    "handoff_id": {"$ref": "common.schema.json#/$defs/id"},
    "predecessor": {
      "type": "object",
      "required": ["task_id", "decision_id", "job_id", "completion_id"],
      "properties": {
        "task_id": {"$ref": "common.schema.json#/$defs/id"},
        "decision_id": {"$ref": "common.schema.json#/$defs/id"},
        "job_id": {"$ref": "common.schema.json#/$defs/id"},
        "completion_id": {"$ref": "common.schema.json#/$defs/id"}
      },
      "additionalProperties": false
    },
    "predecessor_handoff_ids": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/id"}, "uniqueItems": true},
    "summary": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "progress": {
      "type": "object",
      "required": ["completed", "remaining"],
      "properties": {
        "completed": {"$ref": "common.schema.json#/$defs/stringList"},
        "remaining": {"$ref": "common.schema.json#/$defs/stringList"}
      },
      "additionalProperties": false
    },
    "next_action": {
      "type": "object",
      "required": ["objective", "recommended_role", "route_label"],
      "properties": {
        "objective": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
        "recommended_role": {"$ref": "common.schema.json#/$defs/id"},
        "route_label": {"$ref": "common.schema.json#/$defs/id"}
      },
      "additionalProperties": false
    },
    "constraints_to_preserve": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "human_gates": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/humanGateRef"}, "uniqueItems": true},
    "grants_execution_authority": {"const": false},
    "created_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false
}
