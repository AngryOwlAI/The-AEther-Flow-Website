{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/agent-job.schema.json",
  "title": "Portable AgentJob",
  "type": "object",
  "required": [
    "schema_version", "job_id", "task_id", "decision_id", "status",
    "activated_at", "objective", "role_binding", "authority", "source_policy",
    "commands", "validators", "expected_outputs", "completion_contract",
    "stop_conditions", "checkpoint", "claim_boundary", "concurrency", "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.agent-job.v1"},
    "job_id": {"$ref": "common.schema.json#/$defs/id"},
    "task_id": {"$ref": "common.schema.json#/$defs/id"},
    "decision_id": {"$ref": "common.schema.json#/$defs/id"},
    "status": {"enum": ["draft", "active", "completed", "blocked", "failed", "cancelled", "superseded"]},
    "activated_at": {"oneOf": [{"$ref": "common.schema.json#/$defs/timestamp"}, {"type": "null"}]},
    "objective": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "role_binding": {
      "type": "object",
      "required": ["role_id", "role_version", "execution_role_ref"],
      "properties": {
        "role_id": {"$ref": "common.schema.json#/$defs/id"},
        "role_version": {"$ref": "common.schema.json#/$defs/semver"},
        "execution_role_ref": {"$ref": "common.schema.json#/$defs/relativePath"}
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["allowed_read_paths", "allowed_write_paths", "allowed_generated_paths", "forbidden_paths", "allowed_actions", "forbidden_actions", "network_access", "external_effects"],
      "properties": {
        "allowed_read_paths": {"$ref": "common.schema.json#/$defs/pathList"},
        "allowed_write_paths": {"$ref": "common.schema.json#/$defs/pathList"},
        "allowed_generated_paths": {"$ref": "common.schema.json#/$defs/pathList"},
        "forbidden_paths": {"$ref": "common.schema.json#/$defs/pathList"},
        "allowed_actions": {"$ref": "common.schema.json#/$defs/stringList"},
        "forbidden_actions": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
        "network_access": {"type": "boolean"},
        "external_effects": {"$ref": "common.schema.json#/$defs/stringList"}
      },
      "additionalProperties": false
    },
    "source_policy": {
      "type": "object",
      "required": ["allowed_source_classes", "forbidden_source_classes"],
      "properties": {
        "allowed_source_classes": {"$ref": "common.schema.json#/$defs/stringList"},
        "forbidden_source_classes": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1}
      },
      "additionalProperties": false
    },
    "commands": {
      "type": "object",
      "required": ["approved"],
      "properties": {"approved": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/command"}, "uniqueItems": true}},
      "additionalProperties": false
    },
    "validators": {
      "type": "object",
      "required": ["required", "contextual"],
      "properties": {
        "required": {"type": "array", "items": {"$ref": "#/$defs/validator"}, "minItems": 1, "uniqueItems": true},
        "contextual": {"type": "array", "items": {"$ref": "#/$defs/validator"}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "expected_outputs": {"type": "array", "items": {"$ref": "#/$defs/output"}, "minItems": 1, "uniqueItems": true},
    "completion_contract": {
      "type": "object",
      "required": ["required_evidence", "goal_effect"],
      "properties": {
        "required_evidence": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
        "goal_effect": {
          "type": "object",
          "required": ["type", "does_not_imply_global_goal_completion"],
          "properties": {
            "type": {"enum": ["none", "bounded_progress", "bounded_completion", "blocked_evidence"]},
            "does_not_imply_global_goal_completion": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "stop_conditions": {"$ref": "common.schema.json#/$defs/stringList", "minItems": 1},
    "checkpoint": {
      "type": "object",
      "required": ["provider", "required", "auto_commit"],
      "properties": {
        "provider": {"enum": ["none", "git_status", "git_commit", "project_command", "external_system"]},
        "required": {"type": "boolean"},
        "auto_commit": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "claim_boundary": {"$ref": "common.schema.json#/$defs/claimBoundary"},
    "concurrency": {
      "type": "object",
      "required": ["policy", "lease_scope", "idempotency_key"],
      "properties": {
        "policy": {"enum": ["exclusive_worktree", "exclusive_task", "read_only_shared"]},
        "lease_scope": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
        "idempotency_key": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false,
  "$defs": {
    "validator": {
      "type": "object",
      "required": ["validator_id", "validator_class", "mode"],
      "properties": {
        "validator_id": {"$ref": "common.schema.json#/$defs/id"},
        "validator_class": {"$ref": "common.schema.json#/$defs/validatorClass"},
        "mode": {"enum": ["required", "contextual"]}
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "required": ["path", "kind"],
      "properties": {
        "path": {"$ref": "common.schema.json#/$defs/relativePath"},
        "kind": {"enum": ["controlled_source_change", "generated_evidence", "generated_derivative", "cache", "receipt", "external_effect"]}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "active"}}, "required": ["status"]},
      "then": {"properties": {"activated_at": {"$ref": "common.schema.json#/$defs/timestamp"}}}
    }
  ]
}
