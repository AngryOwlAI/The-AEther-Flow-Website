{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/task.schema.json",
  "title": "Portable Task Record",
  "type": "object",
  "required": [
    "schema_version", "task_id", "objective", "status", "parent_task_id",
    "source_task_ref", "current_decision_id", "current_job_id",
    "requires_human_gate", "human_gate_refs", "created_at", "updated_at",
    "revision", "closure", "next_recommended_action", "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.task.v1"},
    "task_id": {"$ref": "common.schema.json#/$defs/id"},
    "objective": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "status": {"enum": ["draft", "active", "blocked", "human_gated", "completed", "cancelled", "superseded"]},
    "parent_task_id": {"oneOf": [{"$ref": "common.schema.json#/$defs/id"}, {"type": "null"}]},
    "source_task_ref": {"oneOf": [{"$ref": "common.schema.json#/$defs/nonEmptyString"}, {"type": "null"}]},
    "current_decision_id": {"oneOf": [{"$ref": "common.schema.json#/$defs/id"}, {"type": "null"}]},
    "current_job_id": {"oneOf": [{"$ref": "common.schema.json#/$defs/id"}, {"type": "null"}]},
    "requires_human_gate": {"type": "boolean"},
    "human_gate_refs": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/humanGateRef"}, "uniqueItems": true},
    "created_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "updated_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "revision": {"type": "integer", "minimum": 1},
    "closure": {
      "type": "object",
      "required": ["status", "summary", "completion_refs", "no_execution_reason"],
      "properties": {
        "status": {"enum": ["open", "closed", "reopened"]},
        "summary": {"type": ["string", "null"]},
        "completion_refs": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/id"}, "uniqueItems": true},
        "no_execution_reason": {"type": ["string", "null"]}
      },
      "additionalProperties": false,
      "if": {"properties": {"status": {"const": "closed"}}, "required": ["status"]},
      "then": {
        "anyOf": [
          {"properties": {"completion_refs": {"minItems": 1}}},
          {"properties": {"no_execution_reason": {"type": "string", "minLength": 1}}}
        ]
      }
    },
    "next_recommended_action": {"type": ["string", "null"]},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "completed"}}, "required": ["status"]},
      "then": {"properties": {"closure": {"properties": {"status": {"const": "closed"}}}}}
    }
  ]
}
