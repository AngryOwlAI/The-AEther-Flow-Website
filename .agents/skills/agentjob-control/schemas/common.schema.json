{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/common.schema.json",
  "title": "AgentJob Control Common Definitions",
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "protocolRange": {
      "type": "string",
      "pattern": "^(?:\\^|~|>=|<=|>|<)?[0-9]+\\.[0-9]+(?:\\.[0-9]+)?(?:[-+][0-9A-Za-z.-]+)?(?:\\s+(?:>=|<=|>|<)[0-9]+\\.[0-9]+(?:\\.[0-9]+)?)?$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {"pattern": "^/"},
          {"pattern": "^[A-Za-z]:[\\\\/]"},
          {"pattern": "^\\\\\\\\"},
          {"pattern": "(^|/)\\.\\.(/|$)"},
          {"enum": ["*", "**", "."]}
        ]
      }
    },
    "resolvedIdentityPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:/|[A-Za-z]:[\\\\/]|\\\\\\\\)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringList": {
      "type": "array",
      "items": {"$ref": "#/$defs/nonEmptyString"},
      "uniqueItems": true
    },
    "pathList": {
      "type": "array",
      "items": {"$ref": "#/$defs/relativePath"},
      "uniqueItems": true
    },
    "validatorClass": {
      "type": "string",
      "enum": [
        "schema_validation",
        "path_validation",
        "dependency_validation",
        "trace_validation",
        "process_validation",
        "control_validation",
        "command_validation",
        "claim_validation",
        "domain_validation",
        "human_authority"
      ]
    },
    "validationResult": {
      "type": "object",
      "required": ["validator_id", "validator_class", "status"],
      "properties": {
        "validator_id": {"$ref": "#/$defs/id"},
        "validator_class": {"$ref": "#/$defs/validatorClass"},
        "status": {"enum": ["pass", "fail", "warning", "skipped", "indeterminate"]},
        "reason_code": {"type": ["string", "null"]},
        "evidence_ref": {"oneOf": [{"$ref": "#/$defs/relativePath"}, {"type": "null"}]},
        "notes": {"$ref": "#/$defs/stringList"}
      },
      "additionalProperties": false
    },
    "claimBoundary": {
      "type": "object",
      "required": ["allowed", "forbidden"],
      "properties": {
        "allowed": {"$ref": "#/$defs/stringList"},
        "forbidden": {"$ref": "#/$defs/stringList", "minItems": 1}
      },
      "additionalProperties": false
    },
    "humanGateRef": {
      "type": "object",
      "required": ["gate_id", "status"],
      "properties": {
        "gate_id": {"$ref": "#/$defs/id"},
        "status": {"enum": ["required", "approved", "rejected", "expired"]},
        "approval_ref": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]}
      },
      "additionalProperties": false
    },
    "extensionValue": {
      "type": "object",
      "required": ["version", "required", "data"],
      "properties": {
        "version": {"$ref": "#/$defs/semver"},
        "required": {"type": "boolean"},
        "data": {"type": "object"}
      },
      "additionalProperties": false
    },
    "extensions": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"},
      "additionalProperties": {"$ref": "#/$defs/extensionValue"}
    },
    "command": {
      "type": "object",
      "required": ["command_id", "argv", "cwd", "environment", "network", "shell", "shell_policy_approval_ref", "timeout_seconds"],
      "properties": {
        "command_id": {"$ref": "#/$defs/id"},
        "argv": {"type": "array", "items": {"$ref": "#/$defs/nonEmptyString"}, "minItems": 1},
        "cwd": {"$ref": "#/$defs/relativePath"},
        "environment": {"type": "object", "additionalProperties": {"type": "string"}},
        "network": {"type": "boolean"},
        "shell": {"type": "boolean"},
        "shell_policy_approval_ref": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 86400}
      },
      "additionalProperties": false,
      "if": {"properties": {"shell": {"const": true}}, "required": ["shell"]},
      "then": {"properties": {"shell_policy_approval_ref": {"$ref": "#/$defs/id"}}}
    }
  }
}
