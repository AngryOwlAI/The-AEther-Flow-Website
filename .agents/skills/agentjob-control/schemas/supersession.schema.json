{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/supersession.schema.json",
  "title": "Portable Supersession Packet",
  "type": "object",
  "required": [
    "schema_version", "supersession_id", "old_decision_id", "old_job_id",
    "reason", "evidence_refs", "prior_execution_status", "working_evidence_handling",
    "replacement_decision_id", "replacement_job_id", "replacement_activation_id",
    "claim_boundary_preserved", "created_at", "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.supersession.v1"},
    "supersession_id": {"$ref": "common.schema.json#/$defs/id"},
    "old_decision_id": {"$ref": "common.schema.json#/$defs/id"},
    "old_job_id": {"$ref": "common.schema.json#/$defs/id"},
    "reason": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "evidence_refs": {"$ref": "common.schema.json#/$defs/pathList", "minItems": 1},
    "prior_execution_status": {"enum": ["unexecuted", "partially_executed", "completed", "failed", "ambiguous"]},
    "working_evidence_handling": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "replacement_decision_id": {"$ref": "common.schema.json#/$defs/id"},
    "replacement_job_id": {"$ref": "common.schema.json#/$defs/id"},
    "replacement_activation_id": {"$ref": "common.schema.json#/$defs/id"},
    "claim_boundary_preserved": {"type": "boolean"},
    "created_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false,
  "not": {
    "anyOf": [
      {"properties": {"old_decision_id": {"const": "replacement_decision_id"}}},
      {"properties": {"old_job_id": {"const": "replacement_job_id"}}}
    ]
  }
}
