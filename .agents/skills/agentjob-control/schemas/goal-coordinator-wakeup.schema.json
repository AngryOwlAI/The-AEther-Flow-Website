{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/goal-coordinator-wakeup.schema.json",
  "title": "Goal Coordinator Wakeup Intent",
  "type": "object",
  "required": [
    "schema_version",
    "wakeup_id",
    "goal_id",
    "generation",
    "worker_thread_id",
    "coordinator_thread_id",
    "step_receipt_sha256",
    "idempotency_key",
    "status",
    "provider_response_sha256",
    "created_at",
    "updated_at",
    "hash_basis",
    "wakeup_content_sha256",
    "finalized"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.goal-coordinator-wakeup.v1"},
    "wakeup_id": {"$ref": "common.schema.json#/$defs/id"},
    "goal_id": {"$ref": "common.schema.json#/$defs/id"},
    "generation": {"type": "integer", "minimum": 1},
    "worker_thread_id": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "coordinator_thread_id": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "step_receipt_sha256": {"$ref": "common.schema.json#/$defs/sha256"},
    "idempotency_key": {"$ref": "common.schema.json#/$defs/id"},
    "status": {"enum": ["pending", "delivered", "ambiguous"]},
    "provider_response_sha256": {
      "oneOf": [
        {"$ref": "common.schema.json#/$defs/sha256"},
        {"type": "null"}
      ]
    },
    "created_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "updated_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "hash_basis": {"const": "canonical_json_without_wakeup_content_sha256"},
    "wakeup_content_sha256": {"$ref": "common.schema.json#/$defs/sha256"},
    "finalized": {"const": true}
  },
  "additionalProperties": false
}
