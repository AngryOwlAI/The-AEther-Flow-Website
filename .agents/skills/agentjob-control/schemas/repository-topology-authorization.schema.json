{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/repository-topology-authorization.schema.json",
  "title": "One-shot Repository Topology Authorization",
  "type": "object",
  "required": [
    "schema_version",
    "authorization_id",
    "action",
    "command_id",
    "starting_revision",
    "requested_name_or_path",
    "user_directive_ref",
    "authorized_at",
    "one_shot",
    "consumed"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.repository-topology-authorization.v1"},
    "authorization_id": {"$ref": "common.schema.json#/$defs/id"},
    "action": {
      "enum": [
        "repository-branch-create",
        "repository-worktree-create",
        "repository-binding-change"
      ]
    },
    "command_id": {"$ref": "common.schema.json#/$defs/id"},
    "starting_revision": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "requested_name_or_path": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "user_directive_ref": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "authorized_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "one_shot": {"const": true},
    "consumed": {"type": "boolean"}
  },
  "additionalProperties": false
}
