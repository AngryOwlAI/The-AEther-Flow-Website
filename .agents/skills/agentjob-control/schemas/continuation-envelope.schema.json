{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/continuation-envelope.schema.json",
  "title": "Portable Continuation Envelope",
  "type": "object",
  "required": [
    "schema_version", "goal_id", "goal_sha256", "completion_contract_sha256",
    "generation", "handoff_token", "idempotency_key", "predecessor_thread_id",
    "predecessor_handoff_id", "repository_binding", "canonical_state",
    "progress_summary", "remaining_work", "required_skill", "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.continuation-envelope.v1"},
    "goal_id": {"$ref": "common.schema.json#/$defs/id"},
    "goal_sha256": {"$ref": "common.schema.json#/$defs/sha256"},
    "completion_contract_sha256": {"$ref": "common.schema.json#/$defs/sha256"},
    "generation": {"type": "integer", "minimum": 1},
    "handoff_token": {"type": "string", "minLength": 32, "maxLength": 512},
    "idempotency_key": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "predecessor_thread_id": {"type": ["string", "null"]},
    "predecessor_handoff_id": {"oneOf": [{"$ref": "common.schema.json#/$defs/id"}, {"type": "null"}]},
    "repository_binding": {"$ref": "goal-state.schema.json#/$defs/repositoryBinding"},
    "canonical_state": {
      "type": "object",
      "required": ["fingerprint", "active_task_id", "current_decision_id", "current_job_id"],
      "properties": {
        "fingerprint": {"$ref": "common.schema.json#/$defs/sha256"},
        "active_task_id": {"oneOf": [{"$ref": "common.schema.json#/$defs/id"}, {"type": "null"}]},
        "current_decision_id": {"oneOf": [{"$ref": "common.schema.json#/$defs/id"}, {"type": "null"}]},
        "current_job_id": {"oneOf": [{"$ref": "common.schema.json#/$defs/id"}, {"type": "null"}]}
      },
      "additionalProperties": false
    },
    "progress_summary": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "remaining_work": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "required_skill": {"const": "continue-implementing-goal"},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false
}
