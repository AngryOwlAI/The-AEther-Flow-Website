{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/continue-result-v3.schema.json",
  "title": "Authority-Bound Portable Continue Result v3",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "boundary_entered",
    "agent_jobs_executed",
    "task_id",
    "decision_id",
    "job_id",
    "completion_id",
    "handoff_id",
    "progress_effect",
    "global_goal_evaluation",
    "repository_fingerprint_before",
    "repository_fingerprint_after",
    "validators",
    "next_recommended_action",
    "execution_performed",
    "reason_code",
    "resolution_disposition",
    "repair_route",
    "execution_authority_sha256",
    "protected_action_request",
    "extensions"
  ],
  "properties": {
    "schema_version": {"const": "sys4ai.continue-result.v3"},
    "status": {
      "enum": [
        "completed",
        "completed_with_warnings",
        "bootstrap_required",
        "human_gate_required",
        "no_action",
        "blocked",
        "control_repair_required",
        "repair_routed",
        "recovery_routed",
        "evidence_gathering_routed",
        "policy_limit_reached",
        "integrity_incident",
        "failed",
        "unknown"
      ]
    },
    "boundary_entered": {
      "enum": [
        "bootstrap_required",
        "existing_agent_job_ready",
        "director_decision_required",
        "human_gate_required",
        "no_action",
        "blocked",
        "control_repair_required"
      ]
    },
    "agent_jobs_executed": {"enum": [0, 1, "unknown"]},
    "task_id": {"type": ["string", "null"]},
    "decision_id": {"type": ["string", "null"]},
    "job_id": {"type": ["string", "null"]},
    "completion_id": {"type": ["string", "null"]},
    "handoff_id": {"type": ["string", "null"]},
    "progress_effect": {
      "enum": [
        "none",
        "bounded_progress",
        "bounded_completion",
        "blocked_evidence",
        "repair_progress",
        "recovery_progress",
        "evidence_progress",
        "unknown"
      ]
    },
    "global_goal_evaluation": {
      "enum": ["not_evaluated_here", "unmet", "met", "indeterminate"]
    },
    "repository_fingerprint_before": {"$ref": "common.schema.json#/$defs/sha256"},
    "repository_fingerprint_after": {"$ref": "common.schema.json#/$defs/sha256"},
    "validators": {
      "type": "object",
      "required": ["required", "passed", "failed", "warning", "skipped"],
      "properties": {
        "required": {"type": "integer", "minimum": 0},
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0},
        "warning": {"type": "integer", "minimum": 0},
        "skipped": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "next_recommended_action": {"type": ["string", "null"]},
    "execution_performed": {"type": "boolean"},
    "reason_code": {"$ref": "common.schema.json#/$defs/id"},
    "resolution_disposition": {"$ref": "resolution-disposition.schema.json"},
    "repair_route": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "strategy_id",
            "authority_refs",
            "requires_agentjob",
            "execute_in_successor"
          ],
          "properties": {
            "strategy_id": {"$ref": "common.schema.json#/$defs/id"},
            "authority_refs": {"$ref": "common.schema.json#/$defs/stringList"},
            "requires_agentjob": {"type": "boolean"},
            "execute_in_successor": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        {"type": "null"}
      ]
    },
    "execution_authority_sha256": {"$ref": "common.schema.json#/$defs/sha256"},
    "protected_action_request": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "grant_id",
            "action_class",
            "operation",
            "target",
            "description",
            "action_sha256"
          ],
          "properties": {
            "grant_id": {"$ref": "common.schema.json#/$defs/id"},
            "action_class": {"$ref": "goal-execution-authority.schema.json#/$defs/actionClass"},
            "operation": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
            "target": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
            "description": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
            "action_sha256": {"$ref": "common.schema.json#/$defs/sha256"}
          },
          "additionalProperties": false
        },
        {"type": "null"}
      ]
    },
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {"execution_performed": {"const": false}},
        "required": ["execution_performed"]
      },
      "then": {"properties": {"agent_jobs_executed": {"const": 0}}}
    },
    {
      "if": {
        "properties": {"agent_jobs_executed": {"const": 1}},
        "required": ["agent_jobs_executed"]
      },
      "then": {
        "properties": {
          "job_id": {"$ref": "common.schema.json#/$defs/id"},
          "completion_id": {"$ref": "common.schema.json#/$defs/id"}
        }
      }
    }
  ]
}
