{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/agentjob-control/extensions/aether-authority-extension.schema.json",
  "title": "AEther authority extension data",
  "type": "object",
  "required": [
    "record_kind",
    "source_path",
    "source_sha256",
    "source_record_id",
    "scientific_authority"
  ],
  "properties": {
    "record_kind": {
      "enum": ["task", "director_decision", "agent_job", "execution_role", "handoff"]
    },
    "source_path": {"$ref": "../../common.schema.json#/$defs/relativePath"},
    "source_sha256": {"$ref": "../../common.schema.json#/$defs/sha256"},
    "source_record_id": {"$ref": "../../common.schema.json#/$defs/id"},
    "claim_boundary_ref": {
      "oneOf": [
        {"$ref": "../../common.schema.json#/$defs/id"},
        {"type": "null"}
      ]
    },
    "route_label": {"type": ["string", "null"]},
    "target_derivation_milestone": {"type": ["string", "null"]},
    "milestone_burden": {"type": ["string", "null"]},
    "scientific_authority": {
      "type": "object",
      "required": [
        "scientific_claims_changed",
        "physics_promotion_authorized",
        "proof_authority"
      ],
      "properties": {
        "scientific_claims_changed": {"type": "boolean"},
        "physics_promotion_authorized": {"type": "boolean"},
        "proof_authority": {"type": "boolean"},
        "gate_chair_verdict": {"type": "boolean"},
        "completed_derivation_claim": {"type": "boolean"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
