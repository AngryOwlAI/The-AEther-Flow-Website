{
  "schema_version": "sys4ai.goal-relay-crash-fixtures.v1",
  "windows": [
    {
      "id": "successor_intent_before_create",
      "boundary": "After successor intent, before provider create",
      "automatic_retry": false,
      "required_outcome": "recovery_pending_or_terminal_cancelled"
    },
    {
      "id": "create_before_successor_id_record",
      "boundary": "After provider create, before successor identity persistence",
      "automatic_retry": "record_only",
      "required_outcome": "successor_created"
    },
    {
      "id": "successor_id_record_before_predecessor_exit",
      "boundary": "After successor identity persistence, before predecessor exit",
      "automatic_retry": false,
      "required_outcome": "step_active"
    },
    {
      "id": "claim_before_consumption",
      "boundary": "After generation claim, before invocation consumption",
      "automatic_retry": false,
      "required_outcome": "terminal_failed_zero_invocation"
    },
    {
      "id": "consumption_before_continue_call",
      "boundary": "After invocation consumption, before continue call",
      "automatic_retry": false,
      "required_outcome": "terminal_awaiting_human_unknown"
    },
    {
      "id": "continue_uncertain_return",
      "boundary": "During continue with an uncertain return",
      "automatic_retry": false,
      "required_outcome": "terminal_awaiting_human_quarantined"
    },
    {
      "id": "return_before_receipt",
      "boundary": "After a direct return, before receipt finalization",
      "automatic_retry": false,
      "required_outcome": "terminal_failed_existing_generation_finalized"
    },
    {
      "id": "receipt_before_successor_transfer",
      "boundary": "After receipt construction, before successor transfer commit",
      "automatic_retry": "same_transaction_record_only",
      "required_outcome": "successor_created_single_receipt"
    },
    {
      "id": "state_commit_before_snapshot_render",
      "boundary": "After canonical database commit, before snapshot render succeeds",
      "automatic_retry": "render_only",
      "required_outcome": "canonical_state_retained_snapshot_regenerated"
    }
  ]
}
