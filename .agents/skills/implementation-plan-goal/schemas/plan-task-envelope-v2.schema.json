{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/implementation-plan-goal/plan-task-envelope-v2.schema.json",
  "title": "Profile-Aware Plan Task Envelope",
  "type": "object",
  "required": [
    "schema_version",
    "plan_id",
    "plan_sha256",
    "task_id",
    "task_sha256",
    "generation",
    "handoff_token",
    "idempotency_key",
    "predecessor_thread_id",
    "repository_binding",
    "activation_receipt_sha256",
    "execution_profile",
    "repository_topology_policy",
    "repository_binding_sha256",
    "activation_sequence",
    "one_task_per_discussion",
    "max_continue_invocations",
    "max_agentjobs",
    "required_skill",
    "extensions"
  ],
  "properties": {
    "schema_version": {
      "const": "sys4ai.plan-task-envelope.v2"
    },
    "plan_id": {
      "$ref": "plan-task-envelope.schema.json#/properties/plan_id"
    },
    "plan_sha256": {
      "$ref": "plan-task-envelope.schema.json#/properties/plan_sha256"
    },
    "task_id": {
      "$ref": "plan-task-envelope.schema.json#/properties/task_id"
    },
    "task_sha256": {
      "$ref": "plan-task-envelope.schema.json#/properties/task_sha256"
    },
    "generation": {
      "$ref": "plan-task-envelope.schema.json#/properties/generation"
    },
    "handoff_token": {
      "$ref": "plan-task-envelope.schema.json#/properties/handoff_token"
    },
    "idempotency_key": {
      "$ref": "plan-task-envelope.schema.json#/properties/idempotency_key"
    },
    "predecessor_thread_id": {
      "$ref": "plan-task-envelope.schema.json#/properties/predecessor_thread_id"
    },
    "repository_binding": {
      "$ref": "plan-task-envelope.schema.json#/properties/repository_binding"
    },
    "activation_receipt_sha256": {
      "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"
    },
    "execution_profile": {
      "$ref": "plan-execution-profile.schema.json"
    },
    "repository_topology_policy": {
      "$ref": "repository-topology-policy.schema.json"
    },
    "repository_binding_sha256": {
      "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"
    },
    "activation_sequence": {
      "type": "integer",
      "minimum": 1
    },
    "one_task_per_discussion": {
      "const": true
    },
    "max_continue_invocations": {
      "const": 1
    },
    "max_agentjobs": {
      "const": 1
    },
    "required_skill": {
      "const": "continue-implementing-plan-task"
    },
    "extensions": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
