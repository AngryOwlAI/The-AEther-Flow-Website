{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/implementation-plan-goal/plan-amendment.schema.json",
  "title": "Append-only Implementation Plan Amendment",
  "type": "object",
  "required": ["schema_version", "amendment_id", "plan_id", "sequence", "prior_effective_plan_sha256", "new_effective_plan_sha256", "created_at", "reason", "authorization", "operations", "evidence_refs", "plan_identity_unchanged", "history_preserved", "prior_receipts_preserved", "consumed_invocations_preserved", "prior_journal_sha256", "hash_basis", "amendment_content_sha256", "finalized", "extensions"],
  "properties": {
    "schema_version": {"const": "sys4ai.plan-amendment.v1"},
    "amendment_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
    "plan_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
    "sequence": {"type": "integer", "minimum": 1},
    "prior_effective_plan_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "new_effective_plan_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "created_at": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/timestamp"},
    "reason": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/nonEmptyString"},
    "authorization": {"$ref": "#/$defs/authorization"},
    "operations": {"type": "array", "items": {"$ref": "#/$defs/operation"}, "minItems": 1},
    "evidence_refs": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/pathList", "minItems": 1},
    "plan_identity_unchanged": {"const": true},
    "history_preserved": {"const": true},
    "prior_receipts_preserved": {"const": true},
    "consumed_invocations_preserved": {"const": true},
    "prior_journal_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "hash_basis": {"const": "canonical_json_without_amendment_content_sha256"},
    "amendment_content_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "finalized": {"const": true},
    "extensions": {"type": "object", "maxProperties": 0}
  },
  "additionalProperties": false,
  "$defs": {
    "authorization": {
      "type": "object",
      "required": ["authority_id", "status", "approval_ref", "approved_at"],
      "properties": {
        "authority_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
        "status": {"const": "approved"},
        "approval_ref": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/relativePath"},
        "approved_at": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/timestamp"}
      },
      "additionalProperties": false
    },
    "operation": {
      "type": "object",
      "required": ["operation_id", "effect", "target_kind", "target_id", "prior_value_sha256", "new_value_sha256", "narrows_authority", "protected_effects_added"],
      "properties": {
        "operation_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
        "effect": {"enum": ["add", "replace", "remove", "narrow"]},
        "target_kind": {"enum": ["phase", "task", "dependency", "acceptance", "validation", "authority", "human_gate", "exclusion"]},
        "target_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
        "prior_value_sha256": {"oneOf": [{"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"}, {"type": "null"}]},
        "new_value_sha256": {"oneOf": [{"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"}, {"type": "null"}]},
        "narrows_authority": {"type": "boolean"},
        "protected_effects_added": {"const": false}
      },
      "additionalProperties": false,
      "allOf": [
        {"if": {"properties": {"effect": {"const": "add"}}}, "then": {"properties": {"prior_value_sha256": {"type": "null"}, "new_value_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"}}}},
        {"if": {"properties": {"effect": {"const": "remove"}}}, "then": {"properties": {"prior_value_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"}, "new_value_sha256": {"type": "null"}}}},
        {"if": {"properties": {"effect": {"enum": ["replace", "narrow"]}}}, "then": {"properties": {"prior_value_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"}, "new_value_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"}}}},
        {"if": {"properties": {"effect": {"const": "narrow"}}}, "then": {"properties": {"narrows_authority": {"const": true}}}}
      ]
    }
  }
}
