{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/implementation-plan-goal/provider-intent-v2.schema.json",
  "title": "Profile-Aware Plan Task Provider Intent and Outcome",
  "type": "object",
  "required": [
    "schema_version",
    "intent_id",
    "plan_id",
    "plan_sha256",
    "task_id",
    "task_sha256",
    "generation",
    "provider_id",
    "idempotency_key",
    "handoff_token_sha256",
    "predecessor_thread_id",
    "expected_revision",
    "repository_fingerprint",
    "execution_profile_sha256",
    "requested_reasoning_effort",
    "effective_reasoning_effort",
    "profile_verification_status",
    "profile_evidence_ref",
    "environment_mode",
    "repository_binding_sha256",
    "observed_topology_sha256",
    "same_thread_profile_repair",
    "created_at",
    "status",
    "provider_create_budget",
    "create_attempts",
    "returned_thread_id",
    "provider_response_sha256",
    "conflicting_thread_ids",
    "retry_authorized",
    "recovery",
    "prior_journal_sha256",
    "hash_basis",
    "intent_content_sha256",
    "finalized",
    "extensions"
  ],
  "properties": {
    "schema_version": {
      "const": "sys4ai.plan-provider-intent.v2"
    },
    "intent_id": {
      "$ref": "provider-intent.schema.json#/properties/intent_id"
    },
    "plan_id": {
      "$ref": "provider-intent.schema.json#/properties/plan_id"
    },
    "plan_sha256": {
      "$ref": "provider-intent.schema.json#/properties/plan_sha256"
    },
    "task_id": {
      "$ref": "provider-intent.schema.json#/properties/task_id"
    },
    "task_sha256": {
      "$ref": "provider-intent.schema.json#/properties/task_sha256"
    },
    "generation": {
      "$ref": "provider-intent.schema.json#/properties/generation"
    },
    "provider_id": {
      "$ref": "provider-intent.schema.json#/properties/provider_id"
    },
    "idempotency_key": {
      "$ref": "provider-intent.schema.json#/properties/idempotency_key"
    },
    "handoff_token_sha256": {
      "$ref": "provider-intent.schema.json#/properties/handoff_token_sha256"
    },
    "predecessor_thread_id": {
      "$ref": "provider-intent.schema.json#/properties/predecessor_thread_id"
    },
    "expected_revision": {
      "$ref": "provider-intent.schema.json#/properties/expected_revision"
    },
    "repository_fingerprint": {
      "$ref": "provider-intent.schema.json#/properties/repository_fingerprint"
    },
    "execution_profile_sha256": {
      "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"
    },
    "requested_reasoning_effort": {
      "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/nonEmptyString"
    },
    "effective_reasoning_effort": {
      "oneOf": [
        {
          "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/nonEmptyString"
        },
        {
          "type": "null"
        }
      ]
    },
    "profile_verification_status": {
      "enum": [
        "not_verified",
        "pending",
        "verified",
        "mismatch",
        "unavailable"
      ]
    },
    "profile_evidence_ref": {
      "oneOf": [
        {
          "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/nonEmptyString"
        },
        {
          "type": "null"
        }
      ]
    },
    "environment_mode": {
      "const": "reuse_bound_checkout"
    },
    "repository_binding_sha256": {
      "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"
    },
    "observed_topology_sha256": {
      "oneOf": [
        {
          "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"
        },
        {
          "type": "null"
        }
      ]
    },
    "same_thread_profile_repair": {
      "type": "object",
      "required": [
        "attempted",
        "thread_id",
        "evidence_ref"
      ],
      "properties": {
        "attempted": {
          "type": "boolean"
        },
        "thread_id": {
          "oneOf": [
            {
              "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"
            },
            {
              "type": "null"
            }
          ]
        },
        "evidence_ref": {
          "oneOf": [
            {
              "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/nonEmptyString"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "attempted": {
                "const": true
              }
            },
            "required": [
              "attempted"
            ]
          },
          "then": {
            "properties": {
              "thread_id": {
                "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"
              },
              "evidence_ref": {
                "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/nonEmptyString"
              }
            }
          },
          "else": {
            "properties": {
              "thread_id": {
                "type": "null"
              },
              "evidence_ref": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "created_at": {
      "$ref": "provider-intent.schema.json#/properties/created_at"
    },
    "status": {
      "$ref": "provider-intent.schema.json#/properties/status"
    },
    "provider_create_budget": {
      "const": 1
    },
    "create_attempts": {
      "$ref": "provider-intent.schema.json#/properties/create_attempts"
    },
    "returned_thread_id": {
      "$ref": "provider-intent.schema.json#/properties/returned_thread_id"
    },
    "provider_response_sha256": {
      "$ref": "provider-intent.schema.json#/properties/provider_response_sha256"
    },
    "conflicting_thread_ids": {
      "$ref": "provider-intent.schema.json#/properties/conflicting_thread_ids"
    },
    "retry_authorized": {
      "const": false
    },
    "recovery": {
      "$ref": "provider-intent.schema.json#/$defs/recovery"
    },
    "prior_journal_sha256": {
      "$ref": "provider-intent.schema.json#/properties/prior_journal_sha256"
    },
    "hash_basis": {
      "const": "canonical_json_without_intent_content_sha256"
    },
    "intent_content_sha256": {
      "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"
    },
    "finalized": {
      "type": "boolean"
    },
    "extensions": {
      "type": "object",
      "maxProperties": 0
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "$ref": "provider-intent.schema.json#/allOf/0"
    },
    {
      "$ref": "provider-intent.schema.json#/allOf/1"
    },
    {
      "$ref": "provider-intent.schema.json#/allOf/2"
    },
    {
      "$ref": "provider-intent.schema.json#/allOf/3"
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "intent"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "effective_reasoning_effort": {
            "type": "null"
          },
          "profile_verification_status": {
            "const": "not_verified"
          },
          "profile_evidence_ref": {
            "type": "null"
          },
          "observed_topology_sha256": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "returned"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "effective_reasoning_effort": {
            "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/nonEmptyString"
          },
          "profile_verification_status": {
            "const": "verified"
          },
          "profile_evidence_ref": {
            "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/nonEmptyString"
          },
          "observed_topology_sha256": {
            "$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"
          }
        }
      }
    }
  ]
}
