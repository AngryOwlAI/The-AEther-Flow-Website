{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys4ai/implementation-plan-goal/selection-proof.schema.json",
  "title": "Revision-bound Deterministic Plan Task Selection Proof",
  "type": "object",
  "required": ["schema_version", "proof_id", "plan_id", "plan_sha256", "plan_revision", "prior_journal_sha256", "repository_fingerprint", "selector_protocol_version", "selection_policy_sha256", "supersession_graph_sha256", "lease_token_sha256", "active_task_ids", "ordered_tasks", "outcome", "selected_task", "blocking_reasons", "canonical_order_only", "revision_bound", "compare_and_swap_required", "hash_basis", "proof_content_sha256", "finalized", "extensions"],
  "properties": {
    "schema_version": {"const": "sys4ai.plan-selection-proof.v1"},
    "proof_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
    "plan_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
    "plan_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "plan_revision": {"type": "integer", "minimum": 0},
    "prior_journal_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "repository_fingerprint": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "selector_protocol_version": {"const": "1.0.0"},
    "selection_policy_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "supersession_graph_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "lease_token_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "active_task_ids": {"type": "array", "items": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"}, "maxItems": 1, "uniqueItems": true},
    "ordered_tasks": {"type": "array", "items": {"$ref": "#/$defs/taskSnapshot"}, "minItems": 1},
    "outcome": {"enum": ["selected", "no_ready_task", "blocked_no_runnable", "completion_candidate", "invalid"]},
    "selected_task": {"oneOf": [{"$ref": "#/$defs/selectedTask"}, {"type": "null"}]},
    "blocking_reasons": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/stringList"},
    "canonical_order_only": {"const": true},
    "revision_bound": {"const": true},
    "compare_and_swap_required": {"const": true},
    "hash_basis": {"const": "canonical_json_without_proof_content_sha256"},
    "proof_content_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
    "finalized": {"const": true},
    "extensions": {"type": "object", "maxProperties": 0}
  },
  "additionalProperties": false,
  "allOf": [
    {"if": {"properties": {"outcome": {"const": "selected"}}}, "then": {"properties": {"selected_task": {"$ref": "#/$defs/selectedTask"}, "active_task_ids": {"maxItems": 0}, "blocking_reasons": {"maxItems": 0}}}},
    {"if": {"properties": {"outcome": {"enum": ["no_ready_task", "blocked_no_runnable", "completion_candidate", "invalid"]}}}, "then": {"properties": {"selected_task": {"type": "null"}}}},
    {"if": {"properties": {"outcome": {"enum": ["blocked_no_runnable", "invalid"]}}}, "then": {"properties": {"blocking_reasons": {"minItems": 1}}}}
  ],
  "$defs": {
    "dependencyProof": {
      "type": "object",
      "required": ["task_id", "effective_task_ids", "status", "receipt_sha256s"],
      "properties": {
        "task_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
        "effective_task_ids": {"type": "array", "items": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"}, "minItems": 1, "uniqueItems": true},
        "status": {"enum": ["terminal", "nonterminal", "unknown", "invalid"]},
        "receipt_sha256s": {"type": "array", "items": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"}, "uniqueItems": true}
      },
      "additionalProperties": false,
      "if": {"properties": {"status": {"const": "terminal"}}},
      "then": {"properties": {"receipt_sha256s": {"minItems": 1}}}
    },
    "taskSnapshot": {
      "type": "object",
      "required": ["canonical_position", "task_id", "task_sha256", "effective_task_ids", "status", "dependencies", "dependency_ready"],
      "properties": {
        "canonical_position": {"type": "integer", "minimum": 0},
        "task_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
        "task_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
        "effective_task_ids": {"type": "array", "items": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"}, "minItems": 1, "uniqueItems": true},
        "status": {"enum": ["pending", "reserved", "active", "completed", "superseded", "blocked", "recovery_pending"]},
        "dependencies": {"type": "array", "items": {"$ref": "#/$defs/dependencyProof"}, "uniqueItems": true},
        "dependency_ready": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "selectedTask": {
      "type": "object",
      "required": ["task_id", "task_sha256", "canonical_position", "dependency_receipt_sha256s"],
      "properties": {
        "task_id": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/id"},
        "task_sha256": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"},
        "canonical_position": {"type": "integer", "minimum": 0},
        "dependency_receipt_sha256s": {"type": "array", "items": {"$ref": "../../agentjob-control/schemas/common.schema.json#/$defs/sha256"}, "uniqueItems": true}
      },
      "additionalProperties": false
    }
  }
}
