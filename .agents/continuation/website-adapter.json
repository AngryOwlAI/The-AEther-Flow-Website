    "source_lock_sha256": "eb952272d720cd6fc4d58e63e9ddb593956a1f5a721a9d1e638c5a7546d4fcef"
  },
  "test_resources": {
    "status": "vendored_read_only",
    "runtime_required": false,
    "validation_required": true,
    "source_commit": "f2852d5273ed7297a0abd55c9aecfbf7f5e4507e",
    "resources": [
      {
        "source_path": "examples/governed-continuation",
