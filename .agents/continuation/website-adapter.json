{
  "schema_version": "sys4ai.website-continuation-adapter.v1",
  "status": "experimental",
  "version": "0.1.0",
  "invocation": {
    "continue": "explicit",
    "continue_goal": "explicit",
    "continue_implementing_goal": "token_bound_or_recovery",
    "agentjob_control": "internal"
  },
  "authority": {
    "implementation_root": "implementation_control",
    "sole_implementation_authority": true,
    "portable_control_bootstrap": false,
    "portable_control_root": null
  },
  "runtime": {
    "vendor_root": ".agents/skills",
    "state_root": ".local/sys4ai/continuation",
    "state_backend": "sqlite",
    "manual_handoff_root": ".local/sys4ai/continuation/manual",
    "activation_receipt_root": ".local/sys4ai/continuation/activations"
  },
  "mapping": {
    "task": "implementation_control/program_state.yaml active_task",
    "job": "implementation_control/program_state.yaml current_job",
    "completion": "active task or job completion_record",
    "handoff": "implementation_control/program_state.yaml latest_handoff",
    "approval_gates": "active task and current job approval_gates",
    "checkpoint": "completion record plus exact Git checkpoint commit evidence",
    "source_authority": "repository boundary task source context and handoff source authority boundary"
  },
  "fingerprint": {
    "includes": [
      "Git HEAD branch common directory and non-relay status",
      "active program state task job completion and handoff hashes",
      "resolved reads writes validators gates checkpoint and source authority"
    ],
    "excludes": [
      ".local/sys4ai/continuation",
      ".local/sys4ai/install-transactions"
    ]
  },
  "providers": {
    "preferred": "codex_fresh_summary_task",
    "automatic_provider_protocol": "reserve create persist activate stop",
    "manual_fallback": true,
    "ambiguous_outcome_policy": "enter_recovery_without_retry"
  },
  "policy": {
    "maximum_agentjobs_per_generation": 1,
    "maximum_successors_per_generation": 1,
    "require_pre_execution_activation_receipt": true,
    "require_exact_repository_and_record_match": true,
    "infer_checkpoint_authority_from_goal": false,
    "launch_real_goal_during_validation": false,
    "allow_push": false,
    "allow_deployment": false,
    "allow_source_refresh": false,
    "allow_public_claim_promotion": false,
    "allow_upstream_write": false
  },
  "source": {
    "repository": "/Volumes/P-SSD/AngryOwl/skills-Sys4AI",
