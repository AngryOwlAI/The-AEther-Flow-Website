---
const homePath = "/project/overview/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${homePath}`} />
    <link rel="canonical" href={homePath} />
    <title>Redirecting to Æther Flow</title>
  </head>
  <body>
    <main>
      <h1>Redirecting to Æther Flow</h1>
      <p>
        Redirecting to <a href={homePath}>the Æther Flow project overview</a>.
      </p>
    </main>
    <script is:inline>
      window.location.replace("/project/overview/");
    </script>
  </body>
</html>
