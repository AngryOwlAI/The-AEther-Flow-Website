---
import CommandBand from "../components/CommandBand.astro";
import EvidenceRail from "../components/EvidenceRail.astro";
import ProjectIntroduction from "../components/ProjectIntroduction.astro";
import ProjectStatusStrip from "../components/ProjectStatusStrip.astro";
import SourceAuthoritySection from "../components/SourceAuthoritySection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { greenfieldRouteDiagramBlocks, projectSourceNoticeDefaults } from "../lib/siteContent";
import { resolvedPublicClaimLadder } from "../lib/publicClaimLadder";
import ComprehensionBlocks from "../components/ComprehensionBlocks.astro";

const sourceNotice = projectSourceNoticeDefaults.home;
const homeClaimByState = new Map(
  resolvedPublicClaimLadder
    .filter(
      ({ statement }) =>
        statement.disposition === "accepted" && statement.surfaces.includes("home"),
    )
    .map(({ state, statement }) => [state, statement] as const),
);
const homePositioningSteps = [
  {
    id: "home-project-definition",
    label: "01 · What the project is",
    title: "A proposed ontology paired with an exact effective package.",
    href: "/physics/ontology/",
    statement: homeClaimByState.get("interpretive")!,
  },
  {
    id: "home-exact-closure",
    label: "02 · Why exact closure matters",
    title: "The observer-level gravitational system is explicit.",
    href: "/physics/exact-gr-benchmark/",
    statement: homeClaimByState.get("adopted-effective")!,
  },
  {
    id: "home-current-result",
    label: "03 · What exists now",
    title: "An operational effective theory statement is complete.",
    href: "/physics/claim-status/",
    statement: homeClaimByState.get("complete-effective")!,
  },
  {
    id: "home-open-foundation",
    label: "04 · What remains open",
    title: "The foundational derivation is still an active burden.",
    href: "/physics/derivation-roadmap/",
    statement: homeClaimByState.get("open-foundational")!,
    supportingStatement: homeClaimByState.get("not-claimed")!,
  },
  {
    id: "home-governed-method",
    label: "05 · How the work is tested and governed",
    title: "AI assistance operates inside a human-accountable method.",
    href: "/ai-research-system/workflow/",
    statement: homeClaimByState.get("governed-method")!,
  },
] as const;
const homeCurrentResult = homeClaimByState.get("complete-effective")!;
const homeOpenFoundation = homeClaimByState.get("open-foundational")!;
const homeProjectIntroduction = [
  "The Æther Flow Project is a two-part research program about foundational physics and the governed use of AI in research. Its physics track explores a proposed way to interpret space, time, and gravity while keeping general relativity as the exact benchmark for observable gravity.",
  "Its AI track develops a human-accountable process for organizing, checking, and reviewing the work. The project has not derived general relativity from its proposed underlying model; that remains an open research problem, and the project does not claim a verified new law of gravity.",
] as const;
const homeStatusItems = [
  {
    id: "exact-closure",
    label: "Exact closure",
    value: "Completed effective statement",
    semantic: "complete",
    description: homeCurrentResult.exactWording,
    qualification: homeCurrentResult.allowedQualification,
  },
  {
    id: "observable-dynamics",
    label: "Observable dynamics",
    value: "Exactly GR by adoption",
    semantic: "adopted",
    description: homeClaimByState.get("adopted-effective")!.exactWording,
    qualification: homeClaimByState.get("adopted-effective")!.allowedQualification,
  },
  {
    id: "ontology",
    label: "Ontology",
    value: "Retained interpretive structure",
    semantic: "interpretive",
    description: homeClaimByState.get("interpretive")!.exactWording,
    qualification: homeClaimByState.get("interpretive")!.allowedQualification,
  },
  {
    id: "first-principles-derivation",
    label: "First-principles derivation",
    value: "Open",
    semantic: "open",
    description: homeOpenFoundation.exactWording,
    qualification: homeOpenFoundation.allowedQualification,
  },
  {
    id: "new-low-energy-signature",
    label: "New low-energy signature",
    value: "Not claimed",
    semantic: "not-claimed",
    description: homeClaimByState.get("not-claimed")!.exactWording,
    qualification: homeClaimByState.get("not-claimed")!.allowedQualification,
  },
] as const;

const physicsDetails = [
  "Æther / Æther-Flow ontology",
  "Exact-GR benchmark package",
  "Open GR-derivation problem",
  "No-go and obstruction record",
];

const aiDetails = [
  "AI research-agent workflow",
  "Role contracts and governed skills",
  "Claim gates, review, and refutation discipline",
  "Source-first memory, wiki, and registries",
];

const trackRailItems = [
  {
    label: "Physics Research",
    title: "Understand the physics proposal without treating it as proved.",
    body: "The physics category starts with ontology, exact-GR benchmark boundaries, the open derivation roadmap, and claim-status discipline.",
    points: [
      ...physicsDetails,
      "Public language preserves the distinction between interpretation, benchmark compatibility, open derivation work, and obstruction records.",
    ],
    href: "/physics/",
    actionLabel: "Open physics research",
  },
  {
    label: "AI Research System",
    title: "Inspect the governed workflow used to pursue the research.",
    body: "The AI research system category explains bounded tasks, roles, validators, handoffs, memory preflight, and human-gated promotion.",
    points: [
      ...aiDetails,
      "Public copy explains the system in plain language before internal terms such as AgentJobs, registries, and role contracts become necessary.",
    ],
    href: "/ai-research-system/",
    actionLabel: "Open AI research system",
  },
];

const readerCapabilityRoutes = [
  {
    title: "Start with physics",
    href: "/physics/",
    body: "Begin with ontology, benchmark boundaries, derivation roadmap, flow geometry, claim status, and open burdens.",
  },
  {
    title: "Check physics claim status",
    href: "/physics/claim-status/",
    body: "Separate stated ideas, benchmark compatibility, open derivation work, obstructions, and blocked overreads.",
  },
  {
    title: "Understand the AI system",
    href: "/ai-research-system/",
    body: "See how bounded tasks, roles, schemas, memory, validators, handoffs, and review discipline organize the work.",
  },
  {
    title: "Inspect validation and handoffs",
    href: "/ai-research-system/validators-and-handoffs/",
    body: "Understand why a validator PASS is bounded to a checked state and why handoffs do not expand authority.",
  },
  {
    title: "Check source authority",
    href: "/documents/governance/source-authority/",
    body: "Learn how website pages, source records, registries, generated surfaces, and derivatives differ.",
  },
  {
    title: "Browse documents",
    href: "/documents/",
    body: "Find research articles, governance guidance, generated derivatives, reading paths, and diagrams.",
  },
];

const ontologyStatusRoutes = [
  {
    title: "Æther / Æther-Flow ontology",
    href: "/physics/ontology/",
    body: "Plain vocabulary for Æther, Æther-Flow, observed space, S-time, expansion, and gravity-language, with boundaries around what those terms do not prove.",
  },
  {
    title: "GR derivation roadmap",
    href: "/physics/derivation-roadmap/",
    body: "A burden map for the still-open derivation path: effective geometry, matter coupling, field equations, and benchmark promotion each require source-side evidence.",
  },
];

const heroFieldMap = `
  <svg class="field-map-svg" viewBox="0 0 680 420" role="img" aria-labelledby="home-field-stage-title home-field-stage-desc">
    <title id="home-field-stage-title">Animated two-track Æther Flow luminous field map</title>
    <desc id="home-field-stage-desc">
      A luminous central field with animated tracers moving along two connected research paths.
    </desc>
    <defs>
      <radialGradient id="home-field-flare" cx="52%" cy="49%" r="58%">
        <stop offset="0%" stop-color="var(--owl-orange-100)" />
        <stop offset="14%" stop-color="var(--owl-orange-500)" stop-opacity="0.96" />
        <stop offset="34%" stop-color="var(--owl-orange-500)" stop-opacity="0.72" />
        <stop offset="58%" stop-color="var(--owl-cyan-400)" stop-opacity="0.22" />
        <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="home-smoke-ribbon" x1="0%" x2="100%" y1="50%" y2="50%">
        <stop offset="0%" stop-color="var(--color-dark-page)" stop-opacity="0" />
        <stop offset="38%" stop-color="var(--owl-cyan-400)" stop-opacity="0.52" />
        <stop offset="58%" stop-color="var(--owl-orange-100)" stop-opacity="0.82" />
        <stop offset="100%" stop-color="var(--owl-cyan-400)" stop-opacity="0.12" />
      </linearGradient>
      <linearGradient id="home-orange-ribbon" x1="0%" x2="100%" y1="50%" y2="50%">
        <stop offset="0%" stop-color="var(--color-dark-page)" stop-opacity="0" />
        <stop offset="35%" stop-color="var(--owl-orange-500)" stop-opacity="0.72" />
        <stop offset="57%" stop-color="var(--owl-orange-100)" stop-opacity="0.92" />
        <stop offset="100%" stop-color="var(--owl-orange-500)" stop-opacity="0.2" />
      </linearGradient>
      <filter id="home-field-bloom" x="-18%" y="-34%" width="136%" height="168%">
        <feGaussianBlur stdDeviation="7" result="bloom" />
        <feMerge>
          <feMergeNode in="bloom" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="home-flare-bloom" x="-90%" y="-90%" width="280%" height="280%">
        <feGaussianBlur stdDeviation="10" result="flareBlur" />
        <feColorMatrix
          in="flareBlur"
          type="matrix"
          values="1.2 0 0 0 0  0 1.02 0 0 0  0 0 0.72 0 0  0 0 0 1 0"
          result="warmBlur"
        />
        <feMerge>
          <feMergeNode in="warmBlur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <rect class="stage-void" width="680" height="420" rx="28" />
    <g class="cosmic-dust" aria-hidden="true">
      <circle cx="54" cy="82" r="0.9" />
      <circle cx="92" cy="306" r="1.1" />
      <circle cx="132" cy="148" r="0.7" />
      <circle cx="190" cy="64" r="1.3" />
      <circle cx="250" cy="340" r="0.8" />
      <circle cx="316" cy="108" r="0.9" />
      <circle cx="384" cy="320" r="1" />
      <circle cx="498" cy="88" r="1.1" />
      <circle cx="566" cy="270" r="0.9" />
      <circle cx="620" cy="142" r="1.2" />
    </g>
    <g class="field-ribbons smoke-field" filter="url(#home-field-bloom)" aria-hidden="true">
      <path class="ribbon wash" d="M-18 286 C124 218, 236 206, 402 216 C505 222, 594 188, 720 106" stroke="url(#home-smoke-ribbon)" />
      <path class="ribbon bright" d="M-10 272 C128 218, 244 208, 404 216 C516 222, 596 198, 714 132" stroke="url(#home-smoke-ribbon)" />
      <path class="ribbon fine" d="M34 338 C166 254, 276 228, 404 218 C516 210, 604 244, 704 308" stroke="url(#home-smoke-ribbon)" />
      <path class="ribbon fine alternate" d="M88 124 C196 132, 300 162, 404 216 C512 272, 604 306, 708 318" stroke="url(#home-smoke-ribbon)" />
    </g>
    <g class="field-ribbons orange-field" filter="url(#home-field-bloom)" aria-hidden="true">
      <path class="ribbon wash" d="M-28 96 C136 150, 252 202, 404 216 C516 226, 594 150, 724 44" stroke="url(#home-orange-ribbon)" />
      <path class="ribbon bright" d="M-20 110 C142 162, 260 204, 404 216 C520 226, 608 162, 714 70" stroke="url(#home-orange-ribbon)" />
      <path class="ribbon fine" d="M8 376 C142 286, 260 238, 404 218 C522 202, 610 278, 710 372" stroke="url(#home-orange-ribbon)" />
      <path class="ribbon fine alternate" d="M116 34 C220 66, 306 142, 404 216 C520 304, 608 282, 714 206" stroke="url(#home-orange-ribbon)" />
    </g>
    <g class="plasma-filaments smoke-filaments" filter="url(#home-field-bloom)" aria-hidden="true">
      <path d="M-12 306 C130 246, 244 224, 404 216 C498 212, 596 184, 710 118" />
      <path d="M-4 248 C116 214, 252 204, 404 216 C506 230, 598 220, 704 166" />
      <path d="M64 172 C182 172, 294 184, 404 216 C512 248, 602 270, 720 282" />
      <path d="M138 82 C238 120, 324 172, 404 216 C494 266, 594 304, 714 342" />
      <path d="M34 356 C168 272, 286 234, 404 216 C496 202, 590 224, 706 270" />
    </g>
    <g class="plasma-filaments orange-filaments" filter="url(#home-field-bloom)" aria-hidden="true">
      <path d="M-24 68 C122 132, 246 188, 404 216 C516 238, 616 168, 724 68" />
      <path d="M30 392 C150 302, 278 242, 404 216 C516 194, 604 260, 718 378" />
      <path d="M108 28 C220 70, 306 146, 404 216 C516 296, 608 280, 724 188" />
      <path d="M308 392 C392 314, 448 254, 498 218 C572 162, 636 106, 724 8" />
      <path d="M468 414 C532 330, 564 248, 612 178 C646 128, 678 88, 724 42" />
    </g>
    <g class="field-trace-system" filter="url(#home-field-bloom)" aria-hidden="true">
      <path class="field-trace orange-trace trace-a" d="M-20 110 C142 162, 260 204, 404 216 C520 226, 608 162, 714 70" />
      <path class="field-trace smoke-trace trace-b" d="M-12 306 C130 246, 244 224, 404 216 C498 212, 596 184, 710 118" />
      <path class="field-trace orange-trace trace-c" d="M30 392 C150 302, 278 242, 404 216 C516 194, 604 260, 718 378" />
      <path class="field-trace smoke-trace trace-d" d="M64 172 C182 172, 294 184, 404 216 C512 248, 602 270, 720 282" />
    </g>
    <g class="flare-system" filter="url(#home-flare-bloom)" aria-hidden="true">
      <circle class="field-flare" cx="404" cy="216" r="116" fill="url(#home-field-flare)" />
      <g class="flare-rays">
        <path d="M280 216 H528" />
        <path d="M404 92 V340" />
        <path d="M316 132 L492 300" />
        <path d="M314 302 L496 130" />
      </g>
      <path class="flare-cross" d="M348 216 H462 M404 160 V272" />
      <path class="lens-arc upper" d="M308 176 C356 132, 430 132, 492 174" />
      <path class="lens-arc lower" d="M304 254 C360 302, 446 294, 506 242" />
    </g>
    <g class="charged-grain" aria-hidden="true">
      <circle cx="354" cy="205" r="1.4" />
      <circle cx="372" cy="232" r="1" />
      <circle cx="390" cy="186" r="1.2" />
      <circle cx="424" cy="236" r="1.1" />
      <circle cx="446" cy="202" r="1.3" />
      <circle cx="468" cy="224" r="0.9" />
    </g>
  </svg>
`;

const physicsMap = `
  <svg class="detail-svg physics-svg" viewBox="0 0 420 220" role="img" aria-label="Animated physics detail map">
    <rect width="420" height="220" rx="18"></rect>
    <path class="metric-grid" d="M30 154 C92 108, 142 108, 208 150 C274 190, 338 166, 390 104"></path>
    <path class="metric-grid second" d="M30 88 C96 128, 146 132, 208 98 C280 58, 342 70, 390 120"></path>
    <circle class="detail-core" cx="210" cy="112" r="28"></circle>
    <g class="detail-nodes">
      <circle cx="84" cy="82" r="7"></circle>
      <circle cx="158" cy="154" r="7"></circle>
      <circle cx="282" cy="70" r="7"></circle>
      <circle cx="338" cy="146" r="7"></circle>
    </g>
  </svg>
`;

const agentMap = `
  <svg class="detail-svg agent-svg" viewBox="0 0 420 220" role="img" aria-label="Animated AI research-agent detail map">
    <rect width="420" height="220" rx="18"></rect>
    <path class="agent-route" d="M54 112 H132 C168 112, 168 64, 204 64 H360"></path>
    <path class="agent-route second" d="M54 112 H132 C168 112, 168 160, 204 160 H360"></path>
    <g class="agent-node-group">
      <circle cx="54" cy="112" r="18"></circle>
      <circle cx="204" cy="64" r="18"></circle>
      <circle cx="204" cy="160" r="18"></circle>
      <circle cx="360" cy="64" r="18"></circle>
      <circle cx="360" cy="160" r="18"></circle>
    </g>
  </svg>
`;
---

<BaseLayout
  title="The Æther Flow Project | Exact Closure and Open Foundations"
  description={`${homeCurrentResult.exactWording} ${homeOpenFoundation.exactWording}`}
  bodyClass="project-overview-page home-page"
  exactTitle
>
  <CommandBand
    className="overview-shell overview-command-hero"
    eyebrow="Dual research program"
    title="The Æther Flow Project"
    lead="Explore a proposed Æther / Æther-Flow ontology, its exact effective gravity package, the open foundational derivation, and the governed research system used to test each step."
    headingLevel="h1"
  >
    <nav class="home-action-row" aria-label="Homepage primary actions">
      <a class="primary-link" href="#ontology-and-gr">Ontology and GR</a>
      <a class="secondary-link" href="/physics/">Physics</a>
      <a class="secondary-link" href="/ai-research-system/">AI Research</a>
      <a class="secondary-link" href="/documents/">Documents</a>
    </nav>

    <Fragment slot="visual">
      <figure class="field-stage" aria-labelledby="home-field-stage-caption">
        <Fragment set:html={heroFieldMap} />
        <figcaption id="home-field-stage-caption">
          The project has two public reading tracks: physics
          interpretation and AI-assisted research discipline, both downstream
          from source authority.
        </figcaption>
      </figure>
    </Fragment>
  </CommandBand>

  <ProjectIntroduction paragraphs={homeProjectIntroduction} className="home-intro-panel" />

  <CommandBand
    id="overview-paths"
    className="overview-panel overview-command-band overview-track-command"
    eyebrow="Two first-class tracks"
    title="Two research tracks, one authority boundary."
    lead="The Home route separates the physics research track from the AI research system while keeping both downstream from reviewed source records."
  >
    <EvidenceRail
      items={trackRailItems}
      ariaLabel="Primary research tracks"
      className="overview-track-rail"
    />

    <Fragment slot="visual">
      <div class="overview-track-scenes" aria-label="Track detail maps">
        <figure class="track-scene physics-scene" aria-label="Physics detail map">
          <Fragment set:html={physicsMap} />
        </figure>
        <figure class="track-scene ai-scene" aria-label="AI research-agent detail map">
          <Fragment set:html={agentMap} />
        </figure>
      </div>
    </Fragment>
  </CommandBand>

  <CommandBand
    id="ontology-and-gr"
    className="overview-panel overview-command-band overview-physics-status-command"
    eyebrow="Physics status"
    title="Ontology and GR"
    lead="The ontology page gives vocabulary and model orientation for Æther / Æther-Flow. The GR derivation roadmap remains an open-burden map, not a completed proof or benchmark promotion."
  >
    <EvidenceRail
      items={ontologyStatusRoutes.map((item) => ({ ...item, actionLabel: "Open route" }))}
      ariaLabel="Ontology and GR derivation status routes"
      className="overview-track-rail"
    />

    <Fragment slot="visual">
      <figure class="physics-status-video" aria-labelledby="physics-status-video-caption">
        <div class="physics-status-video-frame">
          <iframe
            src="https://www.youtube-nocookie.com/embed/psbk97rd9T8?start=2&rel=0"
            title="Supplemental video context for the Æther-Flow physics status"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
        <figcaption id="physics-status-video-caption">
          Supplemental video context. Upstream source records remain
          authoritative for project claims and status.
        </figcaption>
      </figure>
    </Fragment>
  </CommandBand>


  <ComprehensionBlocks content={greenfieldRouteDiagramBlocks.home} />

  <CommandBand
    id="project-capabilities"
    className="overview-panel overview-command-band"
    eyebrow="Reader capability routes"
    title="Choose the route that matches your question."
    lead="The greenfield navigation model gives readers three practical choices: inspect the physics research, inspect the AI research system, or use the resources layer for source authority and supporting materials."
  >
    <EvidenceRail
      items={readerCapabilityRoutes.map((route) => ({
        ...route,
        actionLabel: "Open route",
      }))}
      ariaLabel="Reader capability routes"
      className="overview-capability-rail"
      ordered
    />
    <p class="capability-boundary-note">
      These routes help readers follow the project, inspect documents, and
      understand workflow. They do not create scientific authority, prove a GR
      derivation, adopt a physics candidate, or replace upstream source
      records.
    </p>
  </CommandBand>

  <ProjectStatusStrip items={homeStatusItems} />

  <section
    class="track-page-band public-positioning-sequence"
    aria-labelledby="home-positioning-title"
  >
    <div class="track-page-heading">
      <p class="eyebrow">Source-reviewed positioning</p>
      <h2 id="home-positioning-title">Exact closure first, with the foundation kept explicit.</h2>
      <p>
        These statements are consumed directly from the reviewed public-claim
        ladder. Their qualifications preserve the line between effective
        completion, proposed interpretation, and foundational derivation.
      </p>
    </div>
    {homePositioningSteps.map((step) => (
      <article id={step.id} class="track-page-heading public-positioning-step">
        <p class="eyebrow">{step.label}</p>
        <h3><a href={step.href}>{step.title}</a></h3>
        <p>{step.statement.exactWording}</p>
        <details>
          <summary>Read the qualification</summary>
          <p>{step.statement.allowedQualification}</p>
          {step.supportingStatement && (
            <>
              <p>{step.supportingStatement.exactWording}</p>
              <p>{step.supportingStatement.allowedQualification}</p>
            </>
          )}
        </details>
      </article>
    ))}
  </section>

  <SourceAuthoritySection {...sourceNotice} className="overview-panel overview-command-band" />

</BaseLayout>
