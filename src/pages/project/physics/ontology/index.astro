---
import ComprehensionBlocks from "../../../../components/ComprehensionBlocks.astro";
import SourceAuthoritySection from "../../../../components/SourceAuthoritySection.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { physicsOntologyComprehension } from "../../../../lib/comprehensionContent";
import { projectSourceNoticeDefaults } from "../../../../lib/siteContent";

const sourceNotice = projectSourceNoticeDefaults.physicsOntology;

const vocabularyCards = [
  {
    label: "AEther",
    title: "Deeper substrate",
    body: "AEther names the proposed deeper four-dimensional substrate of reality. It is not an ordinary three-dimensional medium sitting inside observed space.",
  },
  {
    label: "AEther-flow",
    title: "Intrinsic ordered motion",
    body: "AEther-flow names ordered motion of that deeper substrate. It is not a wind, river, or directly detectable current through preexisting observed space.",
  },
  {
    label: "Observed space",
    title: "Observer-accessible slice",
    body: "Observed three-dimensional space is the local appearance through which embedded observers encounter the deeper order. It does not exhaust the ontology.",
  },
  {
    label: "S-time",
    title: "Order of change",
    body: "S-time names experienced order among matter, light, and AEther-flow. It is not a second place-like corridor or a substitute for mathematical closure.",
  },
  {
    label: "Observed expansion",
    title: "Appearance of deeper motion",
    body: "Observed expansion is read as a three-dimensional appearance of deeper four-dimensional ordered motion. That does not mean measured expansion is unreal.",
  },
  {
    label: "Gravity language",
    title: "Heuristic reorganization",
    body: "Gravity may be described ontologically as matter reorganizing surrounding AEther-flow. That remains heuristic until registered sources state stronger mathematics.",
  },
];

const layerCards = [
  {
    label: "Ontology",
    title: "What the model is about",
    body: "Ontology gives the project disciplined language for substrate, flow, observed space, time-language, expansion-language, and gravity interpretation.",
  },
  {
    label: "Mathematics",
    title: "What must still be derived",
    body: "A source-side bridge would need to recover observer structure, metric behavior, matter coupling, and closure without importing the target result by hand.",
  },
  {
    label: "Benchmark",
    title: "What remains ordinary GR",
    body: "The current benchmark keeps observable-scale relativistic behavior in the ordinary GR frame while first-principles substrate derivation remains open.",
  },
  {
    label: "Prediction",
    title: "What cannot be inferred here",
    body: "Public website pages cannot create empirical predictions, promote ontology, or certify exact-GR recovery. Those claims require upstream source authority.",
  },
];

const sourceStatusCards = [
  {
    label: "Registered TeX",
    title: "Scientific source authority",
    body: "Current ontology TeX files under ontology/tex/ are registered canonical source files for ontology and benchmark material.",
  },
  {
    label: "PDF derivatives",
    title: "Readable, not independent",
    body: "PDFs under ontology/pdfs/ are generated human-readable derivatives. They do not outrank the registered TeX source.",
  },
  {
    label: "Markdown ontology notes",
    title: "Context and vocabulary",
    body: "Markdown sources such as ontology/aether-and-aether-flow.md explain context and vocabulary without superseding TeX authority.",
  },
  {
    label: "Generated explainers",
    title: "Reader surfaces",
    body: "GitHub-facing explainers and website pages orient readers. They do not promote ontology or create derivation authority.",
  },
  {
    label: "Claim boundaries",
    title: "Overread controls",
    body: "Claim-boundary rows block overreads such as ontology alone forcing GR, generated pages as proof, or benchmark compatibility as derivation.",
  },
  {
    label: "Open derivation",
    title: "Still downstream",
    body: "Observer-response law, same-metric matter, mode control, and Einsteinian closure remain downstream source-side burdens.",
  },
];

const sourceLinks = [
  {
    title: "Back to physics track",
    href: "/project/physics/",
    body: "Return to the track-level map for ontology, benchmark, open derivation, and obstruction boundaries.",
  },
  {
    title: "Ontology Documents",
    href: "/resources/documents/",
    body: "Read the canonical ontology PDFs and download registered TeX source files.",
  },
  {
    title: "Exact-GR benchmark boundary",
    href: "/project/physics/exact-gr-benchmark/",
    body: "Distinguish exact-GR compatibility and benchmark status from first-principles derivation.",
  },
  {
    title: "Distance-to-GR dashboard",
    href: "/project/physics/distance-to-gr/",
    body: "Inspect the burden ledger that keeps ontology, metric, matter coupling, equations, and promotion separate.",
  },
  {
    title: "Claim Boundary Explorer",
    href: "/project/source-authority/claim-boundary-explorer/",
    body: "Read source-pinned allowed, forbidden, and gate-required wording beside ontology vocabulary.",
  },
  {
    title: "Source authority page",
    href: "/project/source-authority/",
    body: "Read how the website separates reader-facing explanation from upstream scientific authority.",
  },
];
---

<BaseLayout
  title="AEther-Flow Ontology"
  description="Reader-facing ontology explainer for AEther / AEther-flow vocabulary, with explicit boundaries around GR derivation and upstream source authority."
  bodyClass="project-overview-page project-track-page"
>
  <section class="track-page-hero" aria-labelledby="ontology-title">
    <div class="track-page-hero-copy">
      <p class="eyebrow">Physics deep dive / Phase 4A</p>
      <h1 id="ontology-title">AEther-Flow Ontology</h1>
      <p class="overview-lead">
        Start here for the plain vocabulary. AEther, AEther-flow, observed
        space, S-time, expansion, and gravity-language name the project's
        ontology. They do not, by themselves, complete a first-principles
        derivation of general relativity. It is not an accepted derivation of
        general relativity.
      </p>
      <div class="overview-actions" aria-label="Ontology page actions">
        <a class="primary-link" href="#ontology-vocabulary">Read the vocabulary</a>
        <a class="secondary-link" href="/resources/documents/">Ontology documents</a>
        <a class="secondary-link" href="#ontology-boundary">Read the boundary</a>
      </div>
    </div>

    <figure class="track-page-figure" aria-labelledby="ontology-figure-caption">
      <svg viewBox="0 0 620 360" role="img" aria-labelledby="ontology-figure-title">
        <title id="ontology-figure-title">Ontology layer map</title>
        <path class="track-figure-bg" d="M0 0H620V360H0Z" />
        <path class="track-figure-path orange-path" d="M90 248 C166 126, 268 104, 352 176 C414 230, 492 218, 542 112" />
        <path class="track-figure-path signal-path" d="M78 136 C168 174, 240 258, 338 220 C434 182, 490 106, 552 160" />
        <circle class="track-figure-core" cx="310" cy="180" r="48" />
        <g class="track-figure-nodes hollow-nodes">
          <circle cx="122" cy="116" r="14" />
          <circle cx="174" cy="262" r="14" />
          <circle cx="462" cy="102" r="14" />
          <circle cx="512" cy="246" r="14" />
        </g>
      </svg>
      <figcaption id="ontology-figure-caption">
        Visual orientation only: the diagram does not establish a source-side
        law, prediction, or GR derivation.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={physicsOntologyComprehension} />

  <section class="track-page-band" aria-labelledby="ontology-vocabulary-title">
    <div class="track-page-heading">
      <p class="eyebrow">Vocabulary map</p>
      <h2 id="ontology-vocabulary-title">Start with the public terms.</h2>
      <p>
        The safe public reading is simple: these terms discipline the
        conceptual language. They do not replace registered source-side
        mathematics or claim-boundary records.
      </p>
    </div>
    <div class="track-status-grid">
      {vocabularyCards.map((card) => (
        <article class="track-status-card">
          <p>{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="ontology-boundary" class="track-page-band" aria-labelledby="ontology-boundary-title">
    <div class="track-page-heading">
      <p class="eyebrow">Claim boundary</p>
      <h2 id="ontology-boundary-title">Ontology, mathematics, benchmark, and prediction remain separate.</h2>
      <p>
        The source materials support a clear distinction. Ontology can say what
        the model is about. It does not, by itself, force the exact-GR
        benchmark or certify a first-principles substrate derivation.
      </p>
    </div>
    <div class="track-status-grid">
      {layerCards.map((card) => (
        <article class="track-status-card">
          <p>{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="ontology-source-status-title">
    <div class="track-page-heading">
      <p class="eyebrow">Specialist source status</p>
      <h2 id="ontology-source-status-title">After the public vocabulary, inspect source authority.</h2>
      <p>
        The live ontology lane separates registered TeX sources, generated PDF
        derivatives, explanatory Markdown, generated reader surfaces, and
        claim-boundary controls.
      </p>
    </div>
    <div class="track-status-grid">
      {sourceStatusCards.map((card) => (
        <article class="track-status-card">
          <p>{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="ontology-sources-title">
    <div class="track-page-heading">
      <p class="eyebrow">Reader path</p>
      <h2 id="ontology-sources-title">Continue through source-boundary-safe routes.</h2>
      <p>
        Use this page as orientation. For stronger claims, inspect the
        document library, benchmark boundary, Distance-to-GR dashboard, and
        claim-boundary explorer.
      </p>
    </div>
    <div class="source-link-grid">
      {sourceLinks.map((link) => (
        <a class="source-link-card" href={link.href}>
          <span>{link.title}</span>
          <small>{link.body}</small>
        </a>
      ))}
    </div>
  </section>

  <SourceAuthoritySection {...sourceNotice} className="track-page-band" />
</BaseLayout>
