---
import ComprehensionBlocks from "../../../../components/ComprehensionBlocks.astro";
import EvidenceRail from "../../../../components/EvidenceRail.astro";
import SourceAuthoritySection from "../../../../components/SourceAuthoritySection.astro";
import StatusDossier from "../../../../components/StatusDossier.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import snapshot from "../../../../data/physics_current_state_snapshot.json";
import { physicsCurrentStateComprehension } from "../../../../lib/comprehensionContent";
import { projectSourceNoticeDefaults } from "../../../../lib/siteContent";

const sourceNotice = projectSourceNoticeDefaults.physicsCurrentState;
const activeBurden = snapshot.derivation_burden.active_row;
const downstreamRows = snapshot.derivation_burden.downstream_rows;
const shortCommit = snapshot.source_commit
  ? `${snapshot.source_commit.slice(0, 12)}...`
  : "Unavailable";

const metadata = [
  {
    label: "Last refreshed from source",
    value: snapshot.source_refresh_date,
  },
  {
    label: "Source commit",
    value: shortCommit,
  },
  {
    label: "Source commit date",
    value: snapshot.source_commit_date ?? "Unavailable",
  },
  {
    label: "Website publication date",
    value: snapshot.website_publication_date,
  },
];

const statusCards = [
  {
    label: "Active task",
    title: snapshot.active_task_id,
    body: "This is the upstream task id reported by program_state.yaml when the website snapshot was refreshed.",
  },
  {
    label: "Latest handoff",
    title: snapshot.latest_handoff_id,
    body: `Created ${snapshot.latest_handoff_created_at}. The handoff is a source-side control record, not a public claim expansion.`,
  },
  {
    label: "Current status",
    title: snapshot.current_status,
    body: "The status is copied from upstream control state and should be read with the blocked claims below.",
  },
  {
    label: "Active burden",
    title: activeBurden.milestone,
    body: `${activeBurden.current_status}. ${activeBurden.blocking_burden}`,
  },
];

const distanceMechanisms = [
  {
    label: "Milestone chain",
    title: "Burden ladder",
    body: "The control map names source ontology, EqSrc, ObsLoc_lc, Resp_lc, M_src, g_eff, matter coupling, Einstein equations, benchmark promotion, and finite toy response as separate obligations.",
  },
  {
    label: "Ledger",
    title: "Persistent row state",
    body: "The Distance-to-GR ledger records each burden's status, blocking burden, acceptance criteria, freeze or failure criteria, evidence path, timestamp, and notes.",
  },
  {
    label: "Task accounting",
    title: "Milestone declared per packet",
    body: "Physics AgentJobs must state the target derivation milestone and exact milestone burden before a task can be treated as derivation work.",
  },
  {
    label: "Delta fields",
    title: "Validation separated from progress",
    body: "Completion records distinguish task validation from physics progress through explicit progress status, distance-to-GR delta, payload manifest, and forbidden conclusions.",
  },
  {
    label: "Freeze control",
    title: "Repeated gaps are classified",
    body: "Obstruction and freeze control prevents repeated orbit around the same gap by requiring route, repair, freeze, or human-gate decisions when a burden recurs.",
  },
];

const distanceStateCards = [
  {
    label: "Active burden",
    title: activeBurden.required_object,
    body: `${activeBurden.current_status}. ${activeBurden.notes}`,
  },
  {
    label: "Control state",
    title: "Project-control closure is not physics progress",
    body: "When the active burden is none, the handoff is reporting control-state closure. It changes no source-law, MetricData(E), g_eff, matter-coupling, equation, benchmark, or completed-derivation status.",
  },
  {
    label: "Downstream",
    title: "Downstream burdens remain separate",
    body: "Einstein-equation recovery and benchmark promotion require their own source-side derivations and protected review. They cannot be inferred from stress survival.",
  },
  {
    label: "Human gate",
    title: "Gate Chair status remains protected",
    body: "The downstream Gate Chair row remains human-gated. Validator PASS, selector routing, and website publication do not issue a protected verdict.",
  },
];
---

<BaseLayout
  title="Current Physics State"
  description="Curated current-state physics snapshot for active task, latest handoff, derivation burden, blocked claims, and next action."
  bodyClass="project-overview-page project-track-page"
>
  <section class="track-page-hero" aria-labelledby="current-state-title">
    <div class="track-page-hero-copy">
      <p class="eyebrow">Physics current-state snapshot</p>
      <h1 id="current-state-title">Current Physics State</h1>
      <p class="overview-lead">
        This page is a reviewed website snapshot of upstream physics control
        state. It helps readers see the active derivation burden, blocked
        claims, and next source-side action without treating the website as
        scientific authority.
      </p>
      <div class="overview-actions" aria-label="Current-state page actions">
        <a class="primary-link" href="#snapshot-status">Project State Snapshot</a>
        <a class="secondary-link" href="/project/physics/">Back to physics track</a>
      </div>
    </div>

    <figure class="track-page-figure" aria-labelledby="current-state-figure-caption">
      <svg viewBox="0 0 620 360" role="img" aria-labelledby="current-state-figure-title">
        <title id="current-state-figure-title">Current physics state boundary map</title>
        <path class="track-figure-bg" d="M0 0H620V360H0Z" />
        <path class="track-figure-path orange-path" d="M78 214 C150 118, 248 112, 318 178 C398 252, 486 234, 546 126" />
        <path class="track-figure-path signal-path" d="M88 132 C178 188, 250 244, 344 200 C420 164, 478 156, 542 214" />
        <circle class="track-figure-core" cx="318" cy="186" r="42" />
        <g class="track-figure-nodes hollow-nodes">
          <circle cx="116" cy="220" r="13" />
          <circle cx="220" cy="118" r="13" />
          <circle cx="438" cy="146" r="13" />
          <circle cx="520" cy="238" r="13" />
        </g>
      </svg>
      <figcaption id="current-state-figure-caption">
        Visual orientation only: source state, website snapshot, and claim
        authority remain distinct.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={physicsCurrentStateComprehension} />

  <section class="track-page-band" aria-labelledby="distance-to-gr-title">
    <div class="track-page-heading">
      <p class="eyebrow">Distance-to-GR state</p>
      <h2 id="distance-to-gr-title">Distance from GR derivation or hard fail</h2>
      <p>
        The active Distance-to-GR burden is {activeBurden.burden_id}. The
        checked-in snapshot reports {activeBurden.current_status.toLowerCase()}
        and preserves the current human-gate boundary. Downstream equations,
        benchmark promotion, and any Gate Chair verdict remain separate
        controlled states, so this page reports burden state rather than a
        numerical completion score.
      </p>
    </div>

    <EvidenceRail
      items={distanceMechanisms}
      ariaLabel="Distance-to-GR mechanism rail"
      className="snapshot-status-grid burden-evidence-rail"
      ordered
    />

    <div class="snapshot-two-column">
      <article class="snapshot-data-card">
        <p class="snapshot-card-label">Reader rule</p>
        <h3>Distance means burden state.</h3>
        <p>
          A row can move, stay blocked, freeze locally, or require human gate
          authority. The page should therefore be read as a status map, not as
          a numerical completion score.
        </p>
      </article>
      <article class="snapshot-data-card">
        <p class="snapshot-card-label">Current boundary</p>
        <h3>Control progress does not unlock GR.</h3>
        <p>
          The current public state preserves the negative boundary: no source-law
          adoption, no MetricData(E) adoption, no g_eff scope change, no adopted
          matter coupling, no Einstein equations, no benchmark promotion, and no
          completed derivation.
        </p>
      </article>
    </div>

    <StatusDossier
      items={distanceStateCards}
      ariaLabel="Current Distance-to-GR state dossier"
      className="track-status-grid snapshot-status-grid"
    />
  </section>

  <section id="snapshot-status" class="track-page-band" aria-labelledby="snapshot-status-title">
    <div class="track-page-heading">
      <p class="eyebrow">Snapshot metadata</p>
      <h2 id="snapshot-status-title">What source state this page reflects.</h2>
      <p>
        The page imports a checked-in JSON snapshot. Normal Astro builds do not
        read the upstream repository or silently refresh public physics text.
      </p>
    </div>

    <StatusDossier
      items={metadata}
      ariaLabel="Snapshot metadata dossier"
      className="snapshot-meta-grid"
    />

    <StatusDossier
      items={statusCards}
      ariaLabel="Snapshot status dossier"
      className="track-status-grid snapshot-status-grid"
    />
  </section>

  <section class="track-page-band" aria-labelledby="snapshot-boundary-title">
    <div class="track-page-heading">
      <p class="eyebrow">Claim boundary</p>
      <h2 id="snapshot-boundary-title">Scoped evidence is not adoption.</h2>
      <p>{snapshot.claim_boundary_summary}</p>
    </div>

    <div class="snapshot-two-column">
      <article class="snapshot-data-card">
        <p class="snapshot-card-label">Latest handoff summary</p>
        <h3>{snapshot.latest_handoff_id}</h3>
        <p>{snapshot.latest_handoff_summary}</p>
      </article>
      <article class="snapshot-data-card">
        <p class="snapshot-card-label">Next recommended action</p>
        <h3>Bounded next packet</h3>
        <p>{snapshot.next_recommended_action}</p>
      </article>
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="snapshot-burden-title">
    <div class="track-page-heading">
      <p class="eyebrow">Derivation burden</p>
      <h2 id="snapshot-burden-title">The active burden remains upstream and scoped.</h2>
      <p>
        The active Distance-to-GR row is shown for reader orientation. It does
        not by itself adopt a coupling law, derive or adopt matter coupling,
        import stress-energy semantics, derive field equations, or promote a
        benchmark.
      </p>
    </div>

    <article class="snapshot-data-card snapshot-wide-card">
      <p class="snapshot-card-label">{activeBurden.burden_id}</p>
      <h3>{activeBurden.required_object}</h3>
      <p>{activeBurden.accept_criteria}</p>
      <p>{activeBurden.failure_or_freeze_criteria}</p>
      <small>Evidence: {activeBurden.last_evidence_path}</small>
    </article>

    <EvidenceRail
      items={downstreamRows.map((row) => ({
        label: row.burden_id,
        title: row.required_object,
        body: `${row.current_status}. ${row.notes}`,
      }))}
      ariaLabel="Downstream derivation burden rail"
      className="snapshot-status-grid burden-evidence-rail"
    />
  </section>

  <section class="track-page-band" aria-labelledby="snapshot-blocked-title">
    <div class="track-page-heading">
      <p class="eyebrow">Blocked claims</p>
      <h2 id="snapshot-blocked-title">What this snapshot explicitly does not authorize.</h2>
      <p>
        These strings are preserved from the latest upstream handoff. They are
        displayed because the negative boundary is part of the reader-facing
        status, not an incidental footnote.
      </p>
    </div>

    <ul class="snapshot-claim-list">
      {snapshot.blocked_claims.map((claim) => (
        <li>{claim}</li>
      ))}
    </ul>
  </section>

  <section class="track-page-band" aria-labelledby="snapshot-sources-title">
    <div class="track-page-heading">
      <p class="eyebrow">Source provenance</p>
      <h2 id="snapshot-sources-title">Inspect source records without making them the primary journey.</h2>
      <p>
        Primary reading stays inside the website. These pinned links are
        provided for provenance and review.
      </p>
    </div>
    <EvidenceRail
      items={snapshot.source_provenance_links.map((link) => ({
        title: link.label,
        href: link.href,
        body: "Pinned upstream source dependency for this reviewed snapshot.",
        actionLabel: "Inspect source",
      }))}
      ariaLabel="Current-state source provenance rail"
      className="source-link-grid snapshot-source-grid source-evidence-rail"
    />
  </section>

  <SourceAuthoritySection {...sourceNotice} className="track-page-band" />
</BaseLayout>
