---
import ComprehensionBlocks from "../../../../components/ComprehensionBlocks.astro";
import SourceAuthoritySection from "../../../../components/SourceAuthoritySection.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { physicsBenchmarkComprehension } from "../../../../lib/comprehensionContent";
import { projectSourceNoticeDefaults } from "../../../../lib/siteContent";

const sourceNotice = projectSourceNoticeDefaults.physicsExactGrBenchmark;

const contrastCards = [
  {
    label: "Matching a benchmark",
    title: "Use ordinary GR as the reference",
    body: "The page can say observable-scale behavior is held against exact GR: one operative metric, ordinary causal structure, and ordinary same-metric matter behavior.",
  },
  {
    label: "Deriving a benchmark",
    title: "Force it from source ontology",
    body: "A derivation would need source-side mathematics that recovers metric behavior, universal matter coupling, equations, and closure without importing GR by hand.",
  },
  {
    label: "Promoting a benchmark",
    title: "Require protected authority",
    body: "Benchmark promotion is a gated source-authority change. A public page, validator, handoff, or generated derivative cannot issue it.",
  },
];

const benchmarkCards = [
  {
    label: "Observable scale",
    title: "Ordinary GR behavior",
    body: "Under the current benchmark framing, observable-scale physics remains ordinary general relativity rather than a claimed empirical deviation from it.",
  },
  {
    label: "Metric",
    title: "One operative Lorentzian metric",
    body: "The benchmark keeps the reader inside the standard metric description. Public pages must not claim a new effective metric has been derived from substrate data.",
  },
  {
    label: "Matter",
    title: "Universal matter coupling",
    body: "The conservative benchmark preserves ordinary same-metric matter behavior. A derivation of universal coupling remains part of the open source-side burden.",
  },
  {
    label: "Causality",
    title: "Standard causal structure",
    body: "The benchmark keeps standard relativistic causal structure at observable scale. It does not authorize a public claim that substrate equations have forced that structure.",
  },
];

const boundaryCards = [
  {
    label: "Adoption",
    title: "What is taken over operationally",
    body: "Adoption means the project uses exact GR as the current observable-scale benchmark for the public physics track.",
  },
  {
    label: "Compatibility",
    title: "What can sit beside the ontology",
    body: "Compatibility means AEther / AEther-flow language is held beside the benchmark without claiming a completed source-side recovery.",
  },
  {
    label: "Derivation",
    title: "What remains open",
    body: "Derivation would require source-side construction of metric behavior, matter coupling, equations, and closure without importing the target result by hand.",
  },
  {
    label: "Promotion",
    title: "What stays gated",
    body: "Benchmark promotion depends on upstream authority and human gates. Generated website prose cannot issue a Gate Chair decision.",
  },
];

const specialistCards = [
  {
    label: "Burden map",
    title: "Required derivation chain",
    body: "The GR derivation burden map separates source ontology, localization, response, M_src, g_eff, matter coupling, equations, and promotion.",
  },
  {
    label: "Distance ledger",
    title: "Current row status",
    body: "The Distance-to-GR ledger tracks which burdens are accepted, blocked, human-gated, frozen, or still downstream.",
  },
  {
    label: "TeX registry",
    title: "Registered source status",
    body: "The TeX registry names canonical ontology package files and their claim status; PDFs remain generated derivatives.",
  },
  {
    label: "Claim boundaries",
    title: "Forbidden promotion",
    body: "Claim-boundary rows block completed-derivation, g_eff, matter-coupling, Einstein-equation, and benchmark-promotion overreads.",
  },
];

const sourceLinks = [
  {
    title: "Back to physics track",
    href: "/physics/",
    body: "Return to the track-level map for ontology, benchmark, open derivation, and obstruction boundaries.",
  },
  {
    title: "Current physics state",
    href: "/physics/claim-status/",
    body: "Check the latest source-state snapshot before treating benchmark language as current status.",
  },
  {
    title: "Distance-to-GR dashboard",
    href: "/physics/open-burdens/",
    body: "Inspect the burden ledger that separates source, metric, matter, equations, and promotion rows.",
  },
  {
    title: "AEther / AEther-flow ontology",
    href: "/physics/ontology/",
    body: "Read the ontology vocabulary without treating it as a completed derivation.",
  },
  {
    title: "Claim Boundary Explorer",
    href: "/physics/claim-status/",
    body: "Inspect source-pinned allowed, forbidden, and gate-required benchmark wording.",
  },
  {
    title: "Research Articles",
    href: "/documents/research/",
    body: "Read canonical ontology PDFs and download registered TeX source files relevant to the benchmark package.",
  },
  {
    title: "Source authority page",
    href: "/documents/governance/source-authority/",
    body: "Read how the website separates reader-facing explanation from upstream scientific authority.",
  },
];
---

<BaseLayout
  title="Exact-GR Benchmark Boundary"
  description="Reader-facing exact-GR benchmark boundary page separating ordinary-GR observable behavior, compatibility, open derivation, and benchmark promotion."
  bodyClass="project-overview-page project-track-page"
>
  <section class="track-page-hero" aria-labelledby="benchmark-title">
    <div class="track-page-hero-copy">
      <p class="eyebrow">Physics deep dive / Phase 4B</p>
      <h1 id="benchmark-title">Exact-GR Benchmark Boundary</h1>
      <p class="overview-lead">
        AEther Flow uses exact general relativity as a conservative public
        benchmark. At observable scale, the current benchmark framing keeps
        behavior ordinary GR. Matching or using that benchmark is not the same
        as deriving it from AEther / AEther-flow source ontology, and it is not
        benchmark promotion.
      </p>
      <div class="overview-actions" aria-label="Benchmark page actions">
        <a class="primary-link" href="#benchmark-contrast">Compare the claims</a>
        <a class="secondary-link" href="/physics/open-burdens/">Distance-to-GR</a>
        <a class="secondary-link" href="#benchmark-boundary">Read the boundary</a>
      </div>
    </div>

    <figure class="track-page-figure" aria-labelledby="benchmark-figure-caption">
      <svg viewBox="0 0 620 360" role="img" aria-labelledby="benchmark-figure-title">
        <title id="benchmark-figure-title">Exact-GR benchmark boundary map</title>
        <path class="track-figure-bg" d="M0 0H620V360H0Z" />
        <path class="track-figure-path orange-path" d="M78 214 C154 120, 242 116, 318 178 C390 236, 482 236, 546 142" />
        <path class="track-figure-path signal-path" d="M88 132 C178 194, 246 236, 330 210 C430 178, 476 98, 546 176" />
        <circle class="track-figure-core" cx="316" cy="184" r="46" />
        <g class="track-figure-nodes hollow-nodes">
          <circle cx="126" cy="112" r="14" />
          <circle cx="156" cy="252" r="14" />
          <circle cx="480" cy="110" r="14" />
          <circle cx="512" cy="252" r="14" />
        </g>
      </svg>
      <figcaption id="benchmark-figure-caption">
        Visual orientation only: the diagram separates benchmark adoption from
        compatibility, derivation, and promotion.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={physicsBenchmarkComprehension} />

  <section id="benchmark-contrast" class="track-page-band" aria-labelledby="benchmark-contrast-title">
    <div class="track-page-heading">
      <p class="eyebrow">Public contrast</p>
      <h2 id="benchmark-contrast-title">Matching the benchmark is weaker than deriving it.</h2>
      <p>
        This is the central reading rule. Exact GR can be the public benchmark
        while first-principles substrate derivation and protected promotion
        remain open.
      </p>
    </div>
    <div class="track-status-grid">
      {contrastCards.map((card) => (
        <article class="track-status-card">
          <p>{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="benchmark-plain-title">
    <div class="track-page-heading">
      <p class="eyebrow">Plain-language boundary</p>
      <h2 id="benchmark-plain-title">The benchmark keeps public physics ordinary at observable scale.</h2>
      <p>
        The conservative reader rule is simple: exact GR is the operative
        benchmark, and no website page should transform that benchmark into a
        claimed source-side derivation.
      </p>
    </div>
    <div class="track-status-grid">
      {benchmarkCards.map((card) => (
        <article class="track-status-card">
          <p>{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="benchmark-boundary" class="track-page-band" aria-labelledby="benchmark-boundary-title">
    <div class="track-page-heading">
      <p class="eyebrow">Claim states</p>
      <h2 id="benchmark-boundary-title">Adoption, compatibility, derivation, and promotion are different claims.</h2>
      <p>
        The source materials keep these states separate. Compatibility with an
        ontology is weaker than derivation, and derivation is weaker than
        benchmark promotion by the appropriate upstream authority.
      </p>
    </div>
    <div class="track-status-grid">
      {boundaryCards.map((card) => (
        <article class="track-status-card">
          <p>{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="benchmark-specialist-title">
    <div class="track-page-heading">
      <p class="eyebrow">Specialist source layer</p>
      <h2 id="benchmark-specialist-title">The source records name what remains open.</h2>
      <p>
        Technical readers should inspect the burden map, Distance-to-GR
        ledger, TeX registry, and claim-boundary registry before treating any
        benchmark sentence as proof.
      </p>
    </div>
    <div class="track-status-grid">
      {specialistCards.map((card) => (
        <article class="track-status-card">
          <p>{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="benchmark-sources-title">
    <div class="track-page-heading">
      <p class="eyebrow">Reader path</p>
      <h2 id="benchmark-sources-title">Use this page as a boundary map, not as proof.</h2>
      <p>
        Stronger physics claims require upstream source authority, registered
        TeX, claim-boundary records, and gated review where the source system
        requires it.
      </p>
    </div>
    <div class="source-link-grid">
      {sourceLinks.map((link) => (
        <a class="source-link-card" href={link.href}>
          <span>{link.title}</span>
          <small>{link.body}</small>
        </a>
      ))}
    </div>
  </section>

  <SourceAuthoritySection {...sourceNotice} className="track-page-band" />
</BaseLayout>
