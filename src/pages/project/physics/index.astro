---
import SourceNotice from "../../../components/SourceNotice.astro";
import ProjectRouteGrid from "../../../components/ProjectRouteGrid.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  projectPhysicsDeepDiveRoutes,
  projectSourceNoticeDefaults,
} from "../../../lib/siteContent";

const sourceNotice = projectSourceNoticeDefaults.physicsTrack;

const statusLayers = [
  {
    label: "Ontology",
    title: "AEther / AEther-flow",
    body: "The ontology gives the project its conceptual vocabulary: a proposed deeper four-dimensional substrate and ordered flow. It is an explanatory frame, not a completed derivation.",
  },
  {
    label: "Benchmark",
    title: "Exact-GR boundary",
    body: "The public benchmark keeps observable-scale behavior ordinary: one operative Lorentzian metric, universal matter coupling, and standard causal structure.",
  },
  {
    label: "Open burden",
    title: "GR derivation remains open",
    body: "The source-side work must still show how effective Lorentzian geometry, matter coupling, and the field-equation burden arise without importing the target metric by hand.",
  },
  {
    label: "Control",
    title: "No-go and obstruction records",
    body: "Negative results, freeze labels, and human gates preserve scoped failures without inflating them into global rejection or success.",
  },
];

const journeyLinks = [
  {
    title: "Current physics state",
    href: "/project/physics/current-state/",
    body: "Review the latest checked-in status snapshot for active task, handoff, burden, blocked claims, and next action.",
  },
  {
    title: "Ontology Documents",
    href: "/resources/documents/",
    body: "Read PDF derivatives and download registered TeX source files for the canonical ontology package.",
  },
  {
    title: "AEther / AEther-flow ontology",
    href: "/project/physics/ontology/",
    body: "Vocabulary and source-authority boundary for the ontology track.",
  },
  {
    title: "Exact-GR benchmark boundary",
    href: "/project/physics/exact-gr-benchmark/",
    body: "Benchmark compatibility and first-principles derivation remain separate.",
  },
];
---

<BaseLayout
  title="Physics Research"
  description="Physics track landing page for AEther Flow ontology, exact-GR benchmark boundary, open derivation burden, and obstruction discipline."
  bodyClass="project-overview-page project-track-page"
>
  <section class="track-page-hero" aria-labelledby="physics-title">
    <div class="track-page-hero-copy">
      <p class="eyebrow">Physics research track</p>
      <h1 id="physics-title">Physics Research</h1>
      <p class="overview-lead">
        The physics track studies whether ordinary general relativity can be
        interpreted, and eventually derived, from an AEther / AEther-flow
        ontology while keeping the current public benchmark exactly ordinary GR
        at observable scale.
      </p>
      <div class="overview-actions" aria-label="Physics page actions">
        <a class="primary-link" href="#physics-status">Read the track status</a>
        <a class="secondary-link" href="/project/overview/">Back to overview</a>
      </div>
    </div>

    <figure class="track-page-figure physics-figure" aria-labelledby="physics-figure-caption">
      <svg
        class="track-map-svg physics-boundary-svg"
        viewBox="0 0 620 360"
        role="img"
        aria-labelledby="physics-figure-title physics-figure-desc"
      >
        <title id="physics-figure-title">Animated physics claim boundary map</title>
        <desc id="physics-figure-desc">
          Ontology substrate, exact-GR benchmark boundary, open derivation burden,
          and obstruction control records are shown as separate animated layers.
        </desc>
        <defs>
          <radialGradient id="physics-glow" cx="50%" cy="48%" r="70%">
            <stop offset="0%" stop-color="#fff3c3" stop-opacity="0.72" />
            <stop offset="34%" stop-color="#ffad21" stop-opacity="0.24" />
            <stop offset="76%" stop-color="#13110d" stop-opacity="0.16" />
            <stop offset="100%" stop-color="#000000" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="physics-gold-rail" x1="12%" x2="88%" y1="50%" y2="50%">
            <stop offset="0%" stop-color="#ffad21" stop-opacity="0" />
            <stop offset="34%" stop-color="#ffad21" stop-opacity="0.9" />
            <stop offset="64%" stop-color="#fff0bc" stop-opacity="0.8" />
            <stop offset="100%" stop-color="#e8ddc1" stop-opacity="0" />
          </linearGradient>
          <linearGradient id="physics-signal-rail" x1="10%" x2="90%" y1="50%" y2="50%">
            <stop offset="0%" stop-color="#e8ddc1" stop-opacity="0" />
            <stop offset="28%" stop-color="#e8ddc1" stop-opacity="0.78" />
            <stop offset="72%" stop-color="#fff6dc" stop-opacity="0.72" />
            <stop offset="100%" stop-color="#ffad21" stop-opacity="0" />
          </linearGradient>
          <filter id="physics-bloom" x="-20%" y="-24%" width="140%" height="148%">
            <feGaussianBlur stdDeviation="4.5" result="physicsBlur" />
            <feMerge>
              <feMergeNode in="physicsBlur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
        <rect class="track-figure-bg" width="620" height="360" rx="24" />
        <circle class="physics-glow" cx="310" cy="178" r="194" />
        <g class="physics-grid" aria-hidden="true">
          <path d="M72 72 H548" />
          <path d="M72 144 H548" />
          <path d="M72 216 H548" />
          <path d="M72 288 H548" />
          <path d="M148 50 V310" />
          <path d="M310 50 V310" />
          <path d="M472 50 V310" />
        </g>
        <g class="physics-substrate" filter="url(#physics-bloom)" aria-hidden="true">
          <path d="M70 232 C142 170, 214 256, 300 184 C386 112, 454 188, 552 116" />
          <path d="M76 126 C156 190, 230 106, 312 170 C392 232, 466 142, 548 202" />
          <path d="M110 282 C184 230, 260 240, 336 274 C414 310, 488 272, 548 236" />
        </g>
        <g class="physics-benchmark" aria-hidden="true">
          <ellipse cx="310" cy="178" rx="146" ry="82" />
          <ellipse cx="310" cy="178" rx="196" ry="118" />
        </g>
        <g class="physics-burden-rails" filter="url(#physics-bloom)" aria-hidden="true">
          <path class="track-figure-path gold-path physics-flow-path primary" d="M92 238 C168 190, 224 172, 310 178 C398 184, 454 162, 528 108" />
          <path class="track-figure-path signal-path physics-flow-path" d="M92 122 C176 160, 242 206, 310 178 C384 148, 452 156, 528 218" />
          <path class="track-figure-path gold-path physics-flow-path alternate" d="M146 286 C228 248, 270 222, 310 178 C354 130, 404 94, 486 78" />
        </g>
        <g class="physics-control-markers" aria-hidden="true">
          <path d="M94 88 L126 72 L158 88 L158 124 L126 140 L94 124 Z" />
          <path d="M462 232 L494 216 L526 232 L526 268 L494 284 L462 268 Z" />
        </g>
        <circle class="track-figure-core physics-burden-core" cx="310" cy="178" r="40" aria-hidden="true" />
        <g class="track-figure-nodes physics-boundary-nodes" aria-hidden="true">
          <circle cx="92" cy="238" r="7" />
          <circle cx="92" cy="122" r="7" />
          <circle cx="146" cy="286" r="7" />
          <circle cx="310" cy="178" r="9" />
          <circle cx="528" cy="108" r="7" />
          <circle cx="528" cy="218" r="7" />
          <circle cx="486" cy="78" r="7" />
        </g>
      </svg>
      <figcaption id="physics-figure-caption">
        Visual orientation only: ontology, benchmark, derivation burden, and
        obstruction records remain separate claim states.
      </figcaption>
    </figure>
  </section>

  <section id="physics-status" class="track-page-band" aria-labelledby="physics-status-title">
    <div class="track-page-heading">
      <p class="eyebrow">Status model</p>
      <h2 id="physics-status-title">Four boundaries a reader should keep separate.</h2>
      <p>
        The safe public reading is conservative. The page can explain the
        track, but source-side science and claim promotion remain upstream.
      </p>
    </div>
    <div class="track-status-grid">
      {statusLayers.map((layer) => (
        <article class="track-status-card">
          <p>{layer.label}</p>
          <h3>{layer.title}</h3>
          <p>{layer.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="physics-next-title">
    <div class="track-page-heading">
      <p class="eyebrow">Where to go next</p>
      <h2 id="physics-next-title">Use active pages now; treat later routes as planned.</h2>
      <p>
        The physics reading path stays inside the website first. Source links
        remain available in boundary and provenance sections for inspection.
      </p>
    </div>

    <div class="source-link-grid">
      {journeyLinks.map((link) => (
        <a class="source-link-card" href={link.href}>
          <span>{link.title}</span>
          <small>{link.body}</small>
        </a>
      ))}
    </div>

    <ProjectRouteGrid routes={projectPhysicsDeepDiveRoutes} ariaLabel="Physics routes" />
  </section>

  <section class="track-page-band track-page-notice" aria-labelledby="physics-authority-title">
    <div>
      <p class="eyebrow">Source authority</p>
      <h2 id="physics-authority-title">What this page can and cannot establish.</h2>
      <p>
        This website page can organize the physics reading path. It cannot
        promote ontology, certify benchmark recovery, complete the derivation,
        issue a Gate Chair decision, or turn generated documentation into
        scientific authority.
      </p>
    </div>
    <SourceNotice
      claimStatus={sourceNotice.claimStatus}
      updated={sourceNotice.updated}
      note={sourceNotice.note}
      sourceRefs={sourceNotice.sourceRefs}
    />
  </section>
</BaseLayout>
