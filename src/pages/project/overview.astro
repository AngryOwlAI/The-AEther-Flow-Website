---
import SourceNotice from "../../components/SourceNotice.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const physicsDetails = [
  "Æther / Æther-flow ontology",
  "Exact-GR benchmark package",
  "Open GR-derivation problem",
  "No-go and obstruction record",
];

const aiDetails = [
  "AI research-agent workflow",
  "Role contracts and governed skills",
  "Claim gates, review, and refutation discipline",
  "Source-first memory, wiki, and registries",
];

const readerJourneys = [
  {
    title: "Start with physics",
    href: "/project/physics/",
    body: "Ontology, exact-GR benchmark boundary, open derivation roadmap, and claim gates.",
  },
  {
    title: "Understand the AI system",
    href: "/project/ai-research-agent-system/",
    body: "Research-agent workflow, roles, memory, registries, and parent-child synthesis.",
  },
  {
    title: "Inspect operations",
    href: "/project/operations/",
    body: "Routing, AgentJobs, validators, publication process, project-system improvement, and tools.",
  },
  {
    title: "Check source authority",
    href: "/project/source-authority/",
    body: "How website pages, source records, registries, generated surfaces, and derivatives differ.",
  },
  {
    title: "Read ontology documents",
    href: "/resources/documents/",
    body: "Direct PDF reading and TeX downloads for the canonical ontology package.",
  },
];

const physicsMap = `
  <svg class="detail-svg physics-svg" viewBox="0 0 420 220" role="img" aria-label="Animated physics detail map">
    <rect width="420" height="220" rx="18"></rect>
    <path class="metric-grid" d="M30 154 C92 108, 142 108, 208 150 C274 190, 338 166, 390 104"></path>
    <path class="metric-grid second" d="M30 88 C96 128, 146 132, 208 98 C280 58, 342 70, 390 120"></path>
    <circle class="detail-core" cx="210" cy="112" r="28"></circle>
    <g class="detail-nodes">
      <circle cx="84" cy="82" r="7"></circle>
      <circle cx="158" cy="154" r="7"></circle>
      <circle cx="282" cy="70" r="7"></circle>
      <circle cx="338" cy="146" r="7"></circle>
    </g>
    <text x="34" y="40">ontology</text>
    <text x="250" y="194">open derivation gap</text>
  </svg>
`;

const agentMap = `
  <svg class="detail-svg agent-svg" viewBox="0 0 420 220" role="img" aria-label="Animated AI research-agent detail map">
    <rect width="420" height="220" rx="18"></rect>
    <path class="agent-route" d="M54 112 H132 C168 112, 168 64, 204 64 H360"></path>
    <path class="agent-route second" d="M54 112 H132 C168 112, 168 160, 204 160 H360"></path>
    <g class="agent-node-group">
      <circle cx="54" cy="112" r="18"></circle>
      <circle cx="204" cy="64" r="18"></circle>
      <circle cx="204" cy="160" r="18"></circle>
      <circle cx="360" cy="64" r="18"></circle>
      <circle cx="360" cy="160" r="18"></circle>
    </g>
    <text x="32" y="42">route</text>
    <text x="172" y="112">check</text>
    <text x="304" y="112">review</text>
  </svg>
`;
---

<BaseLayout
  title="Project Overview"
  description="General-public overview for Æther Flow as a dual physics-and-AI research program."
  bodyClass="project-overview-page"
>
  <section class="overview-shell" aria-labelledby="overview-title">
    <div class="overview-hero">
      <div class="overview-hero-copy">
        <p class="eyebrow">Dual research program</p>
        <h1 id="overview-title">Æther Flow</h1>
        <p class="overview-lead">
          A dual physics-and-AI research program exploring an Æther-flow
          interpretation of relativity and the research-agent system built to
          pursue it.
        </p>
        <div class="overview-actions" aria-label="Primary reader actions">
          <a class="primary-link" href="#overview-paths">Understand the project</a>
          <a class="secondary-link" href="/project/physics/">Explore physics research</a>
          <a class="secondary-link" href="/project/ai-research-agent-system/">
            Explore the AI research system
          </a>
        </div>
      </div>

      <figure class="field-stage" aria-labelledby="field-stage-caption">
        <svg viewBox="0 0 680 420" role="img" aria-labelledby="field-stage-title">
          <title id="field-stage-title">Animated two-track Æther Flow luminous field map</title>
          <defs>
            <radialGradient id="field-flare" cx="52%" cy="49%" r="58%">
              <stop offset="0%" stop-color="#fff9d9" />
              <stop offset="14%" stop-color="#ffd56a" stop-opacity="0.96" />
              <stop offset="34%" stop-color="#ff8b1d" stop-opacity="0.72" />
              <stop offset="58%" stop-color="#c9bda0" stop-opacity="0.22" />
              <stop offset="100%" stop-color="#000000" stop-opacity="0" />
            </radialGradient>
            <linearGradient id="smoke-ribbon" x1="0%" x2="100%" y1="50%" y2="50%">
              <stop offset="0%" stop-color="#050403" stop-opacity="0" />
              <stop offset="38%" stop-color="#8c8069" stop-opacity="0.52" />
              <stop offset="58%" stop-color="#fff4d2" stop-opacity="0.82" />
              <stop offset="100%" stop-color="#6f6048" stop-opacity="0.12" />
            </linearGradient>
            <linearGradient id="gold-ribbon" x1="0%" x2="100%" y1="50%" y2="50%">
              <stop offset="0%" stop-color="#120400" stop-opacity="0" />
              <stop offset="35%" stop-color="#ff7a00" stop-opacity="0.72" />
              <stop offset="57%" stop-color="#fff5c4" stop-opacity="0.92" />
              <stop offset="100%" stop-color="#ff9d00" stop-opacity="0.2" />
            </linearGradient>
            <filter id="field-bloom" x="-18%" y="-34%" width="136%" height="168%">
              <feGaussianBlur stdDeviation="7" result="bloom" />
              <feMerge>
                <feMergeNode in="bloom" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
            <filter id="flare-bloom" x="-90%" y="-90%" width="280%" height="280%">
              <feGaussianBlur stdDeviation="10" result="flareBlur" />
              <feColorMatrix
                in="flareBlur"
                type="matrix"
                values="1.2 0 0 0 0  0 1.02 0 0 0  0 0 0.72 0 0  0 0 0 1 0"
                result="warmBlur"
              />
              <feMerge>
                <feMergeNode in="warmBlur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
          </defs>
          <rect class="stage-void" width="680" height="420" rx="28" />
          <g class="cosmic-dust" aria-hidden="true">
            <circle cx="54" cy="82" r="0.9" />
            <circle cx="92" cy="306" r="1.1" />
            <circle cx="132" cy="148" r="0.7" />
            <circle cx="190" cy="64" r="1.3" />
            <circle cx="250" cy="340" r="0.8" />
            <circle cx="316" cy="108" r="0.9" />
            <circle cx="384" cy="320" r="1" />
            <circle cx="498" cy="88" r="1.1" />
            <circle cx="566" cy="270" r="0.9" />
            <circle cx="620" cy="142" r="1.2" />
          </g>
          <g class="field-ribbons smoke-field" filter="url(#field-bloom)" aria-hidden="true">
            <path class="ribbon wash" d="M-18 286 C124 218, 236 206, 402 216 C505 222, 594 188, 720 106" />
            <path class="ribbon bright" d="M-10 272 C128 218, 244 208, 404 216 C516 222, 596 198, 714 132" />
            <path class="ribbon fine" d="M34 338 C166 254, 276 228, 404 218 C516 210, 604 244, 704 308" />
            <path class="ribbon fine alternate" d="M88 124 C196 132, 300 162, 404 216 C512 272, 604 306, 708 318" />
          </g>
          <g class="field-ribbons gold-field" filter="url(#field-bloom)" aria-hidden="true">
            <path class="ribbon wash" d="M-28 96 C136 150, 252 202, 404 216 C516 226, 594 150, 724 44" />
            <path class="ribbon bright" d="M-20 110 C142 162, 260 204, 404 216 C520 226, 608 162, 714 70" />
            <path class="ribbon fine" d="M8 376 C142 286, 260 238, 404 218 C522 202, 610 278, 710 372" />
            <path class="ribbon fine alternate" d="M116 34 C220 66, 306 142, 404 216 C520 304, 608 282, 714 206" />
          </g>
          <g class="plasma-filaments smoke-filaments" filter="url(#field-bloom)" aria-hidden="true">
            <path d="M-12 306 C130 246, 244 224, 404 216 C498 212, 596 184, 710 118" />
            <path d="M-4 248 C116 214, 252 204, 404 216 C506 230, 598 220, 704 166" />
            <path d="M64 172 C182 172, 294 184, 404 216 C512 248, 602 270, 720 282" />
            <path d="M138 82 C238 120, 324 172, 404 216 C494 266, 594 304, 714 342" />
            <path d="M34 356 C168 272, 286 234, 404 216 C496 202, 590 224, 706 270" />
          </g>
          <g class="plasma-filaments gold-filaments" filter="url(#field-bloom)" aria-hidden="true">
            <path d="M-24 68 C122 132, 246 188, 404 216 C516 238, 616 168, 724 68" />
            <path d="M30 392 C150 302, 278 242, 404 216 C516 194, 604 260, 718 378" />
            <path d="M108 28 C220 70, 306 146, 404 216 C516 296, 608 280, 724 188" />
            <path d="M308 392 C392 314, 448 254, 498 218 C572 162, 636 106, 724 8" />
            <path d="M468 414 C532 330, 564 248, 612 178 C646 128, 678 88, 724 42" />
          </g>
          <g class="flare-system" filter="url(#flare-bloom)" aria-hidden="true">
            <circle class="field-flare" cx="404" cy="216" r="116" fill="url(#field-flare)" />
            <g class="flare-rays">
              <path d="M280 216 H528" />
              <path d="M404 92 V340" />
              <path d="M316 132 L492 300" />
              <path d="M314 302 L496 130" />
            </g>
            <path class="flare-cross" d="M348 216 H462 M404 160 V272" />
            <path class="lens-arc upper" d="M308 176 C356 132, 430 132, 492 174" />
            <path class="lens-arc lower" d="M304 254 C360 302, 446 294, 506 242" />
          </g>
          <g class="charged-grain" aria-hidden="true">
            <circle cx="354" cy="205" r="1.4" />
            <circle cx="372" cy="232" r="1" />
            <circle cx="390" cy="186" r="1.2" />
            <circle cx="424" cy="236" r="1.1" />
            <circle cx="446" cy="202" r="1.3" />
            <circle cx="468" cy="224" r="0.9" />
          </g>
          <g class="field-labels">
            <text x="56" y="350">Physics research</text>
            <text x="428" y="76">AI research-agent system</text>
          </g>
        </svg>
        <figcaption id="field-stage-caption">
          Two connected tracks: one explores the physics interpretation; one
          develops the AI-assisted research discipline.
        </figcaption>
      </figure>
    </div>
  </section>

  <div id="overview-paths" class="overview-anchor" aria-hidden="true"></div>

  <section
    class="overview-panel"
    aria-labelledby="overview-paths-title"
  >
    <div class="overview-heading">
      <p class="eyebrow">Two first-class tracks</p>
      <h2 id="overview-paths-title">Two paths, one research program.</h2>
      <p>
        The project structure is the first thing a general reader sees:
        physics research and the AI research-agent system are equal first-class
        paths.
      </p>
    </div>
    <div class="track-grid">
      <article class="track-card physics-card">
        <p class="track-label">Physics Research</p>
        <h3>Exploring an Æther-flow interpretation of relativity.</h3>
        <p>
          The physics track studies an ontology, keeps an Exact-GR benchmark as
          a reference point, and treats the GR-derivation problem as open.
        </p>
        <ul>
          {physicsDetails.map((item) => <li>{item}</li>)}
        </ul>
        <details class="track-detail">
          <summary>More detail</summary>
          <div class="detail-grid">
            <Fragment set:html={physicsMap} />
            <p>
              Current public language should preserve the distinction between
              interpretation, benchmark compatibility, open derivation work, and
              obstruction records.
            </p>
          </div>
        </details>
        <a class="track-card-link" href="/project/physics/">Open physics track</a>
      </article>

      <article class="track-card ai-card">
        <p class="track-label">AI Research-Agent System</p>
        <h3>Building the AI-assisted workflow used to pursue the research.</h3>
        <p>
          The AI track organizes research work through bounded tasks, roles,
          review discipline, claim gates, and source-first memory.
        </p>
        <ul>
          {aiDetails.map((item) => <li>{item}</li>)}
        </ul>
        <details class="track-detail">
          <summary>More detail</summary>
          <div class="detail-grid">
            <Fragment set:html={agentMap} />
            <p>
              Public copy should explain the system in plain language before
              introducing internal terms such as AgentJobs, registries, and role
              contracts.
            </p>
          </div>
        </details>
        <a class="track-card-link" href="/project/ai-research-agent-system/">Open AI track</a>
      </article>
    </div>
  </section>

  <section class="overview-panel" aria-labelledby="reader-journeys-title">
    <div class="overview-heading">
      <p class="eyebrow">Reader journeys</p>
      <h2 id="reader-journeys-title">Choose the path that matches your question.</h2>
      <p>
        The website now keeps the primary reading journey internal. Source
        repositories remain available for provenance and inspection.
      </p>
    </div>
    <div class="link-grid">
      {readerJourneys.map((journey) => (
        <a class="link-card" href={journey.href}>
          <span>{journey.title}</span>
          <small>{journey.body}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="overview-panel live-state" aria-labelledby="live-state-title">
    <div>
      <p class="eyebrow">Living project</p>
      <h2 id="live-state-title">The website should follow the source project.</h2>
      <p>
        The Æther Flow project changes as the source research repository
        advances. This website is a public presentation layer intended to be
        refreshed from reviewed project outputs, PDFs, source records, and
        documentation updates.
      </p>
      <a class="track-card-link" href="/project/source-authority/">Read source authority</a>
    </div>
    <SourceNotice
      claimStatus="explanatory overview"
      updated="2026-06-25"
      note="This overview explains the selected public project structure. Future production work should define a sync/update workflow from The-AEther-Flow pushes into website content and manifests."
    />
  </section>
</BaseLayout>
