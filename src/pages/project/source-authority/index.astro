---
import ComprehensionBlocks from "../../../components/ComprehensionBlocks.astro";
import SourceNotice from "../../../components/SourceNotice.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { sourceAuthorityComprehension } from "../../../lib/supportComprehensionContent";
import { projectSourceAuthorityRoutes, projectSourceNoticeDefaults } from "../../../lib/siteContent";

const sourceNotice = projectSourceNoticeDefaults.sourceAuthority;

const authorityLayers = [
  {
    label: "Canonical science",
    title: "Registered TeX",
    body: "Physics and derivational claims belong to registered scientific sources and their stated claim status.",
  },
  {
    label: "Control state",
    title: "Registries",
    body: "CSV registries carry routing, provenance, source-object hashes, generated-output tracking, and memory metadata.",
  },
  {
    label: "Guidance",
    title: "Registered Markdown",
    body: "README files, AGENTS instructions, publication briefs, source specs, role contracts, skills, and design notes guide public and operator work.",
  },
  {
    label: "Derivatives",
    title: "Generated surfaces",
    body: "Website pages, GitHub-facing Markdown, HTML explainers, PDFs, wiki notes, semantic extracts, and local caches orient readers but do not override sources.",
  },
];

const readerRules = [
  {
    label: "Website pages",
    title: "Explain and organize",
    body: "A website page can make the project readable, connect real routes, and state claim status. It cannot create a physics result or change workflow authority.",
  },
  {
    label: "Generated explainers",
    title: "Use as maps",
    body: "Generated public material is useful for orientation after its source binding is known. If it conflicts with a registered source, the source wins.",
  },
  {
    label: "Validator passes",
    title: "Treat as bounded evidence",
    body: "A validator pass means a deterministic check accepted the checked state. It is not a scientific verdict or role-authority grant.",
  },
  {
    label: "Memory and cache",
    title: "Search, then inspect",
    body: "Memory, wiki, semantic extracts, Obsidian mirrors, and local caches help find sources. They are retrieval aids, not citation authority.",
  },
];

const pageLinks = [
  {
    title: "Claim Boundary Explorer",
    href: "/project/source-authority/claim-boundary-explorer/",
    body: "Inspect a source-pinned registry snapshot showing allowed, forbidden, and gate-required wording.",
  },
  {
    title: "Project overview",
    href: "/project/overview/",
    body: "Return to the public two-track overview.",
  },
  {
    title: "Physics Research",
    href: "/project/physics/",
    body: "Read the physics track with the open GR-derivation boundary preserved.",
  },
  {
    title: "AI Research-Agent System",
    href: "/project/ai-research-agent-system/",
    body: "Read the AI workflow track without treating workflow evidence as physics proof.",
  },
  {
    title: "Operations",
    href: "/project/operations/",
    body: "Read operational pages for routing, roles, validation, publication, improvement, and tool requirements.",
  },
  {
    title: "Resources",
    href: "/resources/",
    body: "Inspect ontology documents and current website resource indexes.",
  },
];

const sourceLinks = [
  {
    title: "Upstream source repository",
    href: "https://github.com/AngryOwlAI/The-AEther-Flow",
    body: "Canonical source files, registries, and control records remain upstream.",
  },
  {
    title: "Source authority explainer",
    href: "https://github.com/AngryOwlAI/The-AEther-Flow/blob/main/github-facing/source-authority-explainer.md",
    body: "Reviewed generated noncanonical guide to source authority and derivatives.",
  },
  {
    title: "Publication brief registry",
    href: "https://github.com/AngryOwlAI/The-AEther-Flow/blob/main/registries/PUBLICATION_BRIEF_REGISTRY.csv",
    body: "Registry surface for reviewed public explainer pages and source-material bindings.",
  },
  {
    title: "Claim boundary registry",
    href: "https://github.com/AngryOwlAI/The-AEther-Flow/blob/main/registries/CLAIM_BOUNDARY_REGISTRY.csv",
    body: "Registry source for allowed, forbidden, and gate-required claim language.",
  },
];
---

<BaseLayout
  title="Source Authority"
  description="Public trust and source-boundary page explaining how to read AEther Flow website pages, generated derivatives, and upstream source records."
  bodyClass="project-overview-page project-track-page"
>
  <section class="track-page-hero" aria-labelledby="source-authority-title">
    <div class="track-page-hero-copy">
      <p class="eyebrow">Public trust boundary</p>
      <h1 id="source-authority-title">Source Authority</h1>
      <p class="overview-lead">
        The website is a reader-facing presentation layer. It can explain,
        organize, and link reviewed material, but upstream source files and
        registries decide scientific, mathematical, governance, and workflow
        state.
      </p>
      <div class="overview-actions" aria-label="Source authority page actions">
        <a class="primary-link" href="#authority-ladder">Read the boundary</a>
        <a class="secondary-link" href="/project/overview/">Back to overview</a>
      </div>
    </div>

    <figure class="track-page-figure source-authority-figure" aria-labelledby="source-authority-figure-caption">
      <svg class="source-authority-svg" viewBox="0 0 620 360" role="img" aria-labelledby="source-authority-figure-title source-authority-figure-desc">
        <title id="source-authority-figure-title">Animated source authority boundary map</title>
        <desc id="source-authority-figure-desc">
          Source records, review gates, and reader surfaces are shown as separate animated curved layers.
        </desc>
        <defs>
          <radialGradient id="authority-glow" cx="45%" cy="48%" r="68%">
            <stop offset="0%" stop-color="var(--owl-orange-100)" stop-opacity="0.72" />
            <stop offset="34%" stop-color="var(--owl-orange-500)" stop-opacity="0.28" />
            <stop offset="72%" stop-color="var(--color-dark-page)" stop-opacity="0.18" />
            <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="authority-rail" x1="0%" x2="100%" y1="50%" y2="50%">
            <stop offset="0%" stop-color="var(--owl-orange-500)" stop-opacity="0" />
            <stop offset="24%" stop-color="var(--owl-orange-500)" stop-opacity="0.84" />
            <stop offset="62%" stop-color="var(--owl-orange-100)" stop-opacity="0.78" />
            <stop offset="100%" stop-color="var(--owl-cyan-400)" stop-opacity="0" />
          </linearGradient>
          <filter id="authority-bloom" x="-20%" y="-30%" width="140%" height="160%">
            <feGaussianBlur stdDeviation="5" result="authorityBlur" />
            <feMerge>
              <feMergeNode in="authorityBlur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
        <path class="track-figure-bg" d="M0 0H620V360H0Z" />
        <circle class="authority-glow" cx="304" cy="174" r="190" />
        <g class="authority-grid" aria-hidden="true">
          <ellipse cx="304" cy="174" rx="238" ry="124" />
          <ellipse cx="304" cy="174" rx="170" ry="82" />
          <path d="M72 174 C150 114, 224 96, 304 108 C384 96, 458 114, 536 174" />
          <path d="M72 174 C150 234, 224 252, 304 240 C384 252, 458 234, 536 174" />
        </g>
        <g class="authority-record-currents" filter="url(#authority-bloom)" aria-hidden="true">
          <circle cx="136" cy="101" r="25" />
          <circle cx="136" cy="181" r="25" />
          <circle cx="136" cy="261" r="25" />
          <path d="M136 126 C122 146, 122 164, 136 181 C150 198, 150 220, 136 236" />
        </g>
        <g class="authority-apertures" aria-hidden="true">
          <circle cx="304" cy="134" r="40" />
          <circle cx="304" cy="222" r="40" />
          <path d="M264 134 C286 110, 322 110, 344 134" />
          <path d="M264 222 C286 246, 322 246, 344 222" />
        </g>
        <g class="authority-reader-halo" aria-hidden="true">
          <circle cx="494" cy="97" r="28" />
          <circle cx="484" cy="165" r="28" />
          <circle cx="494" cy="233" r="28" />
          <ellipse cx="494" cy="97" rx="48" ry="18" />
          <ellipse cx="484" cy="165" rx="54" ry="18" />
          <ellipse cx="494" cy="233" rx="48" ry="18" />
        </g>
        <g class="authority-flow" filter="url(#authority-bloom)" aria-hidden="true">
          <path class="track-figure-path orange-path authority-flow-path primary" d="M190 101 C236 102, 256 126, 304 134 C356 142, 392 118, 442 97" />
          <path class="track-figure-path signal-path authority-flow-path" d="M190 181 C238 181, 262 198, 304 222 C354 248, 396 228, 442 233" />
          <path class="track-figure-path orange-path authority-flow-path alternate" d="M190 261 C238 244, 264 168, 304 134 C346 98, 390 156, 424 165" />
        </g>
        <g class="track-figure-nodes authority-node-ring" aria-hidden="true">
          <circle cx="190" cy="101" r="7" />
          <circle cx="190" cy="181" r="7" />
          <circle cx="190" cy="261" r="7" />
          <circle cx="304" cy="134" r="9" />
          <circle cx="304" cy="222" r="9" />
          <circle cx="442" cy="97" r="7" />
          <circle cx="424" cy="165" r="7" />
          <circle cx="442" cy="233" r="7" />
        </g>
        <g class="authority-boundary" aria-hidden="true">
          <path d="M236 56 C218 114, 218 246, 236 304" />
          <path d="M382 56 C400 114, 400 246, 382 304" />
        </g>
      </svg>
      <figcaption id="source-authority-figure-caption">
        Visual orientation only: readable pages are useful maps, not the
        authority that defines project state.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={sourceAuthorityComprehension} />

  <section id="authority-ladder" class="track-page-band" aria-labelledby="authority-ladder-title">
    <div class="track-page-heading">
      <p class="eyebrow">Authority ladder</p>
      <h2 id="authority-ladder-title">Start with the source lane that owns the claim.</h2>
      <p>
        The public trust rule is simple: use website and generated surfaces to
        find the right source, then inspect the registered source file and
        registry row before treating a claim as current.
      </p>
    </div>
    <div class="track-status-grid">
      {authorityLayers.map((layer) => (
        <article class="track-status-card">
          <p>{layer.label}</p>
          <h3>{layer.title}</h3>
          <p>{layer.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="reader-rules-title">
    <div class="track-page-heading">
      <p class="eyebrow">Reader rules</p>
      <h2 id="reader-rules-title">Clear public material still has limited authority.</h2>
      <p>
        A page can be well designed, accurate as a summary, and useful to a
        reader while still remaining downstream from the source record it
        describes.
      </p>
    </div>
    <div class="track-status-grid">
      {readerRules.map((rule) => (
        <article class="track-status-card">
          <p>{rule.label}</p>
          <h3>{rule.title}</h3>
          <p>{rule.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="claim-boundary-explorer-title">
    <div class="track-page-heading">
      <p class="eyebrow">Claim boundaries</p>
      <h2 id="claim-boundary-explorer-title">Make allowed and forbidden wording inspectable.</h2>
      <p>
        The claim-boundary explorer is now the internal route for reading a
        checked-in registry snapshot. It helps readers see what a row permits,
        what it blocks, and what remains gated without turning the website into
        registry authority.
      </p>
    </div>
    <div class="planned-route-grid">
      {projectSourceAuthorityRoutes.map((route) => (
        <a class="planned-route-card planned-route-card-link" href={route.href}>
          <p>{route.phase}</p>
          <h3>{route.title}</h3>
          <span>{route.description}</span>
          <span class="planned-route-action">Open route</span>
        </a>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="source-links-title">
    <div class="track-page-heading">
      <p class="eyebrow">Reading path</p>
      <h2 id="source-links-title">Move between public pages without losing the source boundary.</h2>
      <p>
        These links are real current routes or upstream source surfaces. No
        generated page, including this one, replaces the source material it
        points toward.
      </p>
    </div>
    <div class="source-link-grid">
      {pageLinks.map((link) => (
        <a class="source-link-card" href={link.href}>
          <span>{link.title}</span>
          <small>{link.body}</small>
        </a>
      ))}
    </div>
    <div class="source-link-grid">
      {sourceLinks.map((link) => (
        <a class="source-link-card" href={link.href}>
          <span>{link.title}</span>
          <small>{link.body}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="track-page-band track-page-notice" aria-labelledby="source-authority-notice-title">
    <div>
      <p class="eyebrow">Claim status</p>
      <h2 id="source-authority-notice-title">This page is an orientation surface.</h2>
      <p>
        It cannot change the hierarchy, replace a registry, promote ontology,
        certify a benchmark, issue a Gate Chair verdict, expand roles, modify
        routing behavior, or make generated outputs authoritative.
      </p>
    </div>
    <SourceNotice
      claimStatus={sourceNotice.claimStatus}
      updated={sourceNotice.updated}
      note={sourceNotice.note}
      sourceRefs={sourceNotice.sourceRefs}
    />
  </section>
</BaseLayout>
