---
import ComprehensionBlocks from "../../../../components/ComprehensionBlocks.astro";
import SourceAuthoritySection from "../../../../components/SourceAuthoritySection.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { aiWorkflowComprehension } from "../../../../lib/aiComprehensionContent";
import { projectSourceNoticeDefaults } from "../../../../lib/siteContent";

const sourceNotice = projectSourceNoticeDefaults.aiResearchAgentWorkflow;

const workflowSteps = [
  {
    label: "1. Request",
    title: "Classify before acting",
    body:
      "The operator separates research continuation, project-system repair, documentation, validation, and stop conditions before any write authority exists.",
  },
  {
    label: "2. Memory",
    title: "Use retrieval as navigation",
    body:
      "Memory preflight can find prior decisions and likely sources, but every useful hit must be verified against a canonical file or registry row.",
  },
  {
    label: "3. Decision",
    title: "Select one route",
    body:
      "A Director Decision Record chooses one role path, records the rationale, and keeps rejected alternatives visible when they matter.",
  },
  {
    label: "4. AgentJob",
    title: "Bind one transaction",
    body:
      "The AgentJob names allowed reads, writes, generated paths, forbidden paths, validators, expected outputs, and claim boundary.",
  },
  {
    label: "5. Completion",
    title: "Close with evidence",
    body:
      "The completion records outputs, command results, validation status, verdict, uncertainty, and the next recommendation.",
  },
  {
    label: "6. Handoff",
    title: "Separate the next packet",
    body:
      "A handoff can recommend the next bounded packet. It does not extend the current job after completion.",
  },
];

const exampleMeta = [
  {
    label: "Example task",
    value: "RT-20260614-249",
  },
  {
    label: "Decision",
    value: "DDR-20260614-249",
  },
  {
    label: "AgentJob",
    value: "AJ-RT-20260614-249-001",
  },
  {
    label: "Completion",
    value: "AJC-AJ-RT-20260614-249-001",
  },
  {
    label: "Handoff",
    value: "handoff-0282",
  },
  {
    label: "Verdict",
    value: "selector_selected_stress_energy_interface_criteria_no_adoption",
  },
];

const recordChain = [
  {
    label: "Task",
    path: "research_control/tasks/RT-20260614-249/00_TASK.yaml",
    title: "One objective and closure state",
    body:
      "The task names the objective, parent task, current decision, current job, completion, claim boundary, and closure status.",
    boundary: "It does not authorize adjacent future packets.",
  },
  {
    label: "Director decision",
    path: "research_control/tasks/RT-20260614-249/DDR-20260614-249.md",
    title: "One selected route",
    body:
      "The decision selects a Theoretical Continuation Selector packet and explains why broader routes were not selected.",
    boundary: "It authorizes route classification only.",
  },
  {
    label: "AgentJob",
    path: "research_control/tasks/RT-20260614-249/jobs/AJ-RT-20260614-249-001.yaml",
    title: "Allowed surface",
    body:
      "The job binds reads, writes, generated paths, forbidden paths, validators, outputs, and claim boundary.",
    boundary: "The allowlist is not reusable general permission.",
  },
  {
    label: "Completion",
    path: "research_control/tasks/RT-20260614-249/jobs/completions/AJC-AJ-RT-20260614-249-001.yaml",
    title: "Command and verdict evidence",
    body:
      "The completion records output paths, command results, PASS status, verdict, distance-to-GR notes, and forbidden conclusions.",
    boundary: "PASS is operational evidence for this transaction only.",
  },
  {
    label: "Handoff",
    path: "research_control/handoffs/handoff-0282.yaml",
    title: "Separate next action",
    body:
      "The handoff recommends one future Ontology Formalizer packet and repeats the blocked claims.",
    boundary: "It is not silent extension of the closed job.",
  },
  {
    label: "Registries",
    path: "registries/RESEARCH_TASK_REGISTRY.csv; registries/DIRECTOR_DECISION_REGISTRY.csv; registries/AGENT_JOB_REGISTRY.csv",
    title: "Discovery and checks",
    body:
      "Registry rows make the task, decision, AgentJob, completion, and status discoverable for validators and maintainers.",
    boundary: "Registry metadata is not theorem proof.",
  },
];

const boundaryCards = [
  {
    label: "AI boundary",
    title: "Workflow is not autonomous science",
    body:
      "The page describes governed tool use and source inspection. It does not present model behavior as independent understanding or scientific authority.",
  },
  {
    label: "PASS boundary",
    title: "Validation is scoped",
    body:
      "A PASS receipt says a deterministic check accepted the named state. It does not prove physics, adopt ontology, or promote a benchmark.",
  },
  {
    label: "Memory boundary",
    title: "Retrieval is not authority",
    body:
      "Memory, wiki notes, generated pages, and local caches can help find records. They cannot replace canonical source inspection.",
  },
  {
    label: "Role boundary",
    title: "Templates are not permissions",
    body:
      "A role contract guides reasoning. The execution-role record and AgentJob allowlist define authority for the current transaction.",
  },
  {
    label: "Handoff boundary",
    title: "Next is separate",
    body:
      "A handoff names a possible future packet after the current job closes. It is not a hidden continuation of the same job.",
  },
  {
    label: "Physics boundary",
    title: "Process evidence is not derivation",
    body:
      "The RT-249 example does not adopt a coupling law, derive matter coupling, define Einstein equations, or claim completed derivation.",
  },
];

const relatedLinks = [
  {
    title: "AI research-agent track",
    href: "/ai-research-system/",
    body: "Return to the track landing page for bounded tasks, role contracts, memory, and validators.",
  },
  {
    title: "Roles and skills",
    href: "/ai-research-system/roles-and-schemas/",
    body: "Read how role labels, contracts, execution records, and allowlists differ.",
  },
  {
    title: "Memory and registries",
    href: "/ai-research-system/memory-preflight/",
    body: "Read why retrieval support must resolve back to tracked sources.",
  },
  {
    title: "Director and AgentJob lifecycle",
    href: "/ai-research-system/agentjob-lifecycle/",
    body: "Inspect the operational lifecycle for tasks, decisions, jobs, completions, and handoffs.",
  },
  {
    title: "Validator and operator workflow",
    href: "/ai-research-system/validators-and-handoffs/",
    body: "Read how command evidence and PASS results should be interpreted.",
  },
  {
    title: "Source authority",
    href: "/documents/governance/source-authority/",
    body: "See how website pages, generated explainers, registries, and source records relate.",
  },
];
---

<BaseLayout
  title="Research-Agent Workflow"
  description="Concrete record-chain walkthrough showing how a request narrows into one bounded AgentJob, completion evidence, and handoff without becoming physics proof."
  bodyClass="project-overview-page project-track-page"
>
  <section class="track-page-hero" aria-labelledby="workflow-title">
    <div class="track-page-hero-copy">
      <p class="eyebrow">AI research-agent deep dive / PG-014</p>
      <h1 id="workflow-title">Research-Agent Workflow</h1>
      <p class="overview-lead">
        AEther Flow treats research-agent work as a record chain, not as
        autonomous scientific authority. A request narrows into memory/source
        checks, one Director decision, one AgentJob, completion evidence, and a
        handoff only when the next step is separate.
      </p>
      <div class="overview-actions" aria-label="Research-agent workflow page actions">
        <a class="primary-link" href="#workflow-example">Walk the record chain</a>
        <a class="secondary-link" href="/ai-research-system/validators-and-handoffs/">PASS limits</a>
      </div>
    </div>

    <figure class="track-page-figure" aria-labelledby="workflow-figure-caption">
      <svg viewBox="0 0 620 360" role="img" aria-labelledby="workflow-figure-title workflow-figure-desc">
        <title id="workflow-figure-title">Bounded research-agent workflow map</title>
        <desc id="workflow-figure-desc">
          A request narrows through source checks, a decision point, one
          bounded job, completion evidence, and a separate handoff boundary.
        </desc>
        <path class="track-figure-bg" d="M0 0H620V360H0Z" />
        <path class="track-figure-path signal-path" d="M70 180 H190 C230 180, 230 116, 276 116 H532" />
        <path class="track-figure-path orange-path" d="M70 180 H190 C230 180, 230 244, 276 244 H532" />
        <path class="track-figure-path" d="M310 116 V244" />
        <g class="track-figure-nodes hollow-nodes">
          <circle cx="74" cy="180" r="18" />
          <circle cx="190" cy="180" r="18" />
          <circle cx="310" cy="116" r="18" />
          <circle cx="310" cy="244" r="18" />
          <circle cx="532" cy="116" r="18" />
          <circle cx="532" cy="244" r="18" />
        </g>
        <circle class="track-figure-core" cx="190" cy="180" r="34" />
        <circle class="track-figure-accent" cx="310" cy="116" r="9" />
        <circle class="track-figure-accent" cx="532" cy="244" r="9" />
      </svg>
      <figcaption id="workflow-figure-caption">
        Visual orientation only: the public page explains a governed record
        chain, not independent AI understanding or scientific proof.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={aiWorkflowComprehension} />

  <section id="workflow-lifecycle" class="track-page-band" aria-labelledby="workflow-lifecycle-title">
    <div class="track-page-heading">
      <p class="eyebrow">Workflow lifecycle</p>
      <h2 id="workflow-lifecycle-title">The transaction gets narrower at each step.</h2>
      <p>
        The safe model is not "ask the agent and accept the answer." The safe
        model is classification, retrieval support, source inspection, one
        route decision, one job boundary, completion evidence, and a separate
        handoff if more work remains.
      </p>
    </div>
    <div class="track-status-grid">
      {workflowSteps.map((step) => (
        <article class="track-status-card">
          <p>{step.label}</p>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="workflow-example" class="track-page-band" aria-labelledby="workflow-example-title">
    <div class="track-page-heading">
      <p class="eyebrow">Concrete committed example</p>
      <h2 id="workflow-example-title">RT-20260614-249 shows the chain without promoting the physics.</h2>
      <p>
        This example is useful because every important control surface has a
        committed record: task, decision, AgentJob, completion, handoff, and
        registry rows. The example demonstrates workflow accountability; it
        does not establish the scientific conclusion.
      </p>
    </div>

    <div class="metric-strip" aria-label="RT-20260614-249 record identifiers">
      {exampleMeta.map((item) => (
        <article>
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </article>
      ))}
    </div>

    <div class="track-status-grid">
      {recordChain.map((record) => (
        <article class="track-status-card">
          <p>{record.label}</p>
          <h3>{record.title}</h3>
          <p>{record.body}</p>
          <p><code>{record.path}</code></p>
          <p>{record.boundary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="workflow-boundaries-title">
    <div class="track-page-heading">
      <p class="eyebrow">Authority boundaries</p>
      <h2 id="workflow-boundaries-title">The records make the work inspectable, not automatically true.</h2>
      <p>
        The route must keep operational evidence and scientific evidence
        separate. That separation is especially important when a workflow
        example mentions live physics labels.
      </p>
    </div>
    <div class="track-status-grid">
      {boundaryCards.map((boundary) => (
        <article class="track-status-card">
          <p>{boundary.label}</p>
          <h3>{boundary.title}</h3>
          <p>{boundary.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="workflow-reader-title">
    <div class="track-page-heading">
      <p class="eyebrow">Reader path</p>
      <h2 id="workflow-reader-title">Read the workflow with the surrounding authority pages.</h2>
      <p>
        Internal pages carry the main reader journey. Source links remain
        provenance for readers who want to inspect the committed control
        records directly.
      </p>
    </div>
    <div class="source-link-grid">
      {relatedLinks.map((link) => (
        <a class="source-link-card" href={link.href}>
          <span>{link.title}</span>
          <small>{link.body}</small>
        </a>
      ))}
    </div>
  </section>

  <SourceAuthoritySection {...sourceNotice} className="track-page-band" />
</BaseLayout>
