---
import ComprehensionBlocks from "../../../../components/ComprehensionBlocks.astro";
import SourceAuthoritySection from "../../../../components/SourceAuthoritySection.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { aiMemoryRegistriesComprehension } from "../../../../lib/aiComprehensionContent";
import { projectSourceNoticeDefaults } from "../../../../lib/siteContent";

const sourceNotice = projectSourceNoticeDefaults.aiMemoryRegistries;

const layerCards = [
  {
    label: "Authority",
    title: "Canonical source files",
    body: "Tracked TeX, Markdown, and control files remain the material that must be inspected before claims or routing decisions rely on retrieval hits.",
  },
  {
    label: "Metadata",
    title: "Registry rows",
    body: "Registries carry provenance, source-object hashes, generated-output tracking, and memory metadata, but they do not replace the source files they describe.",
  },
  {
    label: "Retrieval",
    title: "Memory surfaces",
    body: "Wiki notes, semantic extracts, Obsidian mirrors, SQLite indexes, and local caches speed lookup and expose drift; they remain below tracked sources.",
  },
  {
    label: "Receipt",
    title: "Preflight evidence",
    body: "A receipt can record status, query commands, returned IDs, canonical inspections, registries, paths, and hashes for later audit.",
  },
];

const workflowCards = [
  {
    label: "Status",
    title: "Check retrieval freshness",
    body: "Memory status and freshness warnings reveal retrieval drift. A warning is a maintenance signal, not a source claim.",
  },
  {
    label: "Lookup",
    title: "Find likely paths",
    body: "Targeted lookup or search helps locate object IDs, registry rows, prior tasks, or likely source paths without broadening the task.",
  },
  {
    label: "Inspect",
    title: "Open canonical sources",
    body: "Any memory hit that affects routing, claim language, source selection, or project-control changes must be checked against source files or registry rows.",
  },
  {
    label: "Receipt",
    title: "Record evidence",
    body: "Controlled transactions that use memory preflight record status, queries, returned IDs, inspected paths, registries, hashes, and authority notes.",
  },
];

const driftCards = [
  {
    label: "Stale mirror",
    title: "Refresh support layers",
    body: "If a raw mirror, Obsidian note, semantic extract, or SQLite index lags tracked files, refresh retrieval layers and inspect the source directly.",
  },
  {
    label: "Generated disagreement",
    title: "Source wins",
    body: "If a wiki note, generated HTML page, PDF, or public summary disagrees with registered source material, the derivative needs repair.",
  },
  {
    label: "Validate-only",
    title: "Check without writing",
    body: "Validate-only commands can show generated-state problems, but they do not refresh stale derivatives or promote generated artifacts.",
  },
  {
    label: "Private contents",
    title: "Do not publish local memory",
    body: "Public pages should explain the method and surface classes without exposing private prompt caches, local memory results, or uncommitted vault contents.",
  },
];

const sourceLinks = [
  {
    title: "Back to AI research-agent track",
    href: "/project/ai-research-agent-system/",
    body: "Return to the AI track landing page for the deep-dive page family.",
  },
  {
    title: "Research-agent workflow",
    href: "/project/ai-research-agent-system/workflow/",
    body: "Read how memory preflight fits into bounded Director decisions and AgentJobs.",
  },
  {
    title: "One bounded AgentJob",
    href: "/project/ai-research-agent-system/one-bounded-agentjob/",
    body: "Read how the preflight receipt fits into one auditable AgentJob boundary.",
  },
  {
    title: "Source authority page",
    href: "/project/source-authority/",
    body: "Review the broader trust map for website pages, generated derivatives, registries, and tracked sources.",
  },
  {
    title: "Operations",
    href: "/project/operations/",
    body: "Read the operational family for validation, publication, and project-system routing.",
  },
  {
    title: "Project-system improvement",
    href: "/project/operations/project-system-improvement/",
    body: "Read how project-system signals and sidecars are routed without replacing source authority.",
  },
];
---

<BaseLayout
  title="Memory Preflight And Source-First Retrieval"
  description="Reader-facing memory preflight page explaining source-first retrieval, registry inspection, receipt evidence, and retrieval-layer limits."
  bodyClass="project-overview-page project-track-page"
>
  <section class="track-page-hero" aria-labelledby="memory-title">
    <div class="track-page-hero-copy">
      <p class="eyebrow">AI research-agent deep dive / PG-018</p>
      <h1 id="memory-title">Memory Preflight And Source-First Retrieval</h1>
      <p class="overview-lead">
        AEther Flow uses memory preflight to find likely source evidence before
        controlled work begins. The useful result is not the memory hit itself;
        it is the later inspection of tracked source files, registry rows, and
        receipt evidence.
      </p>
      <div class="overview-actions" aria-label="Memory and registries page actions">
        <a class="primary-link" href="#query-workflow">Trace the preflight</a>
        <a class="secondary-link" href="/project/source-authority/">Source authority</a>
      </div>
    </div>

    <figure class="track-page-figure" aria-labelledby="memory-figure-caption">
      <svg viewBox="0 0 620 360" role="img" aria-labelledby="memory-figure-title">
        <title id="memory-figure-title">Source-first memory and registry map</title>
        <path class="track-figure-bg" d="M0 0H620V360H0Z" />
        <path class="track-figure-path signal-path" d="M96 252 C174 192, 236 192, 310 252 C384 312, 454 312, 528 252" />
        <path class="track-figure-path orange-path" d="M96 112 C174 172, 236 172, 310 112 C384 52, 454 52, 528 112" />
        <g class="track-figure-nodes hollow-nodes">
          <circle cx="114" cy="252" r="15" />
          <circle cx="230" cy="196" r="15" />
          <circle cx="390" cy="88" r="15" />
          <circle cx="508" cy="252" r="15" />
        </g>
        <circle class="track-figure-core" cx="310" cy="180" r="42" />
      </svg>
      <figcaption id="memory-figure-caption">
        Visual orientation only: memory routes attention to sources; it does
        not become a source of truth.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={aiMemoryRegistriesComprehension} />

  <section id="authority-layers" class="track-page-band" aria-labelledby="authority-layers-title">
    <div class="track-page-heading">
      <p class="eyebrow">Authority and retrieval layers</p>
      <h2 id="authority-layers-title">Find with memory; decide with source.</h2>
      <p>
        Memory is useful because it is not asked to be authority. It points
        readers and agents toward the tracked layer that owns the question.
      </p>
    </div>
    <div class="track-status-grid">
      {layerCards.map((layer) => (
        <article class="track-status-card">
          <p>{layer.label}</p>
          <h3>{layer.title}</h3>
          <p>{layer.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="query-workflow-title">
    <div class="track-page-heading">
      <p class="eyebrow">Query workflow</p>
      <h2 id="query-workflow-title">Memory preflight is a bounded navigation step.</h2>
      <p>
        The pattern is two-stage: use memory status and targeted lookup to find
        likely evidence, then inspect the named canonical source or registry
        row before relying on it for routing, claim language, source selection,
        or project-control changes.
      </p>
    </div>
    <div class="track-status-grid">
      {workflowCards.map((card) => (
        <article class="track-status-card">
          <p>{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="freshness-title">
    <div class="track-page-heading">
      <p class="eyebrow">Freshness and drift</p>
      <h2 id="freshness-title">Stale retrieval is a maintenance signal, not authority.</h2>
      <p>
        Retrieval drift can matter operationally because it may hide current
        source evidence. It still does not change the source hierarchy or
        create a project-control claim.
      </p>
    </div>
    <div class="track-status-grid">
      {driftCards.map((card) => (
        <article class="track-status-card">
          <p>{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="memory-reader-title">
    <div class="track-page-heading">
      <p class="eyebrow">Reader path</p>
      <h2 id="memory-reader-title">Read memory with workflow, AgentJobs, and source authority.</h2>
      <p>
        Memory and registries connect the AI workflow to source evidence:
        workflow says when memory is used, AgentJobs preserve the receipt, and
        source authority says what must be inspected before claims move.
      </p>
    </div>
    <div class="source-link-grid">
      {sourceLinks.map((link) => (
        <a class="source-link-card" href={link.href}>
          <span>{link.title}</span>
          <small>{link.body}</small>
        </a>
      ))}
    </div>
  </section>

  <SourceAuthoritySection {...sourceNotice} className="track-page-band" />
</BaseLayout>
