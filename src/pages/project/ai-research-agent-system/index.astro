---
import SourceNotice from "../../../components/SourceNotice.astro";
import ProjectRouteGrid from "../../../components/ProjectRouteGrid.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  projectAiDeepDiveRoutes,
  projectSourceNoticeDefaults,
} from "../../../lib/siteContent";

const sourceNotice = projectSourceNoticeDefaults.aiResearchAgentTrack;

const workflowLayers = [
  {
    label: "Bounded work",
    title: "Tasks and AgentJobs",
    body: "The system narrows work into auditable packets with explicit allowed paths, expected outputs, validators, and claim boundaries.",
  },
  {
    label: "Authority",
    title: "Role contracts",
    body: "Roles and skills orient work, but task-local execution records and allowlists decide what a specific transaction may do.",
  },
  {
    label: "Review",
    title: "Claim gates and refutation",
    body: "Proposals, stress tests, completions, handoffs, and human gates keep workflow progress separate from physics proof.",
  },
  {
    label: "Memory",
    title: "Source-first retrieval",
    body: "Memory, wiki, registries, and local search help find sources. They do not replace registered source files or authority rows.",
  },
];

const journeyLinks = [
  {
    title: "Roles and skills",
    href: "/project/ai-research-agent-system/roles-and-skills/",
    body: "Role contracts, governed skills, task-local authority, and allowlist boundaries.",
  },
  {
    title: "Memory and registries",
    href: "/project/ai-research-agent-system/memory-registries/",
    body: "Source-first memory, registries, semantic extracts, and retrieval limits.",
  },
  {
    title: "Operations",
    href: "/project/operations/",
    body: "Operational guides for lifecycle, role routing, validation, publication, improvement, and tools.",
  },
];
---

<BaseLayout
  title="AI Research-Agent System"
  description="AI research-agent track landing page for bounded tasks, role contracts, claim gates, review discipline, and source-first memory."
  bodyClass="project-overview-page project-track-page"
>
  <section class="track-page-hero" aria-labelledby="ai-track-title">
    <div class="track-page-hero-copy">
      <p class="eyebrow">AI research-agent track</p>
      <h1 id="ai-track-title">AI Research-Agent System</h1>
      <p class="overview-lead">
        The AI research-agent system is the governed, human-accountable
        workflow used to plan, check, preserve, and review theoretical physics
        work. Its workflow evidence can organize research; it does not become
        physics proof by itself.
      </p>
      <div class="overview-actions" aria-label="AI research-agent page actions">
        <a class="primary-link" href="#ai-system-status">Read the system status</a>
        <a class="secondary-link" href="/project/overview/">Back to overview</a>
      </div>
    </div>

    <figure class="track-page-figure ai-system-figure" aria-labelledby="ai-figure-caption">
      <svg
        class="track-map-svg ai-system-svg"
        viewBox="0 0 620 360"
        role="img"
        aria-labelledby="ai-figure-title ai-figure-desc"
      >
        <title id="ai-figure-title">Animated governed AI workflow map</title>
        <desc id="ai-figure-desc">
          Bounded task frame, role routing, validators, memory retrieval, review
          gates, and human accountability are shown as separate workflow layers.
        </desc>
        <defs>
          <radialGradient id="ai-system-glow" cx="48%" cy="48%" r="70%">
            <stop offset="0%" stop-color="#fff2c3" stop-opacity="0.66" />
            <stop offset="36%" stop-color="#ffad21" stop-opacity="0.22" />
            <stop offset="76%" stop-color="#11100d" stop-opacity="0.16" />
            <stop offset="100%" stop-color="#000000" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="ai-system-rail" x1="8%" x2="92%" y1="50%" y2="50%">
            <stop offset="0%" stop-color="#e8ddc1" stop-opacity="0" />
            <stop offset="28%" stop-color="#e8ddc1" stop-opacity="0.82" />
            <stop offset="60%" stop-color="#fff4d1" stop-opacity="0.74" />
            <stop offset="100%" stop-color="#ffad21" stop-opacity="0" />
          </linearGradient>
          <filter id="ai-system-bloom" x="-20%" y="-24%" width="140%" height="148%">
            <feGaussianBlur stdDeviation="4.5" result="aiSystemBlur" />
            <feMerge>
              <feMergeNode in="aiSystemBlur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
        <rect class="track-figure-bg" width="620" height="360" rx="24" />
        <circle class="ai-system-glow" cx="304" cy="178" r="194" />
        <g class="ai-system-grid" aria-hidden="true">
          <path d="M72 84 H548" />
          <path d="M72 180 H548" />
          <path d="M72 276 H548" />
          <path d="M154 54 V306" />
          <path d="M304 54 V306" />
          <path d="M458 54 V306" />
        </g>
        <g class="ai-system-frame" aria-hidden="true">
          <rect x="118" y="76" width="374" height="210" rx="26" />
          <rect x="144" y="102" width="322" height="158" rx="18" />
        </g>
        <g class="ai-memory-stack" aria-hidden="true">
          <rect x="74" y="92" width="86" height="34" rx="9" />
          <rect x="74" y="152" width="86" height="34" rx="9" />
          <rect x="74" y="212" width="86" height="34" rx="9" />
        </g>
        <g class="ai-review-gates" aria-hidden="true">
          <path d="M306 84 L346 108 L346 156 L306 180 L266 156 L266 108 Z" />
          <path d="M306 180 L346 204 L346 252 L306 276 L266 252 L266 204 Z" />
        </g>
        <g class="ai-human-boundary" aria-hidden="true">
          <rect x="474" y="96" width="72" height="56" rx="14" />
          <rect x="474" y="208" width="72" height="56" rx="14" />
        </g>
        <g class="ai-system-routes" filter="url(#ai-system-bloom)" aria-hidden="true">
          <path class="track-figure-path signal-path ai-system-flow-path primary" d="M160 109 C214 110, 242 130, 306 132 C370 134, 412 118, 474 124" />
          <path class="track-figure-path gold-path ai-system-flow-path" d="M160 169 C220 170, 248 190, 306 228 C360 264, 412 240, 474 236" />
          <path class="track-figure-path signal-path ai-system-flow-path alternate" d="M160 229 C220 214, 242 164, 306 132 C370 100, 418 174, 474 236" />
        </g>
        <circle class="track-figure-core ai-system-core" cx="306" cy="180" r="38" aria-hidden="true" />
        <g class="track-figure-nodes hollow-nodes ai-system-nodes" aria-hidden="true">
          <circle cx="160" cy="109" r="14" />
          <circle cx="160" cy="169" r="14" />
          <circle cx="160" cy="229" r="14" />
          <circle cx="306" cy="132" r="14" />
          <circle cx="306" cy="228" r="14" />
          <circle cx="474" cy="124" r="14" />
          <circle cx="474" cy="236" r="14" />
        </g>
      </svg>
      <figcaption id="ai-figure-caption">
        Visual orientation only: routing, roles, validation, memory, and review
        support auditable workflow rather than autonomous scientific proof.
      </figcaption>
    </figure>
  </section>

  <section id="ai-system-status" class="track-page-band" aria-labelledby="ai-system-status-title">
    <div class="track-page-heading">
      <p class="eyebrow">System model</p>
      <h2 id="ai-system-status-title">Workflow evidence is not physics authority.</h2>
      <p>
        The AI system is a research discipline: it makes work inspectable,
        repeatable, and harder to overstate. Scientific claims still require
        source artifacts and gates.
      </p>
    </div>
    <div class="track-status-grid">
      {workflowLayers.map((layer) => (
        <article class="track-status-card">
          <p>{layer.label}</p>
          <h3>{layer.title}</h3>
          <p>{layer.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="track-page-band" aria-labelledby="ai-next-title">
    <div class="track-page-heading">
      <p class="eyebrow">Where to go next</p>
      <h2 id="ai-next-title">Move through internal pages before source inspection.</h2>
      <p>
        The AI research-agent track now routes to internal pages first. GitHub
        links remain available in provenance and source-authority contexts.
      </p>
    </div>

    <div class="source-link-grid">
      {journeyLinks.map((link) => (
        <a class="source-link-card" href={link.href}>
          <span>{link.title}</span>
          <small>{link.body}</small>
        </a>
      ))}
    </div>

    <ProjectRouteGrid routes={projectAiDeepDiveRoutes} ariaLabel="AI research-agent routes" />
  </section>

  <section class="track-page-band track-page-notice" aria-labelledby="ai-authority-title">
    <div>
      <p class="eyebrow">Source authority</p>
      <h2 id="ai-authority-title">Human accountability remains explicit.</h2>
      <p>
        This page can describe the AI-assisted workflow. It cannot expand role
        authority, change routing behavior, promote physics claims, or replace
        human-gated publication, authorship, and outreach responsibility.
      </p>
    </div>
    <SourceNotice
      claimStatus={sourceNotice.claimStatus}
      updated={sourceNotice.updated}
      note={sourceNotice.note}
      sourceRefs={sourceNotice.sourceRefs}
    />
  </section>
</BaseLayout>
