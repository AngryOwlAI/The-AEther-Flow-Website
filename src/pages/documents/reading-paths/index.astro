---

<BaseLayout
  title="Reading Paths"
  description="Canonical audience-specific reading paths for general readers, physicists, mathematicians, AI and agent researchers, software and system engineers, and external reviewers."
  bodyClass="project-overview-page project-support-page"
>
  <section class="content-band project-support-hero" aria-labelledby="reading-paths-title">
    <div class="project-support-copy">
      <div class="section-header">
        <p class="eyebrow">Documents / Reading Paths</p>
        <h1 id="reading-paths-title">Reading Paths</h1>
        <p class="lead">
          Choose the path closest to your question or discipline. Each path
          begins with an internal explanation, preserves the strongest
          inference it does not authorize, and leads to source inspection only
          when needed.
        </p>
      </div>
      <div class="overview-actions" aria-label="Reading path actions">
        <a class="primary-link" href="#audience-paths">Choose a specialist path</a>
        <a class="secondary-link" href="/documents/reading-paths/general-public/">General-public path</a>
        <a class="secondary-link" href="/documents/">Documents overview</a>
      </div>
    </div>

    <Figure
      src="/assets/diagrams/comprehension/specialist-guided-starts.png"
      alt="Diagram showing one reading-path hub routing physicists, mathematicians, AI and agent researchers, software and system engineers, and external reviewers to internal prerequisite pages while preserving the no-new-claims boundary."
      caption="The diagram illustrates audience reading paths connecting each discipline to internal routes and source-authority context."
      className="support-figure comprehension-figure"
      loading="eager"
    />
  </section>

  <section class="content-band content-band-tight" aria-labelledby="summary-title">
    <div class="section-header">
      <p class="eyebrow">How to use this index</p>
      <h2 id="summary-title">Read by question, then inspect source authority.</h2>
      <p class="lead">
        These paths are navigation layers. They lower the cost of finding the
        relevant pages without replacing the records that own claim status.
      </p>
    </div>
    <StatusDossier
      items={pathSummary}
      ariaLabel="Reading-path summary"
      className="resource-status-grid resource-status-dossier"
    />
  </section>

  <section id="audience-paths" class="content-band content-band-tight" aria-labelledby="audience-paths-title">
    <div class="section-header">
      <p class="eyebrow">Audience paths</p>
      <h2 id="audience-paths-title">Pick the route family that matches your review question.</h2>
      <p class="lead">
        Every path follows one rule: read canonical internal pages first, then
        use source links and manifests as provenance when auditing a claim or
        artifact.
      </p>
    </div>
  </section>

  {audiencePaths.map((path) => (
    <section id={path.id} class="content-band content-band-tight" aria-labelledby={`${path.id}-title`}>
      <div class="section-header">
        <p class="eyebrow">{path.eyebrow}</p>
        <h2 id={`${path.id}-title`}>{path.title}</h2>
        <p class="lead">{path.summary}</p>
      </div>
      <EvidenceRail
        items={path.routes}
        ariaLabel={`${path.eyebrow} reading-path routes`}
        className="link-grid resource-path-rail"
        ordered
      />
      <StatusDossier
        items={[
          {
            label: "Do not infer",
            title: "Boundary for this path",
            body: path.doNotInfer,
          },
        ]}
        ariaLabel={`${path.eyebrow} reading-path boundary`}
        className="resource-status-grid resource-status-dossier"
      />
    </section>
  ))}
</BaseLayout>
