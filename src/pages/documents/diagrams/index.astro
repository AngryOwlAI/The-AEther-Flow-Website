---
import CommandBand from "../../../components/CommandBand.astro";
import ComprehensionBlocks from "../../../components/ComprehensionBlocks.astro";
import DiagramGalleryList from "../../../components/DiagramGalleryList.astro";
import EvidenceRail from "../../../components/EvidenceRail.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectIntroduction from "../../../components/ProjectIntroduction.astro";
import { approvedDownloads } from "../../../lib/manifests";
import {
  resourcesDiagramsComprehension as legacyDocumentsDiagramsComprehension,
} from "../../../lib/supportComprehensionContent";
import { diagramConceptGroups, diagramGalleryItems } from "../../../lib/siteContent";

const documentsDiagramsComprehension = {
  ...legacyDocumentsDiagramsComprehension,
  id: "documents-diagrams-comprehension",
  relatedRoutes: [
    {
      label: "Internal route",
      title: "Documentation Overview",
      href: "/documents/",
      body: "Return to the document categories and their source-role boundaries.",
    },
    {
      label: "Internal route",
      title: "Source authority",
      href: "/documents/governance/source-authority/",
      body: "Read the broader trust boundary for generated and visual material.",
    },
  ],
};

const approvedDiagramPaths = new Set(
  approvedDownloads.filter((item) => item.kind === "diagram").map((item) => item.path),
);
const seenDiagramPaths = new Set<string>();
const approvedGalleryItems = diagramGalleryItems.filter((item) => {
  if (!approvedDiagramPaths.has(item.src) || seenDiagramPaths.has(item.src)) {
    return false;
  }
  seenDiagramPaths.add(item.src);
  return true;
});
const approvedDiagramLabel =
  approvedGalleryItems.length === 1
    ? "approved public-comprehension PNG"
    : "approved public-comprehension PNGs";

const galleryStatusRows = [
  {
    status: "Approved PNGs",
    current: `${approvedGalleryItems.length} displayed once`,
    reason:
      "The gallery renders only approved comprehension PNGs generated from tracked Mermaid sources.",
    boundary: "Approval here means website comprehension use, not source-claim authority.",
  },
  {
    status: "Caption",
    current: "Interpretation stays in prose",
    reason:
      "Each figure keeps meaning in alt text, caption, nearby copy, and source provenance records.",
    boundary: "A polished visual remains below source files, registries, and governed records.",
  },
  {
    status: "Runtime",
    current: "Static assets only",
    reason: "Public pages use committed PNG assets instead of browser Mermaid rendering.",
    boundary: "Static output improves reliability and accessibility, not authority.",
  },
];

const relatedRoutes = [
  {
    label: "Documents",
    title: "Documentation Overview",
    href: "/documents/",
    body: "Return to the Documents overview for formats, authority levels, status labels, and reading paths.",
  },
  {
    label: "Derivatives",
    title: "Generated Derivatives",
    href: "/documents/derivatives/",
    body: "Compare static diagrams with other generated reader aids.",
  },
  {
    label: "Publication",
    title: "Publication Process",
    href: "/documents/governance/publication-process/",
    body: "Read how source specs, briefs, validation, and review constrain reader surfaces.",
  },
  {
    label: "Authority",
    title: "Source Authority",
    href: "/documents/governance/source-authority/",
    body: "Review why visual material remains below source and registry authority.",
  },
  {
    label: "Builder",
    title: "Site Builder Guide",
    href: "/documents/governance/site-builder-guide/",
    body: "Use source bundles before adding or restoring diagram inventory.",
  },
];

const diagramSvg = `
  <svg class="track-map-svg physics-greenfield-svg" viewBox="0 0 620 360" role="img" aria-labelledby="documents-diagrams-title documents-diagrams-desc">
    <title id="documents-diagrams-title">Animated diagram gallery reset map</title>
    <desc id="documents-diagrams-desc">Diagram source, static output, manifest status, caption, provenance, and approval gate lead to a future gallery inventory.</desc>
    <defs>
      <radialGradient id="documents-diagrams-core" cx="50%" cy="50%" r="66%">
        <stop offset="0%" stop-color="var(--owl-orange-100)" stop-opacity="0.58" />
        <stop offset="44%" stop-color="var(--owl-cyan-400)" stop-opacity="0.24" />
        <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
      </radialGradient>
      <filter id="documents-diagrams-bloom" x="-20%" y="-24%" width="140%" height="148%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <path class="track-figure-bg" d="M0 0H620V360H0Z" />
    <circle class="physics-glow" cx="310" cy="180" r="184" fill="url(#documents-diagrams-core)" />
    <g class="physics-grid" aria-hidden="true">
      <ellipse cx="310" cy="180" rx="230" ry="114" />
      <ellipse cx="310" cy="180" rx="152" ry="74" />
      <path d="M104 112 H516" />
      <path d="M104 248 H516" />
      <path d="M310 72 V288" />
    </g>
    <g filter="url(#documents-diagrams-bloom)" aria-hidden="true">
      <path class="track-figure-path signal-path" d="M106 112 C178 160, 240 180, 310 180 C380 180, 442 160, 514 112" />
      <path class="track-figure-path orange-path" d="M106 248 C178 200, 240 180, 310 180 C380 180, 442 200, 514 248" />
      <path class="track-figure-path signal-path alternate" d="M142 180 C210 104, 410 104, 478 180" />
      <path class="track-figure-path orange-path alternate" d="M142 180 C210 256, 410 256, 478 180" />
    </g>
    <path class="track-figure-core" d="M310 136 L352 180 L310 224 L268 180 Z" aria-hidden="true" />
    <g class="track-figure-nodes hollow-nodes" aria-hidden="true">
      <circle cx="106" cy="112" r="13" />
      <circle cx="106" cy="248" r="13" />
      <circle cx="142" cy="180" r="13" />
      <circle cx="310" cy="180" r="13" />
      <circle cx="478" cy="180" r="13" />
      <circle cx="514" cy="112" r="13" />
      <circle cx="514" cy="248" r="13" />
    </g>
  </svg>
`;
const documentsDiagramGalleryProjectIntroduction = [
  "Diagrams here are visual orientation aids. They can make relationships, route boundaries, and publication flow easier to inspect, but they do not prove science, promote claims, or replace source inspection.",
] as const;

---

<BaseLayout
  title="Diagram Gallery"
  description="Diagram gallery for The AEther Flow Website with manifest-backed static comprehension diagrams grouped by reader concept."
  bodyClass="project-overview-page project-track-page documents-greenfield-page ai-greenfield-page"
>
  <CommandBand
    className="overview-shell overview-command-hero"
    eyebrow="Documents / Diagram Gallery"
    title="Diagram Gallery"
    lead="The gallery publishes approved static comprehension diagrams as reader aids grouped by concept. Each visual remains downstream from tracked source, manifest status, caption, provenance, and source-authority boundaries."
    headingLevel="h1"
  >
    <div class="overview-actions" aria-label="Diagram gallery page actions">
      <a class="primary-link" href="#diagram-group-physics-title">Browse gallery</a>
      <a class="secondary-link" href="#diagram-status">Read diagram status</a>
      <a class="secondary-link" href="/documents/">Open Documentation Overview</a>
      <a class="secondary-link" href="/documents/governance/publication-process/">Read publication governance</a>
    </div>
    <Fragment slot="visual">
      <figure class="track-page-figure physics-figure" aria-labelledby="documents-diagrams-caption">
        <Fragment set:html={diagramSvg} />
        <figcaption id="documents-diagrams-caption">
          The Diagram Gallery publishes relationship maps as reader aids
          with manifest context, not as source authority.
        </figcaption>
      </figure>
    </Fragment>
  </CommandBand>

  <ProjectIntroduction
    paragraphs={documentsDiagramGalleryProjectIntroduction}
    ariaLabel="Diagram gallery introduction"
  />

  <ComprehensionBlocks content={documentsDiagramsComprehension} />

  <section id="diagram-status" class="track-page-band" aria-labelledby="diagram-status-title">
    <div class="track-page-heading">
      <p class="eyebrow">Manifest audit</p>
      <h2 id="diagram-status-title">The gallery displays {approvedGalleryItems.length} {approvedDiagramLabel}.</h2>
      <p>
        The visible inventory is derived from approved diagram manifest rows
        and the tracked gallery metadata. Source paths remain audit data in
        manifests and dossiers rather than visible card copy.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Surface</th>
          <th scope="col">Current state</th>
          <th scope="col">Reason</th>
          <th scope="col">Boundary</th>
        </tr>
      </thead>
      <tbody>
        {galleryStatusRows.map((row) => (
          <tr>
            <th scope="row">{row.status}</th>
            <td>{row.current}</td>
            <td>{row.reason}</td>
            <td>{row.boundary}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  {diagramConceptGroups.map((group) => (
    <section
      class="track-page-band"
      aria-labelledby={`diagram-group-${group.id}-title`}
    >
      <div class="track-page-heading">
        <p class="eyebrow">Concept group</p>
        <h2 id={`diagram-group-${group.id}-title`}>{group.title}</h2>
        <p>{group.body}</p>
      </div>
      <DiagramGalleryList items={approvedGalleryItems.filter((item) => item.group === group.id)} />
    </section>
  ))}

  <CommandBand
    className="overview-panel overview-command-band"
    eyebrow="Related internal routes"
    title="Use diagrams beside documents, publication, derivatives, and source guidance."
    lead="Internal routes remain the primary explanation; diagrams remain visual aids with provenance and non-authority status."
  >
    <EvidenceRail
      items={relatedRoutes.map((route) => ({
        ...route,
        actionLabel: "Open route",
      }))}
      ariaLabel="Related diagram gallery routes"
      className="overview-track-rail"
    />
  </CommandBand>
</BaseLayout>
