---
import ComprehensionBlocks from "../../components/ComprehensionBlocks.astro";
import DiagramGalleryList from "../../components/DiagramGalleryList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resourcesDiagramsComprehension } from "../../lib/supportComprehensionContent";
import { approvedDownloads } from "../../lib/manifests";
import { diagramConceptGroups, diagramGalleryItems } from "../../lib/siteContent";

const approvedDiagramDownloads = approvedDownloads.filter((item) => item.kind === "diagram");
const approvedDiagramPaths = new Set(approvedDiagramDownloads.map((item) => item.path));
const seenDiagramPaths = new Set<string>();
const approvedGalleryItems = diagramGalleryItems.filter((item) => {
  if (!approvedDiagramPaths.has(item.src) || seenDiagramPaths.has(item.src)) {
    return false;
  }
  seenDiagramPaths.add(item.src);
  return true;
});
---

<BaseLayout
  title="Diagram Gallery"
  description="Diagram gallery for The AEther Flow website with manifest-backed asset records."
  bodyClass="project-overview-page project-support-page"
>
  <section class="content-band project-support-hero" aria-labelledby="diagrams-title">
    <div class="project-support-copy">
      <div class="section-header">
        <p class="eyebrow">Visual assets</p>
        <h1 id="diagrams-title">Diagram Gallery</h1>
        <p class="lead">
          Diagrams are presentation aids grouped by reader concept. Current
          comprehension diagrams are generated from tracked Mermaid sources and
          recorded in the manifests; they orient readers but do not become
          scientific or workflow authority.
        </p>
      </div>
    </div>

    <figure class="support-figure diagram-release-flow" aria-labelledby="diagrams-figure-caption">
      <svg
        class="support-svg"
        viewBox="0 0 520 340"
        role="img"
        aria-labelledby="diagrams-figure-title diagrams-figure-desc"
      >
        <title id="diagrams-figure-title">Animated diagram publication filter</title>
        <desc id="diagrams-figure-desc">
          Diagram files move from fixture status through manifest review before
          they become reader-facing visual aids.
        </desc>
        <path class="support-bg" d="M0 0H520V340H0Z" />
        <g class="support-dust" aria-hidden="true">
          <circle cx="54" cy="64" r="1.1" />
          <circle cx="106" cy="252" r="0.9" />
          <circle cx="170" cy="84" r="1" />
          <circle cx="236" cy="292" r="1.2" />
          <circle cx="318" cy="74" r="1" />
          <circle cx="408" cy="270" r="1.1" />
          <circle cx="470" cy="104" r="0.9" />
        </g>
        <g class="support-link-lines" aria-hidden="true">
          <path class="support-line signal-line" d="M86 180 C148 136, 196 132, 250 162" />
          <path class="support-line orange-line" d="M86 180 C148 226, 196 220, 250 178" />
          <path class="support-line signal-line alternate" d="M270 162 C328 128, 374 118, 440 116" />
          <path class="support-line orange-line alternate" d="M270 178 C330 214, 378 224, 440 228" />
        </g>
        <circle class="support-core" cx="260" cy="170" r="34" aria-hidden="true" />
        <g class="support-flow-nodes" aria-hidden="true">
          <circle cx="86" cy="180" r="18" />
          <circle cx="440" cy="116" r="18" />
          <circle cx="440" cy="228" r="18" />
        </g>
        <g class="support-rings" aria-hidden="true">
          <circle cx="260" cy="170" r="54" />
          <circle cx="260" cy="170" r="88" />
        </g>
      </svg>
      <figcaption id="diagrams-figure-caption">
        Visual orientation only: diagrams support explanation but do not become
        source authority.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={resourcesDiagramsComprehension} />

  {diagramConceptGroups.map((group) => (
    <section
      class="content-band content-band-tight"
      aria-labelledby={`diagram-group-${group.id}-title`}
    >
      <div class="section-header">
        <p class="eyebrow">Concept group</p>
        <h2 id={`diagram-group-${group.id}-title`}>{group.title}</h2>
        <p class="lead">{group.body}</p>
      </div>
      <DiagramGalleryList items={approvedGalleryItems.filter((item) => item.group === group.id)} />
    </section>
  ))}
</BaseLayout>
