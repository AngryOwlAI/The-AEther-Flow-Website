---
import ComprehensionBlocks from "../../components/ComprehensionBlocks.astro";
import DownloadList from "../../components/DownloadList.astro";
import Figure from "../../components/Figure.astro";
import SourceNotice from "../../components/SourceNotice.astro";
import StatusDossier from "../../components/StatusDossier.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resourcesDiagramsComprehension } from "../../lib/supportComprehensionContent";
import { approvedDownloads, downloads, sampleDownloads } from "../../lib/manifests";
import { diagramConceptGroups, diagramGalleryItems } from "../../lib/siteContent";

const diagramDownloads = downloads.filter((item) => item.kind === "diagram");
const approvedDiagramDownloads = approvedDownloads.filter((item) => item.kind === "diagram");
const sampleDiagramDownloads = sampleDownloads.filter((item) => item.kind === "diagram");
const sampleDiagramLabel =
  sampleDiagramDownloads.length === 1 ? "sample or legacy diagram file" : "sample or legacy diagram files";
const approvedDiagramLabel =
  approvedDiagramDownloads.length === 1
    ? "approved public-comprehension diagram file"
    : "approved public-comprehension diagram files";

const galleryStatusCards = [
  {
    label: "Static PNG",
    title: "Browser-safe publication",
    body:
      "Public diagram figures use committed PNG assets generated from tracked Mermaid sources.",
  },
  {
    label: "Caption",
    title: "Interpretation stays in prose",
    body:
      "Each figure keeps meaning in alt text, caption, nearby copy, and source provenance.",
  },
  {
    label: "Boundary",
    title: "No diagram authority",
    body:
      "A diagram can explain a relationship, but it cannot prove science, change workflow authority, or replace source inspection.",
  },
];
---

<BaseLayout
  title="Diagram Gallery"
  description="Manifest-backed diagram gallery for The AEther Flow website."
  bodyClass="project-overview-page project-support-page"
>
  <section class="content-band project-support-hero" aria-labelledby="diagrams-title">
    <div class="project-support-copy">
      <div class="section-header">
        <p class="eyebrow">Visual assets</p>
        <h1 id="diagrams-title">Diagram Gallery</h1>
        <p class="lead">
          Diagrams are presentation aids grouped by reader concept. Current
          comprehension diagrams are generated from tracked Mermaid sources and
          recorded in the manifests; they orient readers but do not become
          scientific or workflow authority.
        </p>
      </div>
      <SourceNotice
        claimStatus="source-index-only"
        sourceRefs={[
          "The AEther Flow Website. (2026). docs/content-dossiers/README.md",
          "The AEther Flow Website. (2026). public/files/manifests/source_manifest.json",
        ]}
        updated="2026-06-28"
        note="This page presents website-local visual orientation assets with explicit provenance. It does not make diagrams authoritative."
      />
    </div>

    <figure class="support-figure diagram-release-flow" aria-labelledby="diagrams-figure-caption">
      <svg
        class="support-svg"
        viewBox="0 0 520 340"
        role="img"
        aria-labelledby="diagrams-figure-title diagrams-figure-desc"
      >
        <title id="diagrams-figure-title">Animated diagram publication filter</title>
        <desc id="diagrams-figure-desc">
          Diagram files move from fixture status through manifest review before
          they become reader-facing visual aids.
        </desc>
        <path class="support-bg" d="M0 0H520V340H0Z" />
        <g class="support-dust" aria-hidden="true">
          <circle cx="54" cy="64" r="1.1" />
          <circle cx="106" cy="252" r="0.9" />
          <circle cx="170" cy="84" r="1" />
          <circle cx="236" cy="292" r="1.2" />
          <circle cx="318" cy="74" r="1" />
          <circle cx="408" cy="270" r="1.1" />
          <circle cx="470" cy="104" r="0.9" />
        </g>
        <g class="support-link-lines" aria-hidden="true">
          <path class="support-line signal-line" d="M86 180 C148 136, 196 132, 250 162" />
          <path class="support-line orange-line" d="M86 180 C148 226, 196 220, 250 178" />
          <path class="support-line signal-line alternate" d="M270 162 C328 128, 374 118, 440 116" />
          <path class="support-line orange-line alternate" d="M270 178 C330 214, 378 224, 440 228" />
        </g>
        <circle class="support-core" cx="260" cy="170" r="34" aria-hidden="true" />
        <g class="support-flow-nodes" aria-hidden="true">
          <circle cx="86" cy="180" r="18" />
          <circle cx="440" cy="116" r="18" />
          <circle cx="440" cy="228" r="18" />
        </g>
        <g class="support-rings" aria-hidden="true">
          <circle cx="260" cy="170" r="54" />
          <circle cx="260" cy="170" r="88" />
        </g>
      </svg>
      <figcaption id="diagrams-figure-caption">
        Visual orientation only: diagrams support explanation but do not become
        source authority.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={resourcesDiagramsComprehension} />

  <section class="content-band content-band-tight" aria-labelledby="diagram-status-title">
    <div class="section-header">
      <p class="eyebrow">Manifest audit</p>
      <h2 id="diagram-status-title">Diagram asset status</h2>
      <p class="lead">
        The current manifest contains {sampleDiagramDownloads.length}{" "}
        {sampleDiagramLabel} and {approvedDiagramDownloads.length}{" "}
        {approvedDiagramLabel}. Approved here means approved for website
        comprehension use, not source-claim authority.
      </p>
    </div>
    <StatusDossier
      items={galleryStatusCards}
      ariaLabel="Diagram gallery publication status"
      className="track-status-grid"
    />
    <div class="link-grid">
      <a class="link-card" href="/project/source-authority/">
        <span>Source authority</span>
        <small>Read how website visuals, generated material, and manifests relate to upstream authority.</small>
      </a>
      <a class="link-card" href="/">
        <span>Home</span>
        <small>Return to the canonical public entry point for the dual-track framing.</small>
      </a>
      <a class="link-card" href="/resources/">
        <span>Resource index</span>
        <small>Inspect all current manifest-backed sample files and planned-source boundaries.</small>
      </a>
    </div>
  </section>

  {diagramConceptGroups.map((group) => (
    <section
      class="content-band content-band-tight"
      aria-labelledby={`diagram-group-${group.id}-title`}
    >
      <div class="section-header">
        <p class="eyebrow">Concept group</p>
        <h2 id={`diagram-group-${group.id}-title`}>{group.title}</h2>
        <p class="lead">{group.body}</p>
      </div>
      <div class="figure-grid">
        {diagramGalleryItems
          .filter((item) => item.group === group.id)
          .map((item) => (
            <Figure
              src={item.src}
              alt={item.alt}
              caption={item.caption}
              provenance={item.provenance}
              loading="eager"
            />
          ))}
      </div>
    </section>
  ))}

  <section class="content-band content-band-tight">
    <DownloadList
      items={diagramDownloads}
      eyebrow="Manifest-backed diagram"
      title="Current diagram fixture"
      description="This row is filtered from the asset manifest. Diagram assets are reader aids; manifest approval records website publication status, not source-claim authority."
    />
  </section>
</BaseLayout>
