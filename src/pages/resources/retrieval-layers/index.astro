---
import CommandBand from "../../../components/CommandBand.astro";
import EvidenceRail from "../../../components/EvidenceRail.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ComprehensionBlocks from "../../../components/ComprehensionBlocks.astro";
import { greenfieldRouteDiagramBlocks } from "../../../lib/siteContent";

const layerRows = [
  {
    layer: "Memory lookup",
    examples: "Local memory summaries, prior packet notes, and retrieved workflow hints.",
    use: "Find candidate files, commands, and prior decisions quickly.",
    limit: "Memory lookup is a navigation aid, not claim authority.",
  },
  {
    layer: "Semantic extracts",
    examples: "Vector or text extracts used to locate related source objects.",
    use: "Discover relevant source files or registries for inspection.",
    limit: "Extracts can omit context and cannot replace source reading.",
  },
  {
    layer: "Obsidian or wiki mirrors",
    examples: "Generated notes, object pages, and relationship mirrors.",
    use: "Browse relationships and find source candidates.",
    limit: "Generated notes are retrieval layers unless promoted by a tracked source.",
  },
  {
    layer: "SQLite or local indexes",
    examples: "Local databases, source indexes, and cache tables.",
    use: "Speed search and repeatable lookup across large source sets.",
    limit: "Index rows are not proof, source authority, or public publication state.",
  },
  {
    layer: ".local and QA caches",
    examples: "Ignored previews, screenshots, temporary analysis, and local artifacts.",
    use: "Support local inspection, debugging, or browser QA.",
    limit: ".local data is not committed evidence or source authority.",
  },
];

const workflowRows = [
  {
    step: "Ask the retrieval question",
    action: "Use memory, semantic search, wiki, or cache lookup to find candidate material.",
    boundary: "The retrieval layer can suggest where to inspect; it cannot decide the claim.",
  },
  {
    step: "Locate the owner",
    action: "Map the hit to a source file, registry row, handoff, completion, PRD, or manifest.",
    boundary: "The owner, not the retrieval hit, controls claim status.",
  },
  {
    step: "Inspect the source",
    action: "Read the current tracked source or governed record before changing public copy.",
    boundary: "If source and retrieval disagree, source wins.",
  },
  {
    step: "Report the uncertainty",
    action: "Name stale, partial, or local-only retrieval evidence before reuse.",
    boundary: "Uncertainty remains visible instead of being hidden behind a polished route.",
  },
];

const riskRows = [
  {
    risk: "Stale memory",
    safeResponse: "Refresh against tracked files or state before relying on the hit.",
    blockedUse: "Do not present an older memory note as current source truth.",
  },
  {
    risk: "Partial extract",
    safeResponse: "Open the full source and surrounding context.",
    blockedUse: "Do not infer missing assumptions from the extract alone.",
  },
  {
    risk: "Local cache",
    safeResponse: "Treat cache paths as private QA or navigation support.",
    blockedUse: "Do not cite `.local` or ignored cache state as public evidence.",
  },
  {
    risk: "Generated mirror",
    safeResponse: "Use the mirror to locate the canonical source or registry row.",
    blockedUse: "Do not edit the mirror to change canonical claims.",
  },
];

const relatedRoutes = [
  {
    label: "Derivatives",
    title: "Generated Derivatives",
    href: "/resources/generated-derivatives/",
    body: "Compare retrieval layers with generated reader surfaces.",
  },
  {
    label: "Authority",
    title: "Source Authority",
    href: "/resources/source-authority/",
    body: "Read the authority ladder before using retrieval evidence.",
  },
  {
    label: "Records",
    title: "Registries",
    href: "/resources/registries/",
    body: "Map retrieval hits to source, derivative, workflow, and claim-boundary rows.",
  },
  {
    label: "Memory",
    title: "Memory Preflight",
    href: "/ai-research-system/memory-preflight/",
    body: "Review the governed memory preflight workflow and its source-first boundary.",
  },
  {
    label: "Library",
    title: "Library",
    href: "/resources/library/",
    body: "Use curated reading paths when retrieval would expose repository structure too early.",
  },
  {
    label: "Publication",
    title: "Publication Process",
    href: "/resources/publication-process/",
    body: "Read how public pages convert source-bounded material into reader surfaces.",
  },
];

const provenanceRows = [
  {
    reference: "The AEther Flow Website. (2026a). Memory, Registry, and Retrieval Components [Product requirements document: PRD-05].",
    use: "Defines retrieval-support status and source-first memory requirements.",
  },
  {
    reference: "The AEther Flow Website. (2026b). Folder and Repository Topology Components [Product requirements document: PRD-08].",
    use: "Defines local retrieval, generated mirror, and `.local` folder boundaries.",
  },
  {
    reference: "The AEther Flow Website. (2026c). AI Memory Registries Content Dossier [Content dossier].",
    use: "Provides the memory-preflight route boundary used as a related internal path.",
  },
  {
    reference: "The AEther Flow Project. (2026). Source authority and generated derivatives [Source file: github-facing/source-authority-explainer.md].",
    use: "Provides upstream framing for source-versus-retrieval conflict handling.",
  },
];

const retrievalSvg = `
  <svg class="track-map-svg physics-greenfield-svg" viewBox="0 0 620 360" role="img" aria-labelledby="resources-retrieval-title resources-retrieval-desc">
    <title id="resources-retrieval-title">Animated retrieval layer routing map</title>
    <desc id="resources-retrieval-desc">Retrieval layers route through source inspection before any public claim can change.</desc>
    <defs>
      <radialGradient id="resources-retrieval-core" cx="50%" cy="50%" r="66%">
        <stop offset="0%" stop-color="var(--owl-cyan-400)" stop-opacity="0.58" />
        <stop offset="44%" stop-color="var(--owl-orange-500)" stop-opacity="0.2" />
        <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
      </radialGradient>
      <filter id="resources-retrieval-bloom" x="-20%" y="-24%" width="140%" height="148%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <path class="track-figure-bg" d="M0 0H620V360H0Z" />
    <circle class="physics-glow" cx="310" cy="180" r="184" fill="url(#resources-retrieval-core)" />
    <g class="physics-grid" aria-hidden="true">
      <ellipse cx="310" cy="180" rx="224" ry="118" />
      <ellipse cx="310" cy="180" rx="138" ry="78" />
      <path d="M96 116 H524" />
      <path d="M96 244 H524" />
      <path d="M310 76 V284" />
    </g>
    <g filter="url(#resources-retrieval-bloom)" aria-hidden="true">
      <path class="track-figure-path signal-path" d="M116 116 C194 160, 242 180, 310 180 C378 180, 426 160, 504 116" />
      <path class="track-figure-path orange-path" d="M116 244 C194 200, 242 180, 310 180 C378 180, 426 200, 504 244" />
      <path class="track-figure-path signal-path alternate" d="M116 180 C204 96, 416 96, 504 180" />
      <path class="track-figure-path orange-path alternate" d="M116 180 C204 264, 416 264, 504 180" />
    </g>
    <circle class="track-figure-core" cx="310" cy="180" r="42" aria-hidden="true" />
    <g class="track-figure-nodes hollow-nodes" aria-hidden="true">
      <circle cx="116" cy="116" r="13" />
      <circle cx="116" cy="180" r="13" />
      <circle cx="116" cy="244" r="13" />
      <circle cx="310" cy="180" r="13" />
      <circle cx="504" cy="116" r="13" />
      <circle cx="504" cy="180" r="13" />
      <circle cx="504" cy="244" r="13" />
    </g>
  </svg>
`;
---

<BaseLayout
  title="Retrieval Layers"
  description="Resources retrieval layers route explaining memory, semantic extracts, generated mirrors, local indexes, and caches as navigation support only."
  bodyClass="project-overview-page project-track-page resources-greenfield-page ai-greenfield-page"
>
  <CommandBand
    className="overview-shell overview-command-hero"
    eyebrow="Resources / Retrieval Layers"
    title="Retrieval Layers"
    lead="Retrieval layers help readers find source candidates. They do not decide claim status, prove physics, or replace source inspection."
    headingLevel="h1"
  >
    <div class="overview-actions" aria-label="Retrieval layers page actions">
      <a class="primary-link" href="#retrieval-layers">Read layer classes</a>
      <a class="secondary-link" href="/resources/generated-derivatives/">Derivatives</a>
      <a class="secondary-link" href="/resources/">Resources</a>
    </div>
    <Fragment slot="visual">
      <figure class="track-page-figure physics-figure" aria-labelledby="resources-retrieval-caption">
        <Fragment set:html={retrievalSvg} />
        <figcaption id="resources-retrieval-caption">
          Visual orientation only: retrieval routes candidate material to source inspection.
        </figcaption>
      </figure>
    </Fragment>
  </CommandBand>

  <section class="greenfield-intro-panel" aria-label="Retrieval layers introduction">
    <p>
      Retrieval is useful when it shortens the path to the owner. It becomes
      unsafe when the lookup result is treated as the owner.
    </p>
  </section>


  <ComprehensionBlocks content={greenfieldRouteDiagramBlocks.resourcesRetrievalLayers} />

  <section id="retrieval-layers" class="track-page-band" aria-labelledby="retrieval-layers-title">
    <div class="track-page-heading">
      <p class="eyebrow">Retrieval layer classes</p>
      <h2 id="retrieval-layers-title">Navigation layers stay below source authority.</h2>
      <p>
        The route keeps local, generated, and indexed material useful without
        giving it source status.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Layer</th>
          <th scope="col">Examples</th>
          <th scope="col">Use</th>
          <th scope="col">Limit</th>
        </tr>
      </thead>
      <tbody>
        {layerRows.map((row) => (
          <tr>
            <th scope="row">{row.layer}</th>
            <td>{row.examples}</td>
            <td>{row.use}</td>
            <td>{row.limit}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="retrieval-workflow-title">
    <div class="track-page-heading">
      <p class="eyebrow">Source-first workflow</p>
      <h2 id="retrieval-workflow-title">A retrieval hit becomes useful only after owner inspection.</h2>
      <p>
        The workflow separates discovery, source ownership, inspection, and
        uncertainty reporting.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Step</th>
          <th scope="col">Action</th>
          <th scope="col">Boundary</th>
        </tr>
      </thead>
      <tbody>
        {workflowRows.map((row) => (
          <tr>
            <th scope="row">{row.step}</th>
            <td>{row.action}</td>
            <td>{row.boundary}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="retrieval-risks-title">
    <div class="track-page-heading">
      <p class="eyebrow">Common failure modes</p>
      <h2 id="retrieval-risks-title">The useful warning is specific, not vague.</h2>
      <p>
        Retrieval layers fail differently. Naming the failure mode makes the
        safer next step clear.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Risk</th>
          <th scope="col">Safe response</th>
          <th scope="col">Blocked use</th>
        </tr>
      </thead>
      <tbody>
        {riskRows.map((row) => (
          <tr>
            <th scope="row">{row.risk}</th>
            <td>{row.safeResponse}</td>
            <td>{row.blockedUse}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <CommandBand
    className="overview-panel overview-command-band"
    eyebrow="Related internal routes"
    title="Use retrieval with source, derivative, registry, publication, and library boundaries."
    lead="The internal route network keeps readers oriented before they open local or generated surfaces."
  >
    <EvidenceRail
      items={relatedRoutes.map((route) => ({
        ...route,
        actionLabel: "Open route",
      }))}
      ariaLabel="Related retrieval layer routes"
      className="overview-track-rail"
    />
  </CommandBand>

  <section class="track-page-band" aria-labelledby="retrieval-provenance-title">
    <div class="track-page-heading">
      <p class="eyebrow">Provenance and limits</p>
      <h2 id="retrieval-provenance-title">This page explains retrieval support; it does not make retrieval authoritative.</h2>
      <p>
        The references below are cited in APA 7 style as implementation basis.
        They support the public explanation while current source files,
        registries, manifests, and governed records retain authority.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Reference</th>
          <th scope="col">Used here for</th>
        </tr>
      </thead>
      <tbody>
        {provenanceRows.map((row) => (
          <tr>
            <th scope="row">{row.reference}</th>
            <td>{row.use}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
