---
import CommandBand from "../../../components/CommandBand.astro";
import EvidenceRail from "../../../components/EvidenceRail.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ComprehensionBlocks from "../../../components/ComprehensionBlocks.astro";
import { greenfieldRouteDiagramBlocks } from "../../../lib/siteContent";

const authorityRows = [
  {
    className: "Canonical physics source",
    examples: "Registered TeX sources and their source registries.",
    websiteUse: "Use for technical physics claims after direct source inspection.",
    limit: "Website copy cannot promote a benchmark, derivation, or source law.",
  },
  {
    className: "Canonical documentation source",
    examples: "Registered Markdown sources, README files, role contracts, schemas, and publication briefs.",
    websiteUse: "Use for workflow, role, schema, publication, and governance explanations.",
    limit: "Generated pages cannot silently strengthen the authored source.",
  },
  {
    className: "Registry",
    examples: "CSV source, derivative, role, task, claim-boundary, publication, and relationship registries.",
    websiteUse: "Use for provenance, relationship, status, and source-location claims.",
    limit: "Registry dashboards show provenance and status; they do not prove physics claims.",
  },
  {
    className: "Generated derivative",
    examples: "PDFs, HTML explainers, GitHub-facing Markdown, generated wiki pages, and public diagrams.",
    websiteUse: "Use for reading support and source discovery.",
    limit: "Generated derivatives help readers inspect the project, but registered sources and tracked control records remain authoritative.",
  },
  {
    className: "Local retrieval layer",
    examples: "Semantic extracts, Obsidian mirrors, SQLite indexes, memory lookup, and `.local/` caches.",
    websiteUse: "Use for navigation and candidate source discovery.",
    limit: "Memory lookup is a navigation aid, not claim authority.",
  },
  {
    className: "Website PRD",
    examples: "Website information-space PRDs and implementation plans.",
    websiteUse: "Use for page requirements, route behavior, and acceptance criteria.",
    limit: "Planning artifacts are not canonical source authority for project claims.",
  },
];

const checklistRows = [
  {
    step: "Name the claim class",
    question: "Is the statement physics, workflow, publication, registry, derivative, current-state, or route-implementation language?",
    outcome: "Select the right authority lane before writing copy.",
  },
  {
    step: "Inspect the owner",
    question: "Which source file, registry row, handoff, completion, or PRD owns the statement?",
    outcome: "Use the owner for status; use the website for explanation.",
  },
  {
    step: "Check conflict rules",
    question: "Does a derivative, memory hit, or page summary disagree with the source?",
    outcome: "When source and derivative disagree, inspect the canonical source and current tracked control record.",
  },
  {
    step: "Add the limit",
    question: "What does the positive evidence not prove?",
    outcome: "State the non-proof, non-promotion, or non-authority boundary near the evidence.",
  },
];

const relatedRoutes = [
  {
    label: "Records",
    title: "Registries",
    href: "/resources/registries/",
    body: "Read how registry rows carry status and provenance without becoming proof.",
  },
  {
    label: "Memory",
    title: "Memory Preflight",
    href: "/ai-research-system/memory-preflight/",
    body: "Separate source-finding support from claim authority.",
  },
  {
    label: "Checks",
    title: "Validators and Handoffs",
    href: "/ai-research-system/validators-and-handoffs/",
    body: "Keep validator PASS and handoff evidence below protected decisions.",
  },
  {
    label: "Claims",
    title: "Physics Claim Status",
    href: "/physics/claim-status/",
    body: "Read claim-state examples with blocked overreads visible.",
  },
  {
    label: "Resources",
    title: "Resources Overview",
    href: "/resources/",
    body: "Return to the Resources category landing page.",
  },
  {
    label: "Diagrams",
    title: "Diagram Gallery",
    href: "/resources/diagrams/",
    body: "Inspect visual aids as reader support, not authority.",
  },
];

const provenanceRows = [
  {
    source: "The AEther Flow Website. (2026a). Memory, Registry, and Retrieval Components [Product requirements document: PRD-05].",
    use: "Defines source, registry, derivative, retrieval, and provenance classes.",
  },
  {
    source: "The AEther Flow Website. (2026b). Documentation, Publication, and Website Components [Product requirements document: PRD-06].",
    use: "Defines publication and reader-surface boundaries.",
  },
  {
    source: "The AEther Flow Website. (2026c). Website Positioning Guidance [Product requirements document: PRD-10].",
    use: "Defines safe public claim language and forbidden overclaims.",
  },
  {
    source: "The AEther Flow Project. (2026). Source authority and generated derivatives [Source file: github-facing/source-authority-explainer.md].",
    use: "Provides upstream source-authority framing.",
  },
];

const authoritySvg = `
  <svg class="track-map-svg physics-greenfield-svg" viewBox="0 0 620 360" role="img" aria-labelledby="resources-authority-title resources-authority-desc">
    <title id="resources-authority-title">Animated Resources source authority ladder</title>
    <desc id="resources-authority-desc">Canonical sources, registries, generated derivatives, retrieval support, and website pages remain separate authority layers.</desc>
    <defs>
      <radialGradient id="resources-authority-core" cx="50%" cy="50%" r="66%">
        <stop offset="0%" stop-color="var(--owl-cyan-400)" stop-opacity="0.56" />
        <stop offset="44%" stop-color="var(--owl-orange-500)" stop-opacity="0.22" />
        <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
      </radialGradient>
      <filter id="resources-authority-bloom" x="-20%" y="-24%" width="140%" height="148%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <path class="track-figure-bg" d="M0 0H620V360H0Z" />
    <circle class="physics-glow" cx="310" cy="180" r="184" fill="url(#resources-authority-core)" />
    <g class="physics-grid" aria-hidden="true">
      <ellipse cx="310" cy="180" rx="236" ry="118" />
      <ellipse cx="310" cy="180" rx="164" ry="78" />
      <path d="M96 116 H524" />
      <path d="M96 180 H524" />
      <path d="M96 244 H524" />
    </g>
    <g filter="url(#resources-authority-bloom)" aria-hidden="true">
      <path class="track-figure-path signal-path" d="M116 244 C190 190, 244 150, 310 116 C376 150, 430 190, 504 244" />
      <path class="track-figure-path orange-path" d="M116 116 C190 170, 244 210, 310 244 C376 210, 430 170, 504 116" />
      <path class="track-figure-path signal-path alternate" d="M116 180 C220 132, 400 132, 504 180" />
      <path class="track-figure-path orange-path alternate" d="M116 180 C220 228, 400 228, 504 180" />
    </g>
    <path class="track-figure-core" d="M310 118 L372 180 L310 242 L248 180 Z" aria-hidden="true" />
    <g class="track-figure-nodes hollow-nodes" aria-hidden="true">
      <circle cx="116" cy="116" r="13" />
      <circle cx="116" cy="180" r="13" />
      <circle cx="116" cy="244" r="13" />
      <circle cx="310" cy="116" r="13" />
      <circle cx="310" cy="244" r="13" />
      <circle cx="504" cy="116" r="13" />
      <circle cx="504" cy="180" r="13" />
      <circle cx="504" cy="244" r="13" />
    </g>
  </svg>
`;
---

<BaseLayout
  title="Source Authority"
  description="Resources source authority route explaining canonical sources, registries, generated derivatives, retrieval layers, and website PRDs without rendering a dedicated authority component."
  bodyClass="project-overview-page project-track-page resources-greenfield-page ai-greenfield-page"
>
  <CommandBand
    className="overview-shell overview-command-hero"
    eyebrow="Resources / Source Authority"
    title="Source Authority"
    lead="Use website pages to find the right source lane. Use registered sources, registries, and governed records to decide claim status."
    headingLevel="h1"
  >
    <div class="overview-actions" aria-label="Resources source authority page actions">
      <a class="primary-link" href="#authority-classes">Read authority classes</a>
      <a class="secondary-link" href="/resources/registries/">Registries</a>
      <a class="secondary-link" href="/resources/">Resources</a>
    </div>
    <Fragment slot="visual">
      <figure class="track-page-figure physics-figure" aria-labelledby="resources-authority-caption">
        <Fragment set:html={authoritySvg} />
        <figcaption id="resources-authority-caption">
          Fact: source lanes, generated derivatives, website reader surfaces,
          and access paths have different authority roles.
        </figcaption>
      </figure>
    </Fragment>
  </CommandBand>

  <section class="greenfield-intro-panel" aria-label="Resources source authority introduction">
    <p>
      This page is itself a Resources page, so its authority boundary appears
      as contextual copy and provenance metadata. It does not render a separate
      source-authority component block.
    </p>
  </section>


  <ComprehensionBlocks content={greenfieldRouteDiagramBlocks.resourcesSourceAuthority} />

  <section id="authority-classes" class="track-page-band" aria-labelledby="authority-classes-title">
    <div class="track-page-heading">
      <p class="eyebrow">Authority classes</p>
      <h2 id="authority-classes-title">Different materials can support different claims.</h2>
      <p>
        A useful resource page makes the class visible before the reader sees a
        polished derivative, registry table, download, or memory reference.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Class</th>
          <th scope="col">Examples</th>
          <th scope="col">Website use</th>
          <th scope="col">Limit</th>
        </tr>
      </thead>
      <tbody>
        {authorityRows.map((row) => (
          <tr>
            <th scope="row">{row.className}</th>
            <td>{row.examples}</td>
            <td>{row.websiteUse}</td>
            <td>{row.limit}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="source-checklist-title">
    <div class="track-page-heading">
      <p class="eyebrow">Source-first checklist</p>
      <h2 id="source-checklist-title">Authority is resolved before claim wording is strengthened.</h2>
      <p>
        The checklist is deliberately conservative: identify the claim class,
        inspect the owner, handle conflicts, and state the non-scope.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Step</th>
          <th scope="col">Question</th>
          <th scope="col">Outcome</th>
        </tr>
      </thead>
      <tbody>
        {checklistRows.map((row) => (
          <tr>
            <th scope="row">{row.step}</th>
            <td>{row.question}</td>
            <td>{row.outcome}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <CommandBand
    className="overview-panel overview-command-band"
    eyebrow="Related internal routes"
    title="Use internal routes before provenance excavation."
    lead="Source authority connects to registries, memory, validators, claim status, and diagram status."
  >
    <EvidenceRail
      items={relatedRoutes.map((route) => ({
        ...route,
        actionLabel: "Open route",
      }))}
      ariaLabel="Related Resources source authority routes"
      className="overview-track-rail"
    />
  </CommandBand>

  <section class="track-page-band" aria-labelledby="authority-provenance-title">
    <div class="track-page-heading">
      <p class="eyebrow">Provenance and limits</p>
      <h2 id="authority-provenance-title">This page explains the boundary; it does not become the boundary.</h2>
      <p>
        The references below are cited in APA 7 style as implementation basis.
        They support the public explanation while leaving claim authority in
        upstream source files, registries, and governed records.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Reference</th>
          <th scope="col">Used here for</th>
        </tr>
      </thead>
      <tbody>
        {provenanceRows.map((row) => (
          <tr>
            <th scope="row">{row.source}</th>
            <td>{row.use}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
