---
import ComprehensionBlocks from "../../components/ComprehensionBlocks.astro";
import DocumentActions from "../../components/DocumentActions.astro";
import EvidenceRail from "../../components/EvidenceRail.astro";
import StatusDossier from "../../components/StatusDossier.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resourcesDocumentsComprehension } from "../../lib/supportComprehensionContent";
import {
  approvedDownloads,
  ontologyDocuments,
  ontologyDocumentSequence,
} from "../../lib/manifests";

const approvedDocumentDownloads = approvedDownloads.filter(
  (item) => item.kind === "pdf" || item.kind === "tex",
);
const approvedDocumentLabel =
  approvedDocumentDownloads.length === 1
    ? "approved source-backed document file"
    : "approved source-backed document files";

const documentPathLinks = [
  {
    title: "Ontology vocabulary",
    href: "/physics/ontology/",
    body: "Start here for AEther, AEther-flow, vocabulary, and derivation boundaries.",
  },
  {
    title: "Exact-GR benchmark boundary",
    href: "/physics/exact-gr-benchmark/",
    body: "Read why exact-GR benchmark material is not a full first-principles derivation.",
  },
  {
    title: "Current physics state",
    href: "/physics/claim-status/",
    body: "Read where ontology documents sit relative to open derivation burdens and claim gates.",
  },
  {
    title: "Source authority",
    href: "/resources/source-authority/",
    body: "How to interpret website pages, manifests, derivatives, and upstream records.",
  },
];

const documentReadingGuide = [
  {
    label: "1",
    title: "Read the vocabulary first",
    body:
      "Use the ontology page before opening PDFs so terms and claim boundaries are already visible.",
    href: "/physics/ontology/",
  },
  {
    label: "2",
    title: "Check benchmark status",
    body:
      "Use the exact-GR benchmark page to keep canonical ontology material separate from completed derivation language.",
    href: "/physics/exact-gr-benchmark/",
  },
  {
    label: "3",
    title: "Inspect source authority",
    body:
      "Use the source-authority page before relying on a website copy, PDF derivative, manifest row, or hash.",
    href: "/resources/source-authority/",
  },
  {
    label: "4",
    title: "Then open documents",
    body:
      "Use PDFs for reading and TeX downloads for source inspection against registry metadata.",
  },
];

const specialistReadingOrder = ontologyDocumentSequence.map((entry) => ({
  slug: entry.slug,
  label: String(entry.ordinal),
  title: entry.title,
  body: entry.guidance,
}));

const documentGuidanceBySlug = Object.fromEntries(
  specialistReadingOrder.map((item) => [
    item.slug,
    {
      order: Number(item.label),
      reason: item.body,
    },
  ]),
);

const sourceStatusGuide = [
  {
    label: "TeX",
    title: "Source-inspection target",
    body:
      "Registered TeX files carry source authority for their registered version, with claim status governed by upstream registry metadata.",
  },
  {
    label: "PDF",
    title: "Readable derivative",
    body:
      "PDFs are generated for human reading. Use them to understand the document, not to override TeX or registry status.",
  },
  {
    label: "Website copy",
    title: "Manifest-backed asset",
    body:
      "The website copy has a source commit, hash, and import timestamp. Release readiness still depends on curator source-drift review.",
  },
];
---

<BaseLayout
  title="Ontology Documents"
  description="Canonical ontology PDF and TeX downloads for The AEther Flow website."
  bodyClass="project-overview-page project-support-page"
>
  <section class="content-band project-support-hero" aria-labelledby="documents-title">
    <div class="project-support-copy">
      <div class="section-header">
        <p class="eyebrow">Ontology documents</p>
        <h1 id="documents-title">Ontology Documents</h1>
        <p class="lead">
          This library serves approved website copies of ontology TeX and PDF
          assets with a reading guide. Registered TeX files are the
          source-inspection target for their registered version; PDFs are
          generated human-readable derivatives.
        </p>
      </div>
    </div>

    <figure class="support-figure document-release-flow" aria-labelledby="documents-figure-caption">
      <svg
        class="support-svg"
        viewBox="0 0 520 340"
        role="img"
        aria-labelledby="documents-figure-title documents-figure-desc"
      >
        <title id="documents-figure-title">Animated ontology document release flow</title>
        <desc id="documents-figure-desc">
          Registered TeX sources flow through manifests into public PDF and TeX
          downloads while source authority stays attached to the source record.
        </desc>
        <path class="support-bg" d="M0 0H520V340H0Z" />
        <g class="support-dust" aria-hidden="true">
          <circle cx="62" cy="74" r="1.2" />
          <circle cx="120" cy="274" r="1" />
          <circle cx="186" cy="94" r="0.9" />
          <circle cx="250" cy="288" r="1.2" />
          <circle cx="332" cy="68" r="1" />
          <circle cx="418" cy="262" r="1.1" />
          <circle cx="474" cy="116" r="0.9" />
        </g>
        <g class="support-link-lines" aria-hidden="true">
          <path class="support-line orange-line" d="M92 92 C154 114, 196 142, 246 170" />
          <path class="support-line signal-line" d="M92 248 C152 220, 196 198, 246 170" />
          <path class="support-line orange-line alternate" d="M274 170 C326 126, 368 102, 432 88" />
          <path class="support-line signal-line alternate" d="M274 170 C334 194, 374 222, 432 252" />
        </g>
        <circle class="support-core" cx="260" cy="170" r="34" aria-hidden="true" />
        <g class="support-nodes" aria-hidden="true">
          <circle cx="92" cy="92" r="15" />
          <circle cx="92" cy="248" r="15" />
          <circle cx="432" cy="88" r="15" />
          <circle cx="432" cy="252" r="15" />
        </g>
        <g class="support-rings" aria-hidden="true">
          <circle cx="260" cy="170" r="58" />
          <circle cx="260" cy="170" r="92" />
        </g>
      </svg>
      <figcaption id="documents-figure-caption">
        Registered TeX sources, generated PDFs, website copies, and
        manifest records have distinct authority and reuse roles.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={resourcesDocumentsComprehension} />

  <section class="content-band content-band-tight" aria-labelledby="document-path-title">
    <div class="section-header">
      <p class="eyebrow">Read this first</p>
      <h2 id="document-path-title">Use public pages before downloads.</h2>
      <p class="lead">
        Source-backed explanation is available through the public project pages
        before the raw document files. The documents below are for direct
        reading and inspection, with hashes and source commits recorded in the
        public manifests.
      </p>
    </div>
    <EvidenceRail
      items={documentPathLinks.map((link) => ({
        ...link,
        actionLabel: "Open route",
      }))}
      ariaLabel="Document reading path"
      className="link-grid document-path-rail"
      ordered
    />
  </section>

  <section class="content-band content-band-tight" aria-labelledby="document-guide-title">
    <div class="section-header">
      <p class="eyebrow">Reader sequence</p>
      <h2 id="document-guide-title">Follow the reading guide before treating files as evidence.</h2>
      <p class="lead">
        The guide below is a reader aid. It is not a new scientific dependency
        proof, and it does not promote any document beyond its registry status.
      </p>
    </div>
    <StatusDossier
      items={documentReadingGuide}
      ariaLabel="Ontology document read-this-first guide"
      className="track-status-grid"
    />
  </section>

  <section class="content-band content-band-tight" aria-labelledby="specialist-reading-title">
    <div class="section-header">
      <p class="eyebrow">Specialist order</p>
      <h2 id="specialist-reading-title">Start at the canonical front door.</h2>
      <p class="lead">
        The overview fixes the package order and claim boundary. Follow it
        through the six-document scientific core, then use the flagship article
        as a release-facing synthesis rather than a replacement for the overview.
      </p>
    </div>
    <StatusDossier
      items={specialistReadingOrder}
      ariaLabel="Specialist ontology document reading order"
      className="track-status-grid"
    />
  </section>

  <section class="content-band content-band-tight" aria-labelledby="document-status-title">
    <div class="section-header">
      <p class="eyebrow">Source status</p>
      <h2 id="document-status-title">Document asset status is not one flat label.</h2>
      <p class="lead">
        The current manifest contains {approvedDocumentDownloads.length}{" "}
        {approvedDocumentLabel} across {ontologyDocuments.length} ontology
        document rows. Each card below exposes TeX authority, claim status,
        promotion status, source commit, website import date, and hashes where
        available.
      </p>
    </div>
    <StatusDossier
      items={sourceStatusGuide}
      ariaLabel="Ontology document source-status guide"
      className="track-status-grid"
    />
  </section>

  <section class="content-band content-band-tight">
    <DocumentActions documents={ontologyDocuments} guidanceBySlug={documentGuidanceBySlug} />
  </section>
</BaseLayout>
