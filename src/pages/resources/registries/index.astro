---
import CommandBand from "../../../components/CommandBand.astro";
import EvidenceRail from "../../../components/EvidenceRail.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ComprehensionBlocks from "../../../components/ComprehensionBlocks.astro";
import ProjectIntroduction from "../../../components/ProjectIntroduction.astro";
import { greenfieldRouteDiagramBlocks } from "../../../lib/siteContent";

const resourcesRegistryExplorerProjectIntroduction = [
  "The Æther Flow Project is a two-part research program about foundational physics and the governed, human-accountable AI research system used to organize and test that work.",
  "Its physics track asks whether ordinary general relativity can be interpreted, and eventually derived, from a deeper Æther or Æther-Flow foundation; general relativity remains the exact benchmark for observable gravity, while the first-principles substrate derivation is still open.",
  "Its AI track uses tracked tasks, Director decisions, bounded AgentJobs, roles, validation, memory preflight, completions, handoffs, and human gates so that theoretical work remains inspectable without becoming accepted physics by workflow alone.",
  "Registries are the project's tracked maps to the material and decisions behind both tracks: their rows can identify an owner, path, status, date, hash, relationship, or limit, but they do not replace the file or decision record they describe.",
  "Source registries point to registered TeX for scoped physics and derivational claims and registered Markdown for authored guidance, contracts, schemas, publication briefs, and source specifications; a reader must still inspect the named source and preserve its exact qualification.",
  "Derivative registries connect PDFs, HTML explainers, GitHub-facing Markdown, wiki notes, and other generated reading surfaces to their inputs, while publication and relationship registries connect briefs, specifications, sources, and outputs without making the downstream surface canonical.",
  "Workflow registries record bounded AgentJobs, Director decisions, roles, tasks, completions, and validation state; a row can show what happened and within which paths, but it cannot widen an allowlist, expand a role, or turn a validator PASS into a scientific verdict.",
  "Claim-boundary rows record allowed wording, forbidden overreads, and required gates, while the Distance-to-GR ledger records named open burdens and evidence paths; neither the boundary metadata nor a burden label executes a gate or closes the first-principles derivation.",
  "A reliable reading sequence is to find the relevant row, open the owner it names, check the recorded status, date, source commit, or freshness boundary, and then state both what the row supports and what it cannot prove.",
  "A hash can identify the contents of a particular file, and an approval status can record a bounded publication or review state, but neither establishes scientific correctness.",
  "As a Resources page, Registry Explorer presents these limits through contextual copy, tables, and provenance rather than a separate Source authority component section.",
  "No registry row, dashboard, hash, approval status, generated derivative, memory hit, validator PASS, review receipt, AI output, or website page independently proves a physics claim, completes the open first-principles derivation, promotes the proposed ontology or a benchmark, expands workflow authority, overrides a human gate, or replaces direct source inspection.",
] as const;

const registryRows = [
  {
    family: "Source registries",
    examples: "TEX_SOURCE_REGISTRY, MARKDOWN_SOURCE_REGISTRY, publication source listings.",
    says: "Which tracked source lane exists and where to inspect it.",
    doesNotSay: "The registry row alone proves the source claim.",
  },
  {
    family: "Derivative registries",
    examples: "PDF, HTML explainer, generated wiki, and semantic registries.",
    says: "Which generated surface exists and how it relates to source material.",
    doesNotSay: "A generated surface has become canonical authority.",
  },
  {
    family: "Workflow registries",
    examples: "AgentJob, Director decision, role-execution, research-task, and project-improvement signal registries.",
    says: "What workflow state or operational record is discoverable.",
    doesNotSay: "The workflow record proves physics or expands role authority.",
  },
  {
    family: "Claim and burden registries",
    examples: "CLAIM_BOUNDARY_REGISTRY and DISTANCE_TO_GR_LEDGER.",
    says: "Allowed wording, forbidden overreads, status boundaries, and open burden labels.",
    doesNotSay: "A dashboard, burden label, or row closes the derivation.",
  },
  {
    family: "Publication and relationship registries",
    examples: "PUBLICATION_BRIEF_REGISTRY and source/derivative relationship rows.",
    says: "How reader surfaces, briefs, source specs, and outputs are connected.",
    doesNotSay: "Publication quality grants source authority.",
  },
];

const readRows = [
  {
    step: "Find the row",
    action: "Use the registry to locate a source, derivative, task, role, claim boundary, or public asset.",
    guardrail: "Do not stop at the row when the claim depends on source text.",
  },
  {
    step: "Inspect the owner",
    action: "Open the source file, handoff, completion, publication brief, or manifest record named by the row.",
    guardrail: "The owner decides the claim class and current status.",
  },
  {
    step: "Read status and date",
    action: "Check approval status, freshness, source commit, or current-state boundary before reuse.",
    guardrail: "Outdated metadata is a maintenance signal, not proof or rejection.",
  },
  {
    step: "Record the limit",
    action: "State what the registry supports and what it cannot prove.",
    guardrail: "Registry dashboards show provenance and status; they do not prove physics claims.",
  },
];

const proofLimitRows = [
  {
    signal: "Hash",
    supports: "File identity for a specific published or source object.",
    limit: "Hash integrity does not establish scientific correctness.",
  },
  {
    signal: "Approval status",
    supports: "Publication, asset, or review state for the named surface.",
    limit: "Approval status is not a theorem proof or source-law adoption.",
  },
  {
    signal: "Claim-boundary row",
    supports: "Allowed, forbidden, and gate-required wording for a scoped claim.",
    limit: "Boundary metadata does not execute the gate it describes.",
  },
  {
    signal: "Workflow row",
    supports: "Traceability for a task, job, role, or decision.",
    limit: "Traceability does not widen the original permission envelope.",
  },
];

const relatedRoutes = [
  {
    label: "Authority",
    title: "Source Authority",
    href: "/resources/source-authority/",
    body: "Read the source, registry, derivative, and retrieval class ladder.",
  },
  {
    label: "Memory",
    title: "Memory Preflight",
    href: "/ai-research-system/memory-preflight/",
    body: "Use memory to find candidate registry rows without treating retrieval as authority.",
  },
  {
    label: "Checks",
    title: "Validators and Handoffs",
    href: "/ai-research-system/validators-and-handoffs/",
    body: "Interpret PASS, handoff, and registry evidence at the right grain.",
  },
  {
    label: "Claims",
    title: "Physics Claim Status",
    href: "/physics/claim-status/",
    body: "Read public claim states with blocked overreads visible.",
  },
  {
    label: "Burdens",
    title: "Open Burdens",
    href: "/physics/open-burdens/",
    body: "Use burden labels without turning them into progress proof.",
  },
  {
    label: "Resources",
    title: "Resources Overview",
    href: "/resources/",
    body: "Return to the Resources category landing page.",
  },
];

const registriesSvg = `
  <svg class="track-map-svg physics-greenfield-svg" viewBox="0 0 620 360" role="img" aria-labelledby="resources-registries-title resources-registries-desc">
    <title id="resources-registries-title">Animated registry provenance map</title>
    <desc id="resources-registries-desc">Registry families point to source, derivative, workflow, claim, and publication records while proof remains outside the registry map.</desc>
    <defs>
      <radialGradient id="resources-registries-core" cx="50%" cy="50%" r="66%">
        <stop offset="0%" stop-color="var(--owl-orange-100)" stop-opacity="0.6" />
        <stop offset="42%" stop-color="var(--owl-cyan-400)" stop-opacity="0.24" />
        <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
      </radialGradient>
      <filter id="resources-registries-bloom" x="-20%" y="-24%" width="140%" height="148%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <path class="track-figure-bg" d="M0 0H620V360H0Z" />
    <circle class="physics-glow" cx="310" cy="180" r="184" fill="url(#resources-registries-core)" />
    <g class="physics-grid" aria-hidden="true">
      <ellipse cx="310" cy="180" rx="230" ry="116" />
      <ellipse cx="310" cy="180" rx="144" ry="82" />
      <path d="M92 180 H528" />
      <path d="M310 76 V284" />
    </g>
    <g filter="url(#resources-registries-bloom)" aria-hidden="true">
      <path class="track-figure-path signal-path" d="M100 180 C172 108, 248 108, 310 180 C372 252, 448 252, 520 180" />
      <path class="track-figure-path orange-path" d="M100 180 C172 252, 248 252, 310 180 C372 108, 448 108, 520 180" />
      <path class="track-figure-path signal-path alternate" d="M176 112 C240 160, 380 200, 444 248" />
      <path class="track-figure-path orange-path alternate" d="M176 248 C240 200, 380 160, 444 112" />
    </g>
    <circle class="track-figure-core" cx="310" cy="180" r="42" aria-hidden="true" />
    <g class="track-figure-nodes hollow-nodes" aria-hidden="true">
      <circle cx="100" cy="180" r="13" />
      <circle cx="176" cy="112" r="13" />
      <circle cx="176" cy="248" r="13" />
      <circle cx="310" cy="180" r="13" />
      <circle cx="444" cy="112" r="13" />
      <circle cx="444" cy="248" r="13" />
      <circle cx="520" cy="180" r="13" />
    </g>
  </svg>
`;
---

<BaseLayout
  title="Registries"
  description="Resources registries route explaining registry families, provenance and status use, proof limits, and source-inspection boundaries."
  bodyClass="project-overview-page project-track-page resources-greenfield-page ai-greenfield-page"
>
  <CommandBand
    className="overview-shell overview-command-hero"
    eyebrow="Resources / Registries"
    title="Registries"
    lead="Registries are provenance and status maps. They help readers find the owner of a claim, but they do not prove physics or promote claims."
    headingLevel="h1"
  >
    <div class="overview-actions" aria-label="Resources registries page actions">
      <a class="primary-link" href="#registry-families">Read registry families</a>
      <a class="secondary-link" href="/resources/source-authority/">Source authority</a>
      <a class="secondary-link" href="/resources/">Resources</a>
    </div>
    <Fragment slot="visual">
      <figure class="track-page-figure physics-figure" aria-labelledby="resources-registries-caption">
        <Fragment set:html={registriesSvg} />
        <figcaption id="resources-registries-caption">
          Registry rows preserve status and provenance; they do not
          replace source inspection or human-gated decisions.
        </figcaption>
      </figure>
    </Fragment>
  </CommandBand>

  <ProjectIntroduction
    paragraphs={resourcesRegistryExplorerProjectIntroduction}
    ariaLabel="About the Æther Flow Project and Registry Explorer"
  />


  <ComprehensionBlocks content={greenfieldRouteDiagramBlocks.resourcesRegistries} />

  <section id="registry-families" class="track-page-band" aria-labelledby="registry-families-title">
    <div class="track-page-heading">
      <p class="eyebrow">Registry families</p>
      <h2 id="registry-families-title">Rows are maps to evidence, not the evidence itself.</h2>
      <p>
        The registry page starts with families so readers do not mistake every
        CSV row for the same kind of authority.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Family</th>
          <th scope="col">Examples</th>
          <th scope="col">What it can say</th>
          <th scope="col">What it cannot say</th>
        </tr>
      </thead>
      <tbody>
        {registryRows.map((row) => (
          <tr>
            <th scope="row">{row.family}</th>
            <td>{row.examples}</td>
            <td>{row.says}</td>
            <td>{row.doesNotSay}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="registry-reading-title">
    <div class="track-page-heading">
      <p class="eyebrow">How to read a row</p>
      <h2 id="registry-reading-title">Registry use is a four-step source-inspection workflow.</h2>
      <p>
        A row is most useful when it is followed by owner inspection and a
        clear statement of what the row does not prove.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Step</th>
          <th scope="col">Action</th>
          <th scope="col">Guardrail</th>
        </tr>
      </thead>
      <tbody>
        {readRows.map((row) => (
          <tr>
            <th scope="row">{row.step}</th>
            <td>{row.action}</td>
            <td>{row.guardrail}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="registry-proof-title">
    <div class="track-page-heading">
      <p class="eyebrow">Proof limits</p>
      <h2 id="registry-proof-title">Positive registry signals stay scoped.</h2>
      <p>
        Registry metadata is important because it makes the project auditable.
        It remains metadata, not theorem proof or publication acceptance.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Signal</th>
          <th scope="col">Supports</th>
          <th scope="col">Limit</th>
        </tr>
      </thead>
      <tbody>
        {proofLimitRows.map((row) => (
          <tr>
            <th scope="row">{row.signal}</th>
            <td>{row.supports}</td>
            <td>{row.limit}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <CommandBand
    className="overview-panel overview-command-band"
    eyebrow="Related internal routes"
    title="Read registry rows beside source, memory, validator, and claim boundaries."
    lead="Registries are easier to interpret when their source authority and proof limits are visible."
  >
    <EvidenceRail
      items={relatedRoutes.map((route) => ({
        ...route,
        actionLabel: "Open route",
      }))}
      ariaLabel="Related Resources registries routes"
      className="overview-track-rail"
    />
  </CommandBand>
</BaseLayout>
