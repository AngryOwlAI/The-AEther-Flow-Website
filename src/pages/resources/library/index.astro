---
import CommandBand from "../../../components/CommandBand.astro";
import EvidenceRail from "../../../components/EvidenceRail.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ComprehensionBlocks from "../../../components/ComprehensionBlocks.astro";
import { greenfieldRouteDiagramBlocks } from "../../../lib/siteContent";

const readerPathRows = [
  {
    reader: "First-time reader",
    route: "Start with Home, Resources, Guided Starts, then a topic route.",
    reason: "Context and claim boundaries appear before file or registry structure.",
  },
  {
    reader: "Physics reviewer",
    route: "Use Physics Research, Claim Status, Open Burdens, Documents, then source provenance.",
    reason: "Claim state and open burdens come before generated derivatives or downloads.",
  },
  {
    reader: "AI workflow maintainer",
    route: "Use AI Research System, Workflow, Validators and Handoffs, Memory Preflight, then records.",
    reason: "Operational authority and evidence limits remain visible.",
  },
  {
    reader: "Source/provenance reviewer",
    route: "Use Source Authority, Registries, Publication Process, and Publication And Provenance System.",
    reason: "The review path separates source basis, route maps, manifests, and hash limits.",
  },
  {
    reader: "Site builder",
    route: "Use Library, Publication Process, Repository Map, and Site Builder Guide when available.",
    reason: "Page type, reader job, and source bundle shape should precede editing.",
  },
  {
    reader: "Asset reader",
    route: "Use Ontology Documents, Diagram Gallery, Generated Derivatives, and manifest links.",
    reason: "Downloads and diagrams keep source or derivative status attached.",
  },
];

const libraryRows = [
  {
    shelf: "Reader starts",
    examples: "Home, Guided Starts, Reading Paths, Resources.",
    use: "Choose a route sequence by audience and question.",
    limit: "A recommended path is not source authority.",
  },
  {
    shelf: "Claim and source status",
    examples: "Source Authority, Claim Status, Open Burdens, Registries.",
    use: "Understand authority class, allowed wording, and blocked overreads.",
    limit: "Status pages explain; tracked sources and records decide.",
  },
  {
    shelf: "Publication and derivatives",
    examples: "Generated Derivatives, Publication Process, Publication And Provenance System.",
    use: "Inspect how reader surfaces, manifests, and provenance are built.",
    limit: "Publication quality remains separate from claim authority.",
  },
  {
    shelf: "Documents and diagrams",
    examples: "Ontology Documents, Diagram Gallery, public manifests.",
    use: "Find readable assets with labels, hashes, and source references.",
    limit: "Asset hashes and diagrams do not prove scientific correctness.",
  },
  {
    shelf: "Operations and workflow",
    examples: "Workflow, AgentJob Lifecycle, Roles and Schemas, Validators and Handoffs.",
    use: "Understand how work is bounded, recorded, and validated.",
    limit: "Operational evidence does not become physics proof.",
  },
];

const policyRows = [
  {
    rule: "Reader job first",
    implication: "Organize pages by what the reader is trying to understand.",
    failureMode: "A file-type catalogue exposes repository structure before meaning.",
  },
  {
    rule: "Internal route first",
    implication: "Use website routes as the primary reading path when they exist.",
    failureMode: "A source link becomes a substitute for explanation.",
  },
  {
    rule: "Status label near material",
    implication: "Show source-backed, generated derivative, snapshot, planning, or retrieval status where it matters.",
    failureMode: "A polished page silently inflates authority.",
  },
  {
    rule: "Provenance after comprehension",
    implication: "Expose source and manifest links after the reader knows what they are auditing.",
    failureMode: "Process metadata overwhelms the topic and weakens comprehension.",
  },
];

const relatedRoutes = [
  {
    label: "Publication",
    title: "Publication Process",
    href: "/resources/publication-process/",
    body: "Read how page types, briefs, source specs, validation, and review shape library material.",
  },
  {
    label: "Derivatives",
    title: "Generated Derivatives",
    href: "/resources/generated-derivatives/",
    body: "Distinguish generated reader aids from source authority.",
  },
  {
    label: "Retrieval",
    title: "Retrieval Layers",
    href: "/resources/retrieval-layers/",
    body: "Use memory, semantic, wiki, and local layers as navigation support only.",
  },
  {
    label: "Guides",
    title: "Guided Starts",
    href: "/resources/guided-starts/",
    body: "Use audience-specific reader paths before source archaeology.",
  },
  {
    label: "Documents",
    title: "Ontology Documents",
    href: "/resources/documents/",
    body: "Inspect manifest-backed TeX and PDF materials with status labels.",
  },
  {
    label: "Resources",
    title: "Resources Overview",
    href: "/resources/",
    body: "Return to the Resources category landing page.",
  },
];

const librarySvg = `
  <svg class="track-map-svg physics-greenfield-svg" viewBox="0 0 620 360" role="img" aria-labelledby="resources-library-title resources-library-desc">
    <title id="resources-library-title">Animated Resources library route map</title>
    <desc id="resources-library-desc">Reader-job shelves connect library readers to internal routes before source archaeology.</desc>
    <defs>
      <radialGradient id="resources-library-core" cx="50%" cy="50%" r="66%">
        <stop offset="0%" stop-color="var(--owl-cyan-400)" stop-opacity="0.54" />
        <stop offset="44%" stop-color="var(--owl-orange-500)" stop-opacity="0.24" />
        <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
      </radialGradient>
      <filter id="resources-library-bloom" x="-20%" y="-24%" width="140%" height="148%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <path class="track-figure-bg" d="M0 0H620V360H0Z" />
    <circle class="physics-glow" cx="310" cy="180" r="184" fill="url(#resources-library-core)" />
    <g class="physics-grid" aria-hidden="true">
      <ellipse cx="310" cy="180" rx="234" ry="118" />
      <path d="M112 118 H508" />
      <path d="M112 180 H508" />
      <path d="M112 242 H508" />
      <path d="M222 90 V270" />
      <path d="M398 90 V270" />
    </g>
    <g filter="url(#resources-library-bloom)" aria-hidden="true">
      <path class="track-figure-path signal-path" d="M112 118 C190 154, 232 180, 310 180 C388 180, 430 154, 508 118" />
      <path class="track-figure-path orange-path" d="M112 242 C190 206, 232 180, 310 180 C388 180, 430 206, 508 242" />
      <path class="track-figure-path signal-path alternate" d="M222 90 C250 138, 370 222, 398 270" />
      <path class="track-figure-path orange-path alternate" d="M222 270 C250 222, 370 138, 398 90" />
    </g>
    <circle class="track-figure-core" cx="310" cy="180" r="42" aria-hidden="true" />
    <g class="track-figure-nodes hollow-nodes" aria-hidden="true">
      <circle cx="112" cy="118" r="13" />
      <circle cx="112" cy="242" r="13" />
      <circle cx="222" cy="90" r="13" />
      <circle cx="222" cy="270" r="13" />
      <circle cx="310" cy="180" r="13" />
      <circle cx="398" cy="90" r="13" />
      <circle cx="398" cy="270" r="13" />
      <circle cx="508" cy="118" r="13" />
      <circle cx="508" cy="242" r="13" />
    </g>
  </svg>
`;
---

<BaseLayout
  title="Library"
  description="Resources library route organizing reader paths, publication surfaces, documents, diagrams, workflow pages, and provenance by reader job instead of repository archaeology."
  bodyClass="project-overview-page project-track-page resources-greenfield-page ai-greenfield-page"
>
  <CommandBand
    className="overview-shell overview-command-hero"
    eyebrow="Resources / Library"
    title="Library"
    lead="The Library is a reading surface. It organizes routes by reader job and keeps provenance visible without making repository structure the first task."
    headingLevel="h1"
  >
    <div class="overview-actions" aria-label="Library page actions">
      <a class="primary-link" href="#reader-paths">Choose a path</a>
      <a class="secondary-link" href="/resources/publication-process/">Publication</a>
      <a class="secondary-link" href="/resources/">Resources</a>
    </div>
    <Fragment slot="visual">
      <figure class="track-page-figure physics-figure" aria-labelledby="resources-library-caption">
        <Fragment set:html={librarySvg} />
        <figcaption id="resources-library-caption">
          The Library organizes reader jobs across file structure,
          manifests, route context, and source inspection paths.
        </figcaption>
      </figure>
    </Fragment>
  </CommandBand>

  <section class="greenfield-intro-panel" aria-label="Library introduction">
    <p>
      Library pages support reading paths with provenance and internal routes.
      They are not repository archaeology, proof surfaces, or source authority.
    </p>
  </section>


  <ComprehensionBlocks content={greenfieldRouteDiagramBlocks.resourcesLibrary} />

  <section id="reader-paths" class="track-page-band" aria-labelledby="reader-paths-title">
    <div class="track-page-heading">
      <p class="eyebrow">Reader paths</p>
      <h2 id="reader-paths-title">Choose the path by question before opening files.</h2>
      <p>
        The library starts with reader intent so source links and manifests
        arrive as audit tools rather than as the first cognitive load.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Reader</th>
          <th scope="col">Recommended path</th>
          <th scope="col">Reason</th>
        </tr>
      </thead>
      <tbody>
        {readerPathRows.map((row) => (
          <tr>
            <th scope="row">{row.reader}</th>
            <td>{row.route}</td>
            <td>{row.reason}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="library-shelves-title">
    <div class="track-page-heading">
      <p class="eyebrow">Library shelves</p>
      <h2 id="library-shelves-title">Shelves group reading jobs, not authority by implication.</h2>
      <p>
        A shelf can help readers find material. It cannot promote any page,
        asset, registry, or derivative above its source label.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Shelf</th>
          <th scope="col">Examples</th>
          <th scope="col">Use</th>
          <th scope="col">Limit</th>
        </tr>
      </thead>
      <tbody>
        {libraryRows.map((row) => (
          <tr>
            <th scope="row">{row.shelf}</th>
            <td>{row.examples}</td>
            <td>{row.use}</td>
            <td>{row.limit}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="library-policy-title">
    <div class="track-page-heading">
      <p class="eyebrow">Library policy</p>
      <h2 id="library-policy-title">The library keeps comprehension ahead of provenance detail.</h2>
      <p>
        Provenance is essential, but it becomes most useful after the route has
        explained what the reader is inspecting.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Rule</th>
          <th scope="col">Implication</th>
          <th scope="col">Failure mode</th>
        </tr>
      </thead>
      <tbody>
        {policyRows.map((row) => (
          <tr>
            <th scope="row">{row.rule}</th>
            <td>{row.implication}</td>
            <td>{row.failureMode}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <CommandBand
    className="overview-panel overview-command-band"
    eyebrow="Related internal routes"
    title="Use the library beside publication, derivatives, retrieval, guides, documents, and Resources."
    lead="Internal routes remain the primary reader journey; source and manifest links remain provenance."
  >
    <EvidenceRail
      items={relatedRoutes.map((route) => ({
        ...route,
        actionLabel: "Open route",
      }))}
      ariaLabel="Related library routes"
      className="overview-track-rail"
    />
  </CommandBand>
</BaseLayout>
