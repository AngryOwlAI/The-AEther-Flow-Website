---
import DownloadList from "../../components/DownloadList.astro";
import SourceNotice from "../../components/SourceNotice.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  approvedDownloads,
  downloadStatusCounts,
  downloads,
  sampleDownloads,
} from "../../lib/manifests";
import { resourceGroups } from "../../lib/siteContent";

const sourceRefs = downloads.map((item) => item.source_ref);
const sampleCount = sampleDownloads.length;
const approvedCount = approvedDownloads.length;
const manifestStatusSummary = Object.entries(downloadStatusCounts)
  .map(([status, count]) => `${status}: ${count}`)
  .join(", ");
---

<BaseLayout
  title="Resources"
  description="Manifest-backed downloadable resources for The AEther Flow website."
>
  <section class="content-band" aria-labelledby="resources-title">
    <div class="section-header">
      <p class="eyebrow">Source-index-only</p>
      <h1 id="resources-title">Resources</h1>
      <p class="lead">
        This resource area supports the public reading path while keeping file
        status explicit. Current downloadable files are sample fixtures unless
        the manifest marks them as approved source-backed public assets.
      </p>
    </div>
    <SourceNotice
      claimStatus="source-index-only"
      sourceRefs={sourceRefs}
      updated="2026-06-25"
      note="This resource index is rendered from website-local manifest data and structured page links. It does not create scientific or workflow authority."
    />
  </section>

  <section class="content-band content-band-tight" aria-labelledby="resource-groups-title">
    <div class="section-header">
      <p class="eyebrow">Reader path</p>
      <h2 id="resource-groups-title">Public pages and sample libraries</h2>
      <p class="lead">
        Use the project pages for source-boundary-safe explanation. Use the
        resource libraries to inspect current manifest-backed fixtures.
      </p>
    </div>
    <div class="link-grid">
      {resourceGroups.map((group) => (
        <a class="link-card" href={group.href}>
          <span>{group.title}</span>
          <small>{group.body}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="content-band content-band-tight" aria-labelledby="asset-status-title">
    <div class="section-header">
      <p class="eyebrow">Manifest audit</p>
      <h2 id="asset-status-title">Current downloadable asset status</h2>
      <p class="lead">
        The current manifest records {sampleCount} sample fixture files and{" "}
        {approvedCount} approved source-backed public files. Source-backed
        downloads remain planned until provenance and approval status are
        available in the manifest.
      </p>
    </div>
    <div class="resource-status-grid">
      <article>
        <p>Current files</p>
        <h3>{manifestStatusSummary}</h3>
        <span>
          These counts come from <code>source_manifest.json</code> approval
          statuses and the asset manifest cross-reference.
        </span>
      </article>
      <article>
        <p>Sample fixtures</p>
        <h3>Path and rendering checks</h3>
        <span>
          Sample PDF, TeX, and diagram files validate direct static downloads;
          they are not scientific source documents.
        </span>
      </article>
      <article>
        <p>Planned material</p>
        <h3>Approved downloads deferred</h3>
        <span>
          Real downloadable assets should be added only after source provenance,
          approval status, and usage terms are available.
        </span>
      </article>
    </div>
  </section>

  <section class="content-band content-band-tight">
    <DownloadList
      items={downloads}
      title="Current manifest-backed files"
      description="This list is generated from asset manifest entries. The current rows are sample fixtures unless their status says otherwise."
    />
  </section>
</BaseLayout>
