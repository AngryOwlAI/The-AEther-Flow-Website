---
import CommandBand from "../../components/CommandBand.astro";
import EvidenceRail from "../../components/EvidenceRail.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { downloadStatusCounts } from "../../lib/manifests";
import ComprehensionBlocks from "../../components/ComprehensionBlocks.astro";
import ProjectIntroduction from "../../components/ProjectIntroduction.astro";
import { greenfieldRouteDiagramBlocks } from "../../lib/siteContent";

const resourcesOverviewProjectIntroduction =
  "The Æther Flow Project is a two-part research program about foundational physics and the governed, human-accountable AI research system used to organize and test that work. Its physics track asks whether ordinary general relativity can be interpreted, and eventually derived, from a deeper Æther or Æther-Flow foundation; general relativity remains the exact benchmark for observable gravity, while the first-principles substrate derivation is still open. Its AI track uses tracked tasks, bounded AgentJobs, roles, validation, memory preflight, completions, handoffs, and human gates to make theoretical work inspectable without turning workflow results into scientific proof. This Resources page is the public map for reading evidence around both tracks. Start with the internal route that matches the question—source authority, registries, generated derivatives, retrieval, publication, the library, reading paths, repository structure, builder guidance, diagrams, documents, guided starts, or reviewer material—then check its status label and follow provenance when direct inspection is needed. Registered TeX carries scoped physics and derivational claims within its stated status; registered Markdown and tracked control records carry guidance and workflow authority within their own lanes; and registries record provenance, relationships, hashes, routing, and status without replacing the source files they describe. Generated pages, PDFs, diagrams, and downloads help people read the project, while semantic extracts, Obsidian mirrors, SQLite indexes, and local caches help them find material; when any of those downstream surfaces disagrees with a registered source or current tracked record, the source and record win. Website manifests expose a public file's path, type, byte count, hash, status, and source reference, but a hash identifies file contents rather than scientific correctness. Publication briefs define the reader and acceptance criteria, source specifications bind public outputs to inspected evidence, and deterministic checks, desktop or mobile screenshots, and review notes record bounded publication quality rather than source authority. No route card, manifest row, download, hash, registry entry, generated derivative, retrieval result, validator PASS, screenshot, review receipt, AI output, or website page independently proves a physics claim, completes the open first-principles derivation, promotes the proposed ontology or a benchmark, grants workflow authority, or replaces human review.";

const liveResourceRoutes = [
  {
    label: "Start",
    title: "Source Authority",
    href: "/resources/source-authority/",
    body: "Learn which layer owns claims before opening registries, derivatives, or downloads.",
  },
  {
    label: "Records",
    title: "Registries",
    href: "/resources/registries/",
    body: "Use registries as provenance and status maps, not proof surfaces.",
  },
  {
    label: "Derivatives",
    title: "Generated Derivatives",
    href: "/resources/generated-derivatives/",
    body: "Separate generated reader aids from canonical source authority.",
  },
  {
    label: "Retrieval",
    title: "Retrieval Layers",
    href: "/resources/retrieval-layers/",
    body: "Use memory, semantic, wiki, and cache layers for navigation only.",
  },
  {
    label: "Publication",
    title: "Publication Process",
    href: "/resources/publication-process/",
    body: "Read how briefs, source specs, validation, and review keep pages bounded.",
  },
  {
    label: "Library",
    title: "Library",
    href: "/resources/library/",
    body: "Browse reader paths before source files and repository structure.",
  },
  {
    label: "Paths",
    title: "Reading Paths",
    href: "/resources/reading-paths/",
    body: "Choose internal route sequences by audience and question before source archaeology.",
  },
  {
    label: "Map",
    title: "Repository Map",
    href: "/resources/repository-map/",
    body: "Separate source, control, generated, local, tooling, and archival lanes.",
  },
  {
    label: "Builder",
    title: "Site Builder Guide",
    href: "/resources/site-builder-guide/",
    body: "Use source bundles before implementing future public routes.",
  },
  {
    label: "Assets",
    title: "Diagram Gallery",
    href: "/resources/diagrams/",
    body: "Inspect the greenfield diagram inventory reset and publication workflow.",
  },
  {
    label: "Documents",
    title: "Ontology Documents",
    href: "/resources/documents/",
    body: "Open manifest-backed TeX and PDF assets with status labels preserved.",
  },
  {
    label: "Guides",
    title: "Guided Starts",
    href: "/resources/guided-starts/",
    body: "Choose an internal reading path before source archaeology.",
  },
  {
    label: "Review",
    title: "Reviewer Packet",
    href: "/resources/reviewer-packet/",
    body: "Use the reviewer packet when evaluating boundaries across physics and AI workflow pages.",
  },
];

const routeRows = [
  {
    title: "Source Authority",
    readerJob: "Understand authority classes before reading assets or registries.",
    href: "/resources/source-authority/",
  },
  {
    title: "Registries",
    readerJob: "Interpret registry rows as provenance and workflow state.",
    href: "/resources/registries/",
  },
  {
    title: "Generated Derivatives",
    readerJob: "Distinguish generated reader surfaces from source authority.",
    href: "/resources/generated-derivatives/",
  },
  {
    title: "Retrieval Layers",
    readerJob: "Treat memory, wiki, semantic, and cache layers as navigation support.",
    href: "/resources/retrieval-layers/",
  },
  {
    title: "Publication Process",
    readerJob: "Read source-to-publication workflow without confusing quality and authority.",
    href: "/resources/publication-process/",
  },
  {
    title: "Library",
    readerJob: "Browse reading surfaces by reader job rather than repository layout.",
    href: "/resources/library/",
  },
  {
    title: "Reading Paths",
    readerJob: "Choose a route sequence by audience and question.",
    href: "/resources/reading-paths/",
  },
  {
    title: "Repository Map",
    readerJob: "Understand folder classes without treating local paths as authority.",
    href: "/resources/repository-map/",
  },
  {
    title: "Site Builder Guide",
    readerJob: "Map page types to source bundles and claim-boundary checks.",
    href: "/resources/site-builder-guide/",
  },
  {
    title: "Diagram Gallery",
    readerJob: "Inspect the greenfield inventory reset, static diagram workflow, and non-authority labels.",
    href: "/resources/diagrams/",
  },
];

const manifestRows = Object.entries(downloadStatusCounts).map(([status, count]) => ({
  status,
  count,
  meaning:
    status === "approved"
      ? "Approved public assets with manifest-backed source references."
      : status === "sample"
        ? "Sample fixtures retained for scaffold or visual support."
        : status === "source-index-only"
          ? "Indexed source records without a direct public download."
          : "Manifest category that requires its own status label before use.",
}));

const boundaryRows = [
  {
    surface: "Resource route",
    safeUse: "Guide the reader toward a page, asset class, or source concept.",
    limit: "A route card does not promote claims or create authority.",
  },
  {
    surface: "Manifest row",
    safeUse: "Expose path, kind, hash, status, and source reference for a website asset.",
    limit: "A hash proves file identity only; it does not prove scientific correctness.",
  },
  {
    surface: "Download",
    safeUse: "Let readers inspect a committed public file.",
    limit: "Downloads retain their source or derivative status.",
  },
  {
    surface: "Source/provenance link",
    safeUse: "Support audit after the internal explanation is understood.",
    limit: "External source links should not replace the primary internal reading path.",
  },
];

const resourcesSvg = `
  <svg class="track-map-svg physics-greenfield-svg" viewBox="0 0 620 360" role="img" aria-labelledby="resources-overview-title resources-overview-desc">
    <title id="resources-overview-title">Animated Resources route map</title>
    <desc id="resources-overview-desc">Internal Resources routes, manifests, documents, diagrams, and future reading surfaces orbit a central provenance boundary.</desc>
    <defs>
      <radialGradient id="resources-overview-core" cx="50%" cy="50%" r="66%">
        <stop offset="0%" stop-color="var(--owl-orange-100)" stop-opacity="0.58" />
        <stop offset="42%" stop-color="var(--owl-cyan-400)" stop-opacity="0.24" />
        <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
      </radialGradient>
      <filter id="resources-overview-bloom" x="-20%" y="-24%" width="140%" height="148%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <path class="track-figure-bg" d="M0 0H620V360H0Z" />
    <circle class="physics-glow" cx="310" cy="180" r="184" fill="url(#resources-overview-core)" />
    <g class="physics-grid" aria-hidden="true">
      <ellipse cx="310" cy="180" rx="236" ry="112" />
      <ellipse cx="310" cy="180" rx="166" ry="76" />
      <path d="M84 180 H536" />
      <path d="M310 76 V284" />
    </g>
    <g filter="url(#resources-overview-bloom)" aria-hidden="true">
      <path class="track-figure-path orange-path" d="M98 118 C178 154, 234 180, 310 180 C386 180, 442 154, 522 118" />
      <path class="track-figure-path signal-path" d="M98 242 C178 206, 234 180, 310 180 C386 180, 442 206, 522 242" />
      <path class="track-figure-path orange-path alternate" d="M156 180 C218 112, 402 112, 464 180" />
      <path class="track-figure-path signal-path alternate" d="M156 180 C218 248, 402 248, 464 180" />
    </g>
    <circle class="track-figure-core" cx="310" cy="180" r="42" aria-hidden="true" />
    <g class="track-figure-nodes hollow-nodes" aria-hidden="true">
      <circle cx="98" cy="118" r="13" />
      <circle cx="98" cy="242" r="13" />
      <circle cx="156" cy="180" r="13" />
      <circle cx="310" cy="180" r="13" />
      <circle cx="464" cy="180" r="13" />
      <circle cx="522" cy="118" r="13" />
      <circle cx="522" cy="242" r="13" />
    </g>
  </svg>
`;
---

<BaseLayout
  title="Resources"
  description="Resources overview for The AEther Flow Website, organizing source authority, registries, manifests, documents, diagrams, and planned reader paths without creating source authority."
  bodyClass="project-overview-page project-track-page resources-greenfield-page ai-greenfield-page"
>
  <CommandBand
    className="overview-shell overview-command-hero"
    eyebrow="Resources"
    title="Resources"
    lead="Resources organize reader paths, public assets, manifests, and provenance labels. They do not create source authority or scientific proof."
    headingLevel="h1"
  >
    <div class="overview-actions" aria-label="Resources overview page actions">
      <a class="primary-link" href="/resources/source-authority/">Start with authority</a>
      <a class="secondary-link" href="/resources/registries/">Read registries</a>
      <a class="secondary-link" href="#resource-map">See route map</a>
    </div>
    <Fragment slot="visual">
      <figure class="track-page-figure physics-figure" aria-labelledby="resources-overview-caption">
        <Fragment set:html={resourcesSvg} />
        <figcaption id="resources-overview-caption">
          Resources routes organize reader access to documents, diagrams,
          manifests, provenance, and source-authority guidance.
        </figcaption>
      </figure>
    </Fragment>
  </CommandBand>

  <ProjectIntroduction
    text={resourcesOverviewProjectIntroduction}
    ariaLabel="About the Æther Flow Project and its Resources"
  />


  <ComprehensionBlocks content={greenfieldRouteDiagramBlocks.resourcesIndex} />

  <CommandBand
    className="overview-panel overview-command-band"
    eyebrow="Live resource paths"
    title="Begin with the route that matches the question."
    lead="The overview keeps reader jobs visible before file lists, hashes, or source paths appear."
  >
    <EvidenceRail
      items={liveResourceRoutes.map((route) => ({
        ...route,
        actionLabel: "Open route",
      }))}
      ariaLabel="Live Resources routes"
      className="overview-track-rail"
    />
  </CommandBand>

  <section id="resource-map" class="track-page-band" aria-labelledby="resource-map-title">
    <div class="track-page-heading">
      <p class="eyebrow">Resource route map</p>
      <h2 id="resource-map-title">Resources is a category landing page, not a loose link index.</h2>
      <p>
        Each child route has a reader job and a status boundary before readers
        reach manifests, files, or provenance records.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Route</th>
          <th scope="col">Reader job</th>
        </tr>
      </thead>
      <tbody>
        {routeRows.map((row) => (
          <tr>
            <th scope="row">
              <a href={row.href}>{row.title}</a>
            </th>
            <td>{row.readerJob}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="manifest-summary-title">
    <div class="track-page-heading">
      <p class="eyebrow">Manifest status</p>
      <h2 id="manifest-summary-title">Manifests identify files and status; they do not prove claims.</h2>
      <p>
        Asset and source manifests are useful audit surfaces because they keep
        public file status, hashes, and source references visible.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Status</th>
          <th scope="col">Count</th>
          <th scope="col">Meaning</th>
        </tr>
      </thead>
      <tbody>
        {manifestRows.map((row) => (
          <tr>
            <th scope="row">{row.status}</th>
            <td>{row.count}</td>
            <td>{row.meaning}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="resource-boundaries-title">
    <div class="track-page-heading">
      <p class="eyebrow">Boundaries</p>
      <h2 id="resource-boundaries-title">Resource surfaces preserve status labels.</h2>
      <p>
        A resource page can make the project easier to inspect. It cannot
        promote a source, prove a claim, or override a registry.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Surface</th>
          <th scope="col">Safe use</th>
          <th scope="col">Limit</th>
        </tr>
      </thead>
      <tbody>
        {boundaryRows.map((row) => (
          <tr>
            <th scope="row">{row.surface}</th>
            <td>{row.safeUse}</td>
            <td>{row.limit}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
