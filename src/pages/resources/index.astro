---
import ComprehensionBlocks from "../../components/ComprehensionBlocks.astro";
import DownloadList from "../../components/DownloadList.astro";
import EvidenceRail from "../../components/EvidenceRail.astro";
import StatusDossier from "../../components/StatusDossier.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resourcesIndexComprehension } from "../../lib/supportComprehensionContent";
import {
  approvedDownloads,
  downloadStatusCounts,
  downloads,
  ontologyDocuments,
  sampleDownloads,
} from "../../lib/manifests";
import { resourceGroups } from "../../lib/siteContent";

const sampleCount = sampleDownloads.length;
const approvedCount = approvedDownloads.length;
const manifestStatusSummary = Object.entries(downloadStatusCounts)
  .map(([status, count]) => `${status}: ${count}`)
  .join(", ");

const assetStatusDossier = [
  {
    label: "Current files",
    title: manifestStatusSummary,
    body: "These counts come from source_manifest.json approval statuses and the asset manifest cross-reference.",
  },
  {
    label: "Sample fixtures",
    title: "Path and rendering checks",
    body: "Remaining sample assets are visual fixtures only; sample PDF and TeX files are no longer part of the public manifest.",
  },
  {
    label: "Ontology package",
    title: "Approved downloads active",
    body: "Registered TeX files carry source authority; PDFs are generated human-readable derivatives for direct reading.",
  },
];
---

<BaseLayout
  title="Resources"
  description="Manifest-backed downloadable resources for The AEther Flow website."
  bodyClass="project-overview-page project-support-page"
>
  <section class="content-band project-support-hero" aria-labelledby="resources-title">
    <div class="project-support-copy">
      <div class="section-header">
        <p class="eyebrow">Source-index-only</p>
        <h1 id="resources-title">Resources</h1>
        <p class="lead">
          This resource area supports the public reading path while keeping file
          status explicit. Canonical ontology PDF and TeX assets are committed
          to the website repo with manifest hashes; remaining sample assets are
          clearly labeled as fixtures.
        </p>
      </div>
    </div>

    <figure class="support-figure resource-constellation resources-manifest-figure" aria-labelledby="resources-figure-caption">
      <svg
        class="support-svg resources-manifest-svg"
        viewBox="0 0 520 340"
        role="img"
        aria-labelledby="resources-figure-title resources-figure-desc"
      >
        <title id="resources-figure-title">Animated resource manifest constellation</title>
        <desc id="resources-figure-desc">
          Source manifest, asset manifest, approved PDF and TeX document nodes,
          hash rings, and fixture separation are shown as connected publication
          layers.
        </desc>
        <defs>
          <radialGradient id="resources-glow" cx="50%" cy="48%" r="70%">
            <stop offset="0%" stop-color="var(--owl-orange-100)" stop-opacity="0.7" />
            <stop offset="34%" stop-color="var(--owl-orange-500)" stop-opacity="0.24" />
            <stop offset="76%" stop-color="var(--color-dark-page)" stop-opacity="0.16" />
            <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="resources-rail" x1="8%" x2="92%" y1="50%" y2="50%">
            <stop offset="0%" stop-color="var(--owl-orange-500)" stop-opacity="0" />
            <stop offset="28%" stop-color="var(--owl-orange-500)" stop-opacity="0.86" />
            <stop offset="64%" stop-color="var(--owl-orange-100)" stop-opacity="0.76" />
            <stop offset="100%" stop-color="var(--owl-cyan-400)" stop-opacity="0" />
          </linearGradient>
          <filter id="resources-bloom" x="-20%" y="-24%" width="140%" height="148%">
            <feGaussianBlur stdDeviation="4.2" result="resourcesBlur" />
            <feMerge>
              <feMergeNode in="resourcesBlur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
        <path class="support-bg" d="M0 0H520V340H0Z" />
        <circle class="resources-glow" cx="260" cy="170" r="160" aria-hidden="true" />
        <g class="support-dust" aria-hidden="true">
          <circle cx="54" cy="62" r="1.2" />
          <circle cx="94" cy="264" r="1" />
          <circle cx="168" cy="86" r="0.9" />
          <circle cx="238" cy="286" r="1.2" />
          <circle cx="314" cy="72" r="1" />
          <circle cx="406" cy="266" r="1.1" />
          <circle cx="470" cy="110" r="0.9" />
        </g>
        <g class="resources-manifest-stream" aria-hidden="true">
          <circle cx="110" cy="97" r="23" />
          <circle cx="110" cy="167" r="23" />
          <circle cx="110" cy="237" r="23" />
          <path d="M110 120 C96 140, 96 154, 110 167 C124 180, 124 200, 110 214" />
        </g>
        <g class="resources-approved-rings" aria-hidden="true">
          <circle cx="422" cy="110" r="34" />
          <circle cx="422" cy="230" r="34" />
          <ellipse cx="422" cy="110" rx="54" ry="20" />
          <ellipse cx="422" cy="230" rx="54" ry="20" />
        </g>
        <g class="resources-fixture-orbit" aria-hidden="true">
          <path d="M190 280 C226 300, 294 300, 330 280" />
          <circle cx="260" cy="280" r="13" />
        </g>
        <g class="support-link-lines" filter="url(#resources-bloom)" aria-hidden="true">
          <path class="support-line orange-line resources-flow-path primary" d="M133 97 C186 96, 218 130, 260 170 C308 216, 348 116, 388 110" />
          <path class="support-line signal-line resources-flow-path" d="M133 167 C190 168, 224 168, 260 170 C306 172, 348 224, 388 230" />
          <path class="support-line orange-line alternate resources-flow-path" d="M133 237 C190 222, 226 194, 260 170 C310 134, 348 116, 388 110" />
          <path class="support-line signal-line alternate resources-flow-path" d="M260 170 C258 212, 258 238, 260 280" />
        </g>
        <circle class="support-core" cx="260" cy="170" r="34" aria-hidden="true" />
        <g class="support-nodes" aria-hidden="true">
          <circle cx="133" cy="97" r="8" />
          <circle cx="133" cy="167" r="8" />
          <circle cx="133" cy="237" r="8" />
          <circle cx="260" cy="170" r="10" />
          <circle cx="388" cy="110" r="8" />
          <circle cx="388" cy="230" r="8" />
          <circle cx="260" cy="280" r="8" />
        </g>
        <g class="support-rings" aria-hidden="true">
          <circle cx="260" cy="170" r="58" />
          <circle cx="260" cy="170" r="92" />
          <circle cx="260" cy="170" r="126" />
        </g>
      </svg>
      <figcaption id="resources-figure-caption">
        Manifest-backed resources stay indexed and status-labeled before public use.
      </figcaption>
    </figure>
  </section>

  <ComprehensionBlocks content={resourcesIndexComprehension} />

  <section class="content-band content-band-tight" aria-labelledby="resource-groups-title">
    <div class="section-header">
      <p class="eyebrow">Reader path</p>
      <h2 id="resource-groups-title">Public pages and ontology documents</h2>
      <p class="lead">
        Use the project pages for source-boundary-safe explanation. Use the
        resource libraries to inspect current manifest-backed assets.
      </p>
    </div>
    <EvidenceRail
      items={resourceGroups.map((group) => ({
        ...group,
        actionLabel: "Open resource",
      }))}
      ariaLabel="Resource reader paths"
      className="link-grid resource-path-rail"
      ordered
    />
  </section>

  <section class="content-band content-band-tight" aria-labelledby="asset-status-title">
    <div class="section-header">
      <p class="eyebrow">Manifest audit</p>
      <h2 id="asset-status-title">Current downloadable asset status</h2>
      <p class="lead">
        The current manifest records {sampleCount} sample fixture files and{" "}
        {approvedCount} approved source-backed public files. Source-backed
        ontology downloads are grouped into {ontologyDocuments.length} PDF/TeX
        document pairs.
      </p>
    </div>
    <StatusDossier
      items={assetStatusDossier}
      ariaLabel="Downloadable asset status dossier"
      className="resource-status-grid resource-status-dossier"
    />
  </section>

  <section class="content-band content-band-tight">
    <DownloadList
      items={downloads}
      title="Current manifest-backed files"
      description="This list is generated from asset manifest entries. Status labels distinguish approved ontology assets from remaining visual fixtures."
    />
  </section>
</BaseLayout>
