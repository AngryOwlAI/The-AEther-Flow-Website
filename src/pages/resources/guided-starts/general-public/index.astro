---
import EvidenceRail from "../../../../components/EvidenceRail.astro";
import StatusDossier from "../../../../components/StatusDossier.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";

const pathSummary = [
  {
    label: "Audience",
    title: "General public",
    body: "No physics, mathematics, AI, or software background is assumed.",
  },
  {
    label: "Purpose",
    title: "Reading order",
    body: "The page assembles existing sourced routes into a short first path.",
  },
  {
    label: "Boundary",
    title: "No new claims",
    body: "The guided start cannot update source state or promote scientific results.",
  },
  {
    label: "Provenance",
    title: "Inspect when needed",
    body: "Use source links after the internal explanation makes the question clear.",
  },
];

const whatIsThis = [
  {
    title: "Home",
    href: "/",
    body: "Start here for the two-track frame: speculative physics research and the governed AI research-agent workflow.",
  },
  {
    title: "Physics Research",
    href: "/physics/",
    body: "Use this track landing to see ontology, benchmarks, derivation burden, current state, and claim-control pages.",
  },
  {
    title: "AI Research-Agent System",
    href: "/ai-research-system/",
    body: "Use this track landing to understand bounded AgentJobs, roles, validators, memory, and workflow governance.",
  },
  {
    title: "Source authority",
    href: "/resources/source-authority/",
    body: "Read this before treating any page, diagram, validator, generated explainer, or download as authoritative.",
  },
];

const currentClaims = [
  {
    title: "Current physics state",
    href: "/physics/claim-status/",
    body: "Read the checked-in snapshot of active task, latest handoff, open burden, blocked claims, and next action.",
  },
  {
    title: "Distance-to-GR dashboard",
    href: "/physics/open-burdens/",
    body: "Inspect the burden ledger as rows and blocked downstream decisions, not as a progress score.",
  },
  {
    title: "Gate Chair and human gates",
    href: "/ai-research-system/human-gated-promotion/",
    body: "Understand why readiness, validators, handoffs, and boundary rows do not equal protected verdicts.",
  },
  {
    title: "Claim Boundary Explorer",
    href: "/physics/claim-status/",
    body: "Compare allowed, forbidden, and gate-required wording from a source-pinned registry snapshot.",
  },
];

const doNotInfer = [
  {
    title: "Claim gates",
    href: "/physics/claim-status/",
    body: "Use this page to separate proposals, audits, stress tests, obstructions, freezes, and gates from adoption.",
  },
  {
    title: "Source extension pipeline",
    href: "/physics/derivation-roadmap/",
    body: "Read how proposal-only and draft/control work can be useful without becoming adopted physics.",
  },
  {
    title: "Exact-GR benchmark boundary",
    href: "/physics/exact-gr-benchmark/",
    body: "Distinguish benchmark compatibility from a first-principles derivation and benchmark promotion.",
  },
  {
    title: "GR derivation roadmap",
    href: "/physics/derivation-roadmap/",
    body: "See the open burden structure without reading the roadmap as proof of completed derivation.",
  },
];

const provenancePath = [
  {
    title: "Ontology documents",
    href: "/resources/documents/",
    body: "Inspect registered TeX sources and generated PDF derivatives after reading the public orientation pages.",
  },
  {
    title: "Diagram gallery",
    href: "/resources/diagrams/",
    body: "Review diagram assets as visual aids with explicit source and non-authority captions.",
  },
  {
    title: "Resources index",
    href: "/resources/",
    body: "Return to manifest-backed resources and route groups.",
  },
];
---

<BaseLayout
  title="General-Public Guided Start"
  description="A general-public guided start that assembles existing AEther Flow pages into a source-bound first reading path."
  bodyClass="project-overview-page project-support-page"
>
  <section class="content-band project-support-hero" aria-labelledby="guided-start-title">
    <div class="project-support-copy">
      <div class="section-header">
        <p class="eyebrow">Guided start / general public</p>
        <h1 id="guided-start-title">General-Public Guided Start</h1>
        <p class="lead">
          Use this as the first path through the site. It answers three
          questions in order: what is this project, what is currently claimed,
          and what should I not infer?
        </p>
      </div>
      <div class="overview-actions" aria-label="General-public guided start actions">
        <a class="primary-link" href="#what-is-this">Start reading</a>
        <a class="secondary-link" href="/physics/claim-status/">Current state</a>
      </div>
    </div>

    <figure class="support-figure" aria-labelledby="guided-start-figure-caption">
      <svg viewBox="0 0 520 340" role="img" aria-labelledby="guided-start-figure-title guided-start-figure-desc">
        <title id="guided-start-figure-title">Animated general-public guided-start map</title>
        <desc id="guided-start-figure-desc">
          A reader path moves from orientation to current state, source
          authority, claim boundaries, and provenance while overreads stay
          blocked.
        </desc>
        <defs>
          <radialGradient id="guided-start-glow" cx="50%" cy="48%" r="70%">
            <stop offset="0%" stop-color="var(--owl-orange-100)" stop-opacity="0.72" />
            <stop offset="36%" stop-color="var(--owl-orange-500)" stop-opacity="0.26" />
            <stop offset="78%" stop-color="var(--owl-cyan-400)" stop-opacity="0.12" />
            <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
          </radialGradient>
        </defs>
        <path class="support-bg" d="M0 0H520V340H0Z" />
        <circle class="resources-glow" cx="260" cy="170" r="162" fill="url(#guided-start-glow)" aria-hidden="true" />
        <g class="support-rings" aria-hidden="true">
          <circle cx="260" cy="170" r="58" />
          <circle cx="260" cy="170" r="96" />
          <circle cx="260" cy="170" r="132" />
        </g>
        <g class="support-link-lines" aria-hidden="true">
          <path class="support-line orange-line" d="M94 170 C150 104, 214 104, 260 170 C310 240, 376 238, 432 170" />
          <path class="support-line signal-line" d="M94 112 C164 160, 216 210, 260 170 C308 128, 364 128, 432 112" />
          <path class="support-line signal-line alternate" d="M94 228 C164 184, 216 132, 260 170 C310 214, 364 214, 432 228" />
        </g>
        <circle class="support-core" cx="260" cy="170" r="34" aria-hidden="true" />
        <g class="support-nodes hollow-nodes" aria-hidden="true">
          <circle cx="94" cy="112" r="13" />
          <circle cx="94" cy="170" r="13" />
          <circle cx="94" cy="228" r="13" />
          <circle cx="432" cy="112" r="13" />
          <circle cx="432" cy="170" r="13" />
          <circle cx="432" cy="228" r="13" />
        </g>
      </svg>
      <figcaption id="guided-start-figure-caption">
        Visual orientation only: a reading path can organize pages without
        adding source authority.
      </figcaption>
    </figure>
  </section>

  <section class="content-band content-band-tight" aria-labelledby="guided-summary-title">
    <div class="section-header">
      <p class="eyebrow">How to use this page</p>
      <h2 id="guided-summary-title">Read the website in question order, not proof order.</h2>
      <p class="lead">
        The guide starts with plain orientation, then current state, then
        forbidden inferences. Provenance is available when you need to inspect
        the source basis behind a page.
      </p>
    </div>
    <StatusDossier
      items={pathSummary}
      ariaLabel="General-public guided start summary"
      className="resource-status-grid resource-status-dossier"
    />
  </section>

  <section id="what-is-this" class="content-band content-band-tight" aria-labelledby="what-is-this-title">
    <div class="section-header">
      <p class="eyebrow">Question 1</p>
      <h2 id="what-is-this-title">What is this?</h2>
      <p class="lead">
        Begin with orientation pages. They explain the project shape before
        asking you to inspect detailed source records.
      </p>
    </div>
    <EvidenceRail
      items={whatIsThis}
      ariaLabel="What is this guided start routes"
      className="link-grid resource-path-rail"
      ordered
    />
  </section>

  <section class="content-band content-band-tight" aria-labelledby="current-claims-title">
    <div class="section-header">
      <p class="eyebrow">Question 2</p>
      <h2 id="current-claims-title">What is currently claimed?</h2>
      <p class="lead">
        Use source-state pages next. They preserve the difference between
        current evidence, current blocks, and protected decisions that have not
        happened.
      </p>
    </div>
    <EvidenceRail
      items={currentClaims}
      ariaLabel="Currently claimed guided start routes"
      className="link-grid resource-path-rail"
      ordered
    />
  </section>

  <section class="content-band content-band-tight" aria-labelledby="do-not-infer-title">
    <div class="section-header">
      <p class="eyebrow">Question 3</p>
      <h2 id="do-not-infer-title">What should I not infer?</h2>
      <p class="lead">
        Read these pages when a phrase sounds stronger than the source record:
        derivation, adoption, proof, promotion, benchmark, or completed result.
      </p>
    </div>
    <EvidenceRail
      items={doNotInfer}
      ariaLabel="Do not infer guided start routes"
      className="link-grid resource-path-rail"
      ordered
    />
  </section>

  <section class="content-band content-band-tight" aria-labelledby="diagram-title">
    <div class="section-header">
      <p class="eyebrow">Public comprehension diagram</p>
      <h2 id="diagram-title">The guide assembles pages; it does not update source state.</h2>
      <p class="lead">
        The static diagram shows the reader path moving through existing pages
        and then to provenance when source inspection is needed.
      </p>
    </div>
    <figure class="content-figure comprehension-figure" aria-labelledby="diagram-caption">
      <img
        src="/assets/diagrams/comprehension/general-public-guided-start.png"
        alt="Diagram showing a general-public reader moving through Home, current state, source authority, claim boundaries, and provenance without creating new claims."
        loading="lazy"
      />
      <figcaption id="diagram-caption">
        Static comprehension diagram: the guided start assembles existing
        internal pages and preserves source authority.
      </figcaption>
    </figure>
  </section>

  <section class="content-band content-band-tight" aria-labelledby="provenance-title">
    <div class="section-header">
      <p class="eyebrow">When to inspect provenance</p>
      <h2 id="provenance-title">Use source links after the public path makes the question clear.</h2>
      <p class="lead">
        Provenance is important, but it is easier to inspect after you know
        which claim, boundary, or artifact you are checking.
      </p>
    </div>
    <EvidenceRail
      items={provenancePath}
      ariaLabel="General-public provenance routes"
      className="link-grid resource-path-rail"
    />
  </section>
</BaseLayout>
