---
import CommandBand from "../../../components/CommandBand.astro";
import EvidenceRail from "../../../components/EvidenceRail.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ComprehensionBlocks from "../../../components/ComprehensionBlocks.astro";
import { greenfieldRouteDiagramBlocks } from "../../../lib/siteContent";

const audienceRows = [
  {
    reader: "General reader",
    first: "/",
    path: "Home, Resources, Guided Starts, then the topic route that answers the question.",
    reason: "The project frame and claim boundaries appear before technical detail.",
  },
  {
    reader: "Physics reviewer",
    first: "/physics/",
    path: "Physics Research, Ontology, Exact-GR Benchmark, Derivation Roadmap, Claim Status, Open Burdens.",
    reason: "Claim state, benchmark status, and open derivation burdens stay visible.",
  },
  {
    reader: "AI workflow reviewer",
    first: "/ai-research-system/",
    path: "AI Research System, Workflow, AgentJob Lifecycle, Roles and Schemas, Validators and Handoffs.",
    reason: "Operational authority is read through bounded records instead of inferred from automation.",
  },
  {
    reader: "Contributor",
    first: "/resources/source-authority/",
    path: "Source Authority, Repository Map, Site Builder Guide, Publication Process, then the relevant page family.",
    reason: "The edit boundary and source bundle precede implementation or copy changes.",
  },
  {
    reader: "Site builder",
    first: "/resources/site-builder-guide/",
    path: "Site Builder Guide, Repository Map, Publication Process, Library, then the target route family.",
    reason: "A source-bundle-first path prevents building from derivative seed material alone.",
  },
  {
    reader: "Asset reviewer",
    first: "/resources/",
    path: "Resources, Generated Derivatives, Documents, Diagram Gallery, then manifest or provenance records.",
    reason: "Assets are read with status labels before hashes or source links dominate.",
  },
];

const questionRows = [
  {
    question: "What is the project?",
    route: "Home and Resources",
    href: "/",
    boundary: "The site explains the dual physics and AI workflow mission without claiming a completed GR derivation.",
  },
  {
    question: "What claims are currently allowed?",
    route: "Physics Claim Status",
    href: "/physics/claim-status/",
    boundary: "Claim status pages explain tracked states; they do not promote blocked or open claims.",
  },
  {
    question: "How does the AI system control work?",
    route: "AI Workflow",
    href: "/ai-research-system/workflow/",
    boundary: "Workflow pages describe bounded AgentJobs and evidence receipts, not proof of physics.",
  },
  {
    question: "Where should I inspect source and derivatives?",
    route: "Source Authority and Registries",
    href: "/resources/source-authority/",
    boundary: "Authority classes and registry rows guide inspection but remain below upstream source and governed records.",
  },
  {
    question: "How should a page be built?",
    route: "Site Builder Guide",
    href: "/resources/site-builder-guide/",
    boundary: "Source bundles are implementation orientation, not unrestricted write permission.",
  },
];

const routeClusters = [
  {
    label: "Start",
    title: "Home",
    href: "/",
    body: "Begin with the subject-level frame before route families or source records.",
  },
  {
    label: "Physics",
    title: "Physics Research",
    href: "/physics/",
    body: "Follow claim status, source ontology, benchmark, roadmap, and open-burden routes.",
  },
  {
    label: "AI workflow",
    title: "AI Research System",
    href: "/ai-research-system/",
    body: "Read governed workflow, roles, memory, runtime, validators, and handoffs.",
  },
  {
    label: "Resources",
    title: "Resources",
    href: "/resources/",
    body: "Use manifests, library routes, derivatives, retrieval, documents, and diagrams with status labels.",
  },
  {
    label: "Builder",
    title: "Site Builder Guide",
    href: "/resources/site-builder-guide/",
    body: "Map page families to source bundles before implementation starts.",
  },
  {
    label: "Topology",
    title: "Repository Map",
    href: "/resources/repository-map/",
    body: "Separate source, control, generated, local, tooling, archival, and reserved lanes.",
  },
];

const policyRows = [
  {
    rule: "Internal route first",
    meaning: "When a website route exists, it is the primary reader path.",
    failureMode: "A GitHub link or file path becomes a substitute for explanation.",
  },
  {
    rule: "Status before provenance",
    meaning: "The route should identify source, derivative, retrieval, snapshot, or planning status before source links.",
    failureMode: "A reader sees a polished surface and silently upgrades its authority.",
  },
  {
    rule: "Audience before repository",
    meaning: "Choose the path by reader job, then expose files and manifests as audit tools.",
    failureMode: "Repository archaeology appears before the reader understands the subject.",
  },
  {
    rule: "Freshness where current state appears",
    meaning: "Current-state paths must identify source precedence and refresh expectations.",
    failureMode: "A dated snapshot is read as current fact.",
  },
];

const provenanceRows = [
  {
    reference: "The AEther Flow Website. (2026a). High-Level Components [Product requirements document: PRD-01].",
    use: "Defines internal-first reader paths for general readers, physicists, AI researchers, contributors, and site builders.",
  },
  {
    reference: "The AEther Flow Website. (2026b). Documentation, Publication, and Website Components [Product requirements document: PRD-06].",
    use: "Defines reading-path pages, publication surfaces, and library organization by reader job.",
  },
  {
    reference: "The AEther Flow Website. (2026c). Quick Source Map for Site Builders [Product requirements document: PRD-11].",
    use: "Defines source-bundle-first paths for future route implementation.",
  },
  {
    reference: "The AEther Flow Website. (2026d). Sitewide Greenfield Rebuild Implementation Plan [Implementation plan].",
    use: "Defines the new short route inventory and GF-012 acceptance criteria.",
  },
];

const readingPathsSvg = `
  <svg class="track-map-svg physics-greenfield-svg" viewBox="0 0 620 360" role="img" aria-labelledby="resources-reading-title resources-reading-desc">
    <title id="resources-reading-title">Animated internal reading path map</title>
    <desc id="resources-reading-desc">Audience paths move from Home through route families, Resources, and source inspection without replacing source authority.</desc>
    <defs>
      <radialGradient id="resources-reading-core" cx="50%" cy="50%" r="66%">
        <stop offset="0%" stop-color="var(--owl-cyan-400)" stop-opacity="0.56" />
        <stop offset="45%" stop-color="var(--owl-orange-100)" stop-opacity="0.26" />
        <stop offset="100%" stop-color="var(--color-dark-page)" stop-opacity="0" />
      </radialGradient>
      <filter id="resources-reading-bloom" x="-20%" y="-24%" width="140%" height="148%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <path class="track-figure-bg" d="M0 0H620V360H0Z" />
    <circle class="physics-glow" cx="310" cy="180" r="184" fill="url(#resources-reading-core)" />
    <g class="physics-grid" aria-hidden="true">
      <ellipse cx="310" cy="180" rx="238" ry="114" />
      <ellipse cx="310" cy="180" rx="154" ry="72" />
      <path d="M88 180 H532" />
      <path d="M310 76 V284" />
    </g>
    <g filter="url(#resources-reading-bloom)" aria-hidden="true">
      <path class="track-figure-path signal-path" d="M92 108 C174 142, 230 180, 310 180 C390 180, 446 142, 528 108" />
      <path class="track-figure-path orange-path" d="M92 252 C174 218, 230 180, 310 180 C390 180, 446 218, 528 252" />
      <path class="track-figure-path signal-path alternate" d="M152 180 C218 104, 402 104, 468 180" />
      <path class="track-figure-path orange-path alternate" d="M152 180 C218 256, 402 256, 468 180" />
    </g>
    <circle class="track-figure-core" cx="310" cy="180" r="42" aria-hidden="true" />
    <g class="track-figure-nodes hollow-nodes" aria-hidden="true">
      <circle cx="92" cy="108" r="13" />
      <circle cx="92" cy="252" r="13" />
      <circle cx="152" cy="180" r="13" />
      <circle cx="310" cy="180" r="13" />
      <circle cx="468" cy="180" r="13" />
      <circle cx="528" cy="108" r="13" />
      <circle cx="528" cy="252" r="13" />
    </g>
  </svg>
`;
---

<BaseLayout
  title="Reading Paths"
  description="Resources reading paths route for The AEther Flow Website, organizing internal-first paths by reader job, question, source status, and route family."
  bodyClass="project-overview-page project-track-page resources-greenfield-page ai-greenfield-page"
>
  <CommandBand
    className="overview-shell overview-command-hero"
    eyebrow="Resources / Reading Paths"
    title="Reading Paths"
    lead="Reading paths choose the internal route sequence before source links, manifests, or repository files appear. They organize comprehension; they do not create authority."
    headingLevel="h1"
  >
    <div class="overview-actions" aria-label="Reading paths page actions">
      <a class="primary-link" href="#audience-paths">Choose by audience</a>
      <a class="secondary-link" href="/resources/site-builder-guide/">Builder guide</a>
      <a class="secondary-link" href="/resources/">Resources</a>
    </div>
    <Fragment slot="visual">
      <figure class="track-page-figure physics-figure" aria-labelledby="resources-reading-caption">
        <Fragment set:html={readingPathsSvg} />
        <figcaption id="resources-reading-caption">
          Fact: reading paths help different audiences choose internal pages
          before provenance or source inspection.
        </figcaption>
      </figure>
    </Fragment>
  </CommandBand>

  <section class="greenfield-intro-panel" aria-label="Reading paths introduction">
    <p>
      The logical path is question first, route second, provenance third.
      Internal explanations help readers understand what they are auditing
      before they inspect source files, registries, manifests, or generated
      derivatives.
    </p>
  </section>


  <ComprehensionBlocks content={greenfieldRouteDiagramBlocks.resourcesReadingPaths} />

  <section id="audience-paths" class="track-page-band" aria-labelledby="audience-paths-title">
    <div class="track-page-heading">
      <p class="eyebrow">Audience paths</p>
      <h2 id="audience-paths-title">Start with the reader job, not the repository tree.</h2>
      <p>
        Each path starts at a short website route and keeps claim boundaries
        visible before source or provenance inspection.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Reader</th>
          <th scope="col">First route</th>
          <th scope="col">Recommended path</th>
          <th scope="col">Reason</th>
        </tr>
      </thead>
      <tbody>
        {audienceRows.map((row) => (
          <tr>
            <th scope="row">{row.reader}</th>
            <td><a href={row.first}>{row.first}</a></td>
            <td>{row.path}</td>
            <td>{row.reason}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="question-router-title">
    <div class="track-page-heading">
      <p class="eyebrow">Question router</p>
      <h2 id="question-router-title">Use the question to select the route.</h2>
      <p>
        The route choice is a reading convenience. It does not decide source
        status, claim status, or implementation permission.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Question</th>
          <th scope="col">Route</th>
          <th scope="col">Boundary</th>
        </tr>
      </thead>
      <tbody>
        {questionRows.map((row) => (
          <tr>
            <th scope="row">{row.question}</th>
            <td><a href={row.href}>{row.route}</a></td>
            <td>{row.boundary}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <CommandBand
    className="overview-panel overview-command-band"
    eyebrow="Route clusters"
    title="Short routes are the public reading surface."
    lead="Use internal pages for orientation and source/provenance links for audit after the route has explained the subject."
  >
    <EvidenceRail
      items={routeClusters.map((route) => ({
        ...route,
        actionLabel: "Open route",
      }))}
      ariaLabel="Reading path route clusters"
      className="overview-track-rail"
    />
  </CommandBand>

  <section class="track-page-band" aria-labelledby="reading-policy-title">
    <div class="track-page-heading">
      <p class="eyebrow">Policy</p>
      <h2 id="reading-policy-title">Reading paths keep comprehension ahead of file inspection.</h2>
      <p>
        A path is safe when it lowers cognitive load without hiding source,
        derivative, retrieval, or freshness status.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Rule</th>
          <th scope="col">Meaning</th>
          <th scope="col">Failure mode</th>
        </tr>
      </thead>
      <tbody>
        {policyRows.map((row) => (
          <tr>
            <th scope="row">{row.rule}</th>
            <td>{row.meaning}</td>
            <td>{row.failureMode}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="track-page-band" aria-labelledby="reading-provenance-title">
    <div class="track-page-heading">
      <p class="eyebrow">Provenance and limits</p>
      <h2 id="reading-provenance-title">This route orders reading; it does not create source truth.</h2>
      <p>
        The references below are cited in APA 7 style as implementation basis.
        They support the reading-path route while upstream source records,
        registries, and governed control files remain authoritative for claims.
      </p>
    </div>
    <table class="greenfield-matrix">
      <thead>
        <tr>
          <th scope="col">Reference</th>
          <th scope="col">Used here for</th>
        </tr>
      </thead>
      <tbody>
        {provenanceRows.map((row) => (
          <tr>
            <th scope="row">{row.reference}</th>
            <td>{row.use}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
