---
import { siteNavigationLinks } from "../lib/siteContent";
import "../styles/global.css";
import "../styles/math.css";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  exactTitle?: boolean;
}

const siteName = "The AEther Flow";
const brandName = "AngryOwl";
const brandLogoPath = "/assets/brand/main_angryowl_round.png";
const {
  title = siteName,
  description = "Reader-facing website for The AEther Flow research project.",
  bodyClass = "",
  exactTitle = false,
} = Astro.props;
const pageTitle = exactTitle || title === siteName ? title : `${title} | ${siteName}`;
const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const isExactNavPath = (href: string) => currentPath === href;

const isActiveNavLink = (link: (typeof siteNavigationLinks)[number]) => {
  const childHrefs = link.children?.map((child) => child.href) ?? [];
  return (
    currentPath === link.href ||
    childHrefs.includes(currentPath) ||
    (link.matchPrefixes ?? []).some((prefix) => currentPath.startsWith(prefix))
  );
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href={brandLogoPath} />
    <link rel="apple-touch-icon" href={brandLogoPath} />
    <title>{pageTitle}</title>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation" data-site-navigation>
        <a class="brand" href="/" aria-label={`${brandName} home`}>
          <img
            class="brand-mark"
            src={brandLogoPath}
            alt=""
            width="40"
            height="40"
            decoding="async"
            aria-hidden="true"
          />
          <span>{brandName}</span>
        </a>
        <button
          class="nav-menu-trigger mobile-nav-trigger"
          type="button"
          aria-expanded="false"
          aria-controls="primary-navigation-links"
          data-mobile-nav-trigger
          hidden
        >
          <span>Menu</span>
          <span class="nav-menu-caret" aria-hidden="true"></span>
        </button>
        <div class="nav-links" id="primary-navigation-links" data-primary-navigation>
          {siteNavigationLinks.map((link, index) => {
            const children = link.children ?? [];
            const isActive = isActiveNavLink(link);
            const menuId = `primary-nav-menu-${index}`;
            if (children.length > 0) {
              return (
                <div class="nav-menu" data-nav-menu>
                  <button
                    class="nav-menu-trigger"
                    type="button"
                    aria-expanded="false"
                    aria-controls={menuId}
                    data-active={isActive ? "true" : undefined}
                    data-nav-menu-trigger
                  >
                    <span>{link.title}</span>
                    <span class="nav-menu-caret" aria-hidden="true"></span>
                  </button>
                  <div class="nav-menu-panel" id={menuId} hidden data-nav-menu-panel>
                    {children.map((child) => (
                      <a
                        class="nav-menu-link"
                        href={child.href}
                        aria-current={isExactNavPath(child.href) ? "page" : undefined}
                      >
                        <span>{child.title}</span>
                        <small>{child.description}</small>
                      </a>
                    ))}
                  </div>
                </div>
              );
            }
            return (
              <a class="nav-link" href={link.href} aria-current={isActive ? "page" : undefined}>
                {link.title}
              </a>
            );
          })}
        </div>
        <noscript>
          <div class="nav-links" data-no-script-navigation>
            {siteNavigationLinks.filter((link) => (link.children?.length ?? 0) > 0).map((link) => (
              <a href={link.href}>{link.title}</a>
            ))}
          </div>
        </noscript>
      </nav>
    </header>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer-inner">
        <section class="footer-block footer-authority" aria-label="Source authority and copyright">
          <p>
            Source authority remains with the research repository. This website is
            a publication and presentation layer for reviewed, reader-facing
            material.
          </p>
          <p class="footer-copyright">
            Copyright &copy; 2026 Angry Owl. Reuse is governed by the project license.
          </p>
        </section>
        <section class="footer-block footer-project" aria-label="Project links">
          <h2>Project</h2>
          <nav class="footer-link-list" aria-label="Footer project links">
            <a
              class="footer-badge-link"
              href="https://github.com/AngryOwlAI/The-AEther-Flow"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub repository for AngryOwlAI/The-AEther-Flow"
            >
              <img
                src="https://img.shields.io/static/v1?label=AngryOwlAI%2F&message=The-AEther-Flow&color=181717&style=for-the-badge&logo=github&logoColor=white"
                alt="AngryOwlAI/The-AEther-Flow"
                width="258"
                height="28"
                loading="lazy"
                decoding="async"
              />
            </a>
            <a href="/license/">License</a>
          </nav>
        </section>
        <section class="footer-block footer-creator" aria-label="Project creator">
          <h2>Project Creator</h2>
          <div class="footer-creator-line">
            <a
              class="footer-creator-avatar"
              href="https://www.alexomegapy.com"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Alexander Ricciardi website"
            >
              <img
                src="https://github.com/user-attachments/assets/a8e0ea66-5d8f-43b3-8fff-2c3d74d57f53"
                alt="Alexander Ricciardi"
                width="30"
                height="30"
                loading="lazy"
                decoding="async"
              />
            </a>
            <strong>Alexander Ricciardi</strong>
          </div>
          <div class="footer-social-links" aria-label="Creator profile links">
            <a
              class="footer-badge-link"
              href="https://github.com/Omegapy"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub profile for Omega.py"
            >
              <img
                src="https://img.shields.io/badge/Omegapy-181717?style=for-the-badge&logo=github&logoColor=white"
                alt="GitHub - Omega.py"
                width="111"
                height="28"
                loading="lazy"
                decoding="async"
              />
            </a>
            <a
              class="footer-badge-link"
              href="https://medium.com/@alex.omegapy"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Medium profile for Alexander Ricciardi"
            >
              <img
                src="https://img.shields.io/badge/Medium-12100E?style=for-the-badge&logo=medium&logoColor=white"
                alt="Medium"
                width="105"
                height="28"
                loading="lazy"
                decoding="async"
              />
            </a>
            <a
              class="footer-badge-link"
              href="https://linkedin.com/in/alex-ricciardi"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn profile for Alexander Ricciardi"
            >
              <img
                src="https://img.shields.io/badge/LinkedIn-0077B5?style=for-the-badge&logo=linkedin&logoColor=white"
                alt="LinkedIn"
                width="119"
                height="28"
                loading="lazy"
                decoding="async"
              />
            </a>
          </div>
        </section>
      </div>
    </footer>
    <script>
      const siteNavigation = document.querySelector("[data-site-navigation]");
      const mobileMenuTrigger = document.querySelector("[data-mobile-nav-trigger]");
      const primaryNavigation = document.querySelector("[data-primary-navigation]");
      const navigationMenus = Array.from(document.querySelectorAll("[data-nav-menu]"));
      const compactNavigationQuery = window.matchMedia(
        "(max-width: 780px), (max-height: 480px) and (max-width: 900px)",
      );

      const getMenuParts = (menu) => {
        const trigger = menu.querySelector("[data-nav-menu-trigger]");
        const panel = menu.querySelector("[data-nav-menu-panel]");
        return { trigger, panel };
      };

      const setMenuExpanded = (menu, expanded, returnFocus = false) => {
        const { trigger, panel } = getMenuParts(menu);
        if (!(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
          return;
        }

        trigger.setAttribute("aria-expanded", String(expanded));
        panel.hidden = !expanded;

        if (!expanded && returnFocus) {
          trigger.focus();
        }
      };

      const closeMenus = (exceptMenu = null) => {
        navigationMenus.forEach((menu) => {
          if (menu !== exceptMenu) {
            setMenuExpanded(menu, false);
          }
        });
      };

      const setMobileMenuExpanded = (expanded, returnFocus = false) => {
        if (
          !(mobileMenuTrigger instanceof HTMLButtonElement) ||
          !(primaryNavigation instanceof HTMLElement)
        ) {
          return;
        }

        const isCompact = compactNavigationQuery.matches;
        const nextExpanded = isCompact && expanded;
        mobileMenuTrigger.setAttribute("aria-expanded", String(nextExpanded));
        primaryNavigation.hidden = isCompact && !nextExpanded;

        if (!nextExpanded) {
          closeMenus();
        }

        if (!nextExpanded && returnFocus) {
          mobileMenuTrigger.focus();
        }
      };

      const syncCompactNavigation = () => {
        if (
          !(siteNavigation instanceof HTMLElement) ||
          !(mobileMenuTrigger instanceof HTMLButtonElement) ||
          !(primaryNavigation instanceof HTMLElement)
        ) {
          return;
        }

        const activeElementWasInside = primaryNavigation.contains(document.activeElement);
        const isCompact = compactNavigationQuery.matches;
        siteNavigation.dataset.compact = String(isCompact);
        mobileMenuTrigger.hidden = !isCompact;
        setMobileMenuExpanded(false, isCompact && activeElementWasInside);

        if (!isCompact) {
          primaryNavigation.hidden = false;
        }
      };

      if (mobileMenuTrigger instanceof HTMLButtonElement) {
        mobileMenuTrigger.addEventListener("click", () => {
          const isExpanded = mobileMenuTrigger.getAttribute("aria-expanded") === "true";
          setMobileMenuExpanded(!isExpanded, isExpanded);
        });
      }

      navigationMenus.forEach((menu) => {
        const { trigger } = getMenuParts(menu);
        if (!(trigger instanceof HTMLButtonElement)) {
          return;
        }

        trigger.addEventListener("click", () => {
          const isExpanded = trigger.getAttribute("aria-expanded") === "true";
          closeMenus(menu);
          setMenuExpanded(menu, !isExpanded);
        });
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Node)) {
          return;
        }

        if (siteNavigation instanceof HTMLElement && !siteNavigation.contains(target)) {
          closeMenus();
          setMobileMenuExpanded(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") {
          return;
        }

        if (
          compactNavigationQuery.matches &&
          mobileMenuTrigger instanceof HTMLButtonElement &&
          mobileMenuTrigger.getAttribute("aria-expanded") === "true"
        ) {
          event.preventDefault();
          setMobileMenuExpanded(false, true);
          return;
        }

        const openMenu = navigationMenus.find((menu) => {
          const { trigger } = getMenuParts(menu);
          return trigger instanceof HTMLButtonElement && trigger.getAttribute("aria-expanded") === "true";
        });

        if (openMenu) {
          event.preventDefault();
          setMenuExpanded(openMenu, false, true);
        }
      });

      if (siteNavigation instanceof HTMLElement) {
        siteNavigation.dataset.navigationEnhanced = "true";
      }
      compactNavigationQuery.addEventListener("change", syncCompactNavigation);
      syncCompactNavigation();
    </script>
  </body>
</html>
