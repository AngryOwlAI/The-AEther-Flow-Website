---
import { siteNavigationLinks } from "../lib/siteContent";
import "../styles/global.css";
import "../styles/math.css";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const siteName = "The AEther Flow";
const brandName = "Angry Owl";
const brandLogoPath = "/assets/brand/main_angryowl_round.png";
const {
  title = siteName,
  description = "Reader-facing website for The AEther Flow research project.",
  bodyClass = "",
} = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const isActiveNavLink = (href: string, matchPrefixes: string[] = []) => {
  return currentPath === href || matchPrefixes.some((prefix) => currentPath.startsWith(prefix));
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href={brandLogoPath} />
    <link rel="apple-touch-icon" href={brandLogoPath} />
    <title>{pageTitle}</title>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="brand" href="/project/overview/" aria-label={`${brandName} home`}>
          <img
            class="brand-mark"
            src={brandLogoPath}
            alt=""
            width="40"
            height="40"
            decoding="async"
            aria-hidden="true"
          />
          <span>{brandName}</span>
        </a>
        <div class="nav-links">
          {siteNavigationLinks.map((link) => {
            const isActive = isActiveNavLink(link.href, link.matchPrefixes);
            return (
              <a href={link.href} aria-current={isActive ? "page" : undefined}>
                {link.title}
              </a>
            );
          })}
        </div>
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        Source authority remains with the research repository. This website is
        a publication and presentation layer for reviewed, reader-facing
        material.
      </p>
    </footer>
  </body>
</html>
