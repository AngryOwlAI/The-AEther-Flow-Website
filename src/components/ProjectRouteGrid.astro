---
import EvidenceRail from "./EvidenceRail.astro";

interface ProjectRouteCard {
  title: string;
  href: string;
  phase: string;
  status: string;
  description: string;
}

interface Props {
  routes: ProjectRouteCard[];
  ariaLabel: string;
}

const { routes, ariaLabel } = Astro.props;

const routeItems = routes.map((route) => ({
  label: `${route.phase} / ${route.status}`,
  title: route.title,
  body: route.description,
  href: route.status === "implemented" ? route.href : undefined,
  actionLabel: route.status === "implemented" ? "Open page" : "Planned page",
}));
---

<EvidenceRail
  items={routeItems}
  ariaLabel={ariaLabel}
  className="planned-route-grid route-evidence-rail"
/>
