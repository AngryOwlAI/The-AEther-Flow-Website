---
export interface EvidenceRailItem {
  label?: string;
  title: string;
  body: string;
  href?: string;
  actionLabel?: string;
  points?: string[];
}

interface Props {
  items: EvidenceRailItem[];
  ariaLabel: string;
  className?: string;
  ordered?: boolean;
}

const { items, ariaLabel, className = "", ordered = false } = Astro.props;
---

<div
  class={`evidence-rail ${ordered ? "evidence-rail-ordered" : ""} ${className}`.trim()}
  aria-label={ariaLabel}
>
  {items.map((item, index) => {
    const label = item.label ?? (ordered ? String(index + 1).padStart(2, "0") : undefined);
    const actionLabel = item.actionLabel ?? "Open route";
    const accessibleActionLabel = `${actionLabel}: ${item.title}`;
    const linkClass = item.href
      ? `evidence-rail-link ${item.href.startsWith("http") ? "evidence-rail-link-external" : ""}`
      : "";

    return (
      <article class={`evidence-rail-item ${linkClass}`.trim()}>
        {label && <p class="evidence-rail-label">{label}</p>}
        <h3>{item.title}</h3>
        <p>{item.body}</p>
        {item.points && item.points.length > 0 && (
          <ul>
            {item.points.map((point) => <li>{point}</li>)}
          </ul>
        )}
        {item.href && (
          <a class="evidence-rail-action" href={item.href} aria-label={accessibleActionLabel}>
            {actionLabel}
          </a>
        )}
      </article>
    );
  })}
</div>

<style>
  .evidence-rail-link:hover,
  .evidence-rail-link:focus-within {
    background:
      linear-gradient(
        160deg,
        color-mix(in srgb, var(--overview-orange) 13%, transparent),
        transparent 44%
      ),
      color-mix(in srgb, var(--color-dark-panel) 76%, transparent);
    transform: translateY(-2px);
  }

  .evidence-rail-link:focus-within {
    outline: 3px solid var(--color-focus-ring);
    outline-offset: 0.2rem;
  }

  .evidence-rail-link-external {
    background:
      linear-gradient(
        160deg,
        color-mix(in srgb, var(--overview-cyan) 9%, transparent),
        transparent 44%
      ),
      color-mix(in srgb, var(--color-dark-panel) 54%, transparent);
  }

  .evidence-rail-action {
    min-height: 2.75rem;
    align-items: center;
  }

  .evidence-rail-action::after {
    position: absolute;
    inset: 0;
    content: "";
  }

  @media (prefers-reduced-motion: reduce) {
    .evidence-rail-link:hover,
    .evidence-rail-link:focus-within {
      transform: none;
    }
  }
</style>
