---
export interface EvidenceRailItem {
  label?: string;
  title: string;
  body: string;
  href?: string;
  actionLabel?: string;
  points?: string[];
}

interface Props {
  items: EvidenceRailItem[];
  ariaLabel: string;
  className?: string;
  ordered?: boolean;
}

const { items, ariaLabel, className = "", ordered = false } = Astro.props;
---

<div
  class={`evidence-rail ${ordered ? "evidence-rail-ordered" : ""} ${className}`.trim()}
  aria-label={ariaLabel}
>
  {items.map((item, index) => {
    const label = item.label ?? (ordered ? String(index + 1).padStart(2, "0") : undefined);
    const content = (
      <>
        {label && <p class="evidence-rail-label">{label}</p>}
        <h3>{item.title}</h3>
        <p>{item.body}</p>
        {item.points && item.points.length > 0 && (
          <ul>
            {item.points.map((point) => <li>{point}</li>)}
          </ul>
        )}
        {item.href && <span class="evidence-rail-action">{item.actionLabel ?? "Open route"}</span>}
      </>
    );

    return item.href ? (
      <a class="evidence-rail-item evidence-rail-link" href={item.href}>
        {content}
      </a>
    ) : (
      <article class="evidence-rail-item">
        {content}
      </article>
    );
  })}
</div>
