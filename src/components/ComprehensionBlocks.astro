---
import Figure from "./Figure.astro";
import type { ComprehensionContent } from "../lib/comprehensionContent";

interface Props {
  content: ComprehensionContent;
  className?: string;
}

const { content, className = "" } = Astro.props;
const diagramFit = content.diagramFit ?? "default";
const diagramFitClass =
  diagramFit === "default" ? "" : `comprehension-diagram-wrap--${diagramFit}`;
const figureFitClass =
  diagramFit === "default" ? "" : `comprehension-figure--${diagramFit}`;
const defaultDiagramNote =
  "The diagram is a static reader aid. It does not replace the source files, route dossiers, or claim-status records that govern the topic.";
const diagramNote =
  content.diagramNote === false ? "" : content.diagramNote ?? defaultDiagramNote;
---

<section
  id={content.id}
  class={`track-page-band comprehension-blocks ${className}`.trim()}
  aria-labelledby={`${content.id}-title`}
>
  <div class="track-page-heading comprehension-heading">
    <p class="eyebrow">{content.eyebrow}</p>
    <h2 id={`${content.id}-title`}>{content.title}</h2>
    <p>{content.summary}</p>
  </div>

  {content.diagram && (
    <div class={`comprehension-diagram-wrap ${diagramFitClass}`.trim()}>
      <Figure
        id={`${content.id}-figure`}
        src={content.diagram.src}
        alt={content.diagram.alt}
        caption={content.diagram.caption}
        className={`comprehension-figure ${figureFitClass}`.trim()}
        loading="eager"
        expandable={content.diagramExpandable}
      />
      {diagramNote && <p class="comprehension-diagram-note">{diagramNote}</p>}
    </div>
  )}
  {content.equations && content.equations.length > 0 && (
    <section class="comprehension-subsection" aria-labelledby={`${content.id}-equations-title`}>
      <div class="track-page-heading">
        <p class="eyebrow">Equation walkthrough</p>
        <h3 id={`${content.id}-equations-title`}>Read formulas with their assumptions and limits.</h3>
      </div>
      <div class="track-status-grid comprehension-equation-grid">
        {content.equations.map((item) => (
          <article class="track-status-card">
            <p>Equation</p>
            <h4>{item.label}</h4>
            <p>{item.expression} Source status: {item.sourceStatus}</p>
          </article>
        ))}
      </div>
    </section>
  )}
</section>
