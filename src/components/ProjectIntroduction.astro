---
interface Props {
  paragraphs: readonly string[];
  ariaLabel?: string;
  className?: string;
}

const {
  paragraphs,
  ariaLabel = "About the Æther Flow Project",
  className = "greenfield-intro-panel",
} = Astro.props;

if (
  !Array.isArray(paragraphs) ||
  paragraphs.length === 0 ||
  paragraphs.some((paragraph) => !paragraph.trim())
) {
  throw new Error(
    "ProjectIntroduction requires a nonempty paragraphs array with no empty items.",
  );
}
---

<section
  class={`project-introduction ${className}`.trim()}
  aria-label={ariaLabel}
  data-project-introduction
>
  {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
</section>
