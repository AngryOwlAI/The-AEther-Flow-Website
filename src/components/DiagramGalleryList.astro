---
interface DiagramGalleryItem {
  title: string;
  src: string;
  alt: string;
  caption: string;
  provenance?: string;
  width: number;
  height: number;
  aspectRatio: string;
}

interface Props {
  items: DiagramGalleryItem[];
  emptyTitle?: string;
  emptyBody?: string;
}

const {
  items,
  emptyTitle = "No diagram inventory is currently published.",
  emptyBody = "Future diagrams need explicit reapproval evidence before they appear in this gallery.",
} = Astro.props;
---

<div class="diagram-gallery-list">
  {items.length === 0 ? (
    <article class="diagram-gallery-item diagram-gallery-empty">
      <div class="diagram-gallery-copy">
        <p class="download-kind">Inventory reset</p>
        <h3>{emptyTitle}</h3>
        <p>{emptyBody}</p>
        <p class="diagram-gallery-boundary">
          Diagram publication requires tracked source, generated static output,
          manifest status, descriptive caption text, and audit provenance in the
          source records.
        </p>
      </div>
    </article>
  ) : (
    items.map((item) => (
      <article class="diagram-gallery-item">
        <div class="diagram-gallery-copy">
          <p class="download-kind">Diagram</p>
          <h3>
            <a href={item.src}>{item.title}</a>
          </h3>
          <p>{item.caption}</p>
          <p class="diagram-gallery-boundary">
            Audit provenance remains available through the manifests and source
            dossiers for inspection.
          </p>
        </div>
        <a
          class="diagram-gallery-image-link"
          href={item.src}
          aria-label={`Open ${item.title}`}
          style={`--diagram-aspect-ratio: ${item.aspectRatio};`}
        >
          <img
            src={item.src}
            alt={item.alt}
            width={item.width}
            height={item.height}
            style={`aspect-ratio: ${item.aspectRatio};`}
            loading="lazy"
            decoding="async"
          />
        </a>
      </article>
    ))
  )}
</div>

<style>
  .diagram-gallery-image-link {
    aspect-ratio: var(--diagram-aspect-ratio);
    max-height: 22rem;
  }

  @media (max-width: 780px) {
    .diagram-gallery-image-link {
      max-height: 18rem;
    }
  }
</style>
