---
export type ProjectStatusSemantic =
  | "complete"
  | "adopted"
  | "interpretive"
  | "open"
  | "not-claimed";

export interface ProjectStatusItem {
  id: string;
  label: string;
  value: string;
  description: string;
  qualification: string;
  semantic: ProjectStatusSemantic;
}

interface Props {
  items: readonly ProjectStatusItem[];
}

const { items } = Astro.props;
const expectedSemantics: readonly ProjectStatusSemantic[] = [
  "complete",
  "adopted",
  "interpretive",
  "open",
  "not-claimed",
];
const semanticDetails: Record<
  ProjectStatusSemantic,
  { marker: string; label: string }
> = {
  complete: { marker: "✓", label: "Complete within the stated scope" },
  adopted: { marker: "=", label: "Used as the observable benchmark" },
  interpretive: { marker: "◎", label: "Proposed interpretation" },
  open: { marker: "○", label: "Not completed" },
  "not-claimed": { marker: "■", label: "Outside the project's current claims" },
};

if (
  items.length !== expectedSemantics.length ||
  items.some((item, index) => item.semantic !== expectedSemantics[index])
) {
  throw new Error(
    "ProjectStatusStrip requires exactly five items in complete, adopted, interpretive, open, and not-claimed order.",
  );
}
---

<section class="project-status-strip" aria-labelledby="project-status-strip-title">
  <div class="project-status-strip-heading">
    <p class="eyebrow">Current project status</p>
    <h2 id="project-status-strip-title">Five states, explained.</h2>
    <p class="project-status-strip-intro">
      Each item distinguishes what the project has completed, adopted, proposed,
      left open, or does not claim.
    </p>
  </div>
  <ol class="project-status-strip-list">
    {items.map((item) => {
      const descriptionId = `project-status-${item.id}-description`;
      const qualificationId = `project-status-${item.id}-qualification`;
      const semantic = semanticDetails[item.semantic];
      return (
        <li
          class="project-status-strip-item"
          data-status-semantic={item.semantic}
        >
          <div class="project-status-row">
            <span class="project-status-marker" aria-hidden="true">{semantic.marker}</span>
            <div class="project-status-copy">
              <div class="project-status-summary">
                <span class="project-status-name">{item.label}</span>
                <strong class="project-status-value">{item.value}</strong>
                <span class="project-status-shape-label">{semantic.label}</span>
              </div>
              <div class="project-status-explanation">
                <p id={descriptionId} class="project-status-context">
                  {item.description}
                </p>
                <p id={qualificationId} class="project-status-qualification">
                  <strong>Boundary:</strong> {item.qualification}
                </p>
              </div>
            </div>
          </div>
        </li>
      );
    })}
  </ol>
</section>
