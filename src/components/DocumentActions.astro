---
import StatusDossier from "./StatusDossier.astro";
import type { OntologyDocument } from "../lib/manifests";

interface Props {
  documents: OntologyDocument[];
  guidanceBySlug?: Record<string, { order: number; reason: string }>;
}

const { documents, guidanceBySlug = {} } = Astro.props;
const byteFormatter = new Intl.NumberFormat("en-US");
const shortCommit = (value?: string) => (value ? value.slice(0, 12) : undefined);
const dateOnly = (value?: string) => (value ? value.slice(0, 10) : undefined);

type DossierItem = {
  label: string;
  title?: string;
  value?: string | number | null;
  body?: string;
};

const buildDocumentDossier = (document: OntologyDocument): DossierItem[] => {
  const items: DossierItem[] = [];
  const guidance = guidanceBySlug[document.slug];
  if (guidance) {
    items.push({
      label: "Reading order",
      value: guidance.order,
      body: guidance.reason,
    });
  }
  if (document.pdf) {
    items.push({
      label: "PDF bytes",
      value: byteFormatter.format(document.pdf.bytes),
    });
    items.push({
      label: "PDF role",
      value: "human-readable derivative",
    });
  }
  if (document.tex) {
    items.push({
      label: "TeX bytes",
      value: byteFormatter.format(document.tex.bytes),
    });
  }
  if (document.tex?.source?.source_authority_status) {
    items.push({
      label: "TeX authority",
      value: document.tex.source.source_authority_status,
    });
  }
  if (document.tex?.source?.claim_status) {
    items.push({
      label: "Claim status",
      value: document.tex.source.claim_status,
    });
  }
  if (document.tex?.source?.research_status) {
    items.push({
      label: "Research status",
      value: document.tex.source.research_status,
    });
  }
  if (document.tex?.source?.ontology_promotion_status) {
    items.push({
      label: "Ontology status",
      value: document.tex.source.ontology_promotion_status,
    });
  }
  const texSourceCommit = shortCommit(document.tex?.source?.source_commit);
  if (texSourceCommit) {
    items.push({
      label: "TeX source commit",
      value: texSourceCommit,
    });
  }
  const importedAt = dateOnly(document.tex?.source?.generated_at ?? document.pdf?.source?.generated_at);
  if (importedAt) {
    items.push({
      label: "Website import",
      value: importedAt,
    });
  }
  if (document.tex?.source?.sha256) {
    items.push({
      label: "TeX SHA-256",
      value: document.tex.source.sha256,
    });
  }
  if (document.pdf?.source?.sha256) {
    items.push({
      label: "PDF SHA-256",
      value: document.pdf.source.sha256,
    });
  }
  return items;
};
---

<section class="download-section" aria-labelledby="ontology-documents-list-title">
  <div class="section-header">
    <p class="eyebrow">Canonical ontology package</p>
    <h2 id="ontology-documents-list-title">PDF readers and TeX sources</h2>
    <p class="lead">
      TeX files are the registered source-authority artifacts. PDFs are
      generated human-readable derivatives for direct reading.
    </p>
  </div>

  <div class="download-list document-action-list">
    {documents.map((document) => (
      <article class="download-item document-action-item">
        <div>
          <p class="download-kind">Ontology document</p>
          <h3>{document.title}</h3>
          <p>
            {guidanceBySlug[document.slug]?.reason ?? "Use the PDF for reading."} Use the TeX
            file for source inspection when comparing authority-bearing text,
            source commits, and registry metadata.
          </p>
          <div class="document-actions" aria-label={`${document.title} actions`}>
            {document.pdf && <a class="primary-link" href={document.pdf.path}>Read PDF</a>}
            {document.pdf && <a class="secondary-link" href={document.pdf.path} download>Download PDF</a>}
            {document.tex && <a class="secondary-link" href={document.tex.path} download>Download TeX</a>}
          </div>
        </div>
        <StatusDossier
          items={buildDocumentDossier(document)}
          ariaLabel={`${document.title} document metadata`}
          className="download-meta document-download-dossier"
        />
      </article>
    ))}
  </div>
</section>
