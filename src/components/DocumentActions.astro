---
import DocumentCollection from "./documents/DocumentCollection.astro";
import type {
  DocumentAuthorityRole,
  DocumentManifestation,
  DocumentRecord,
} from "../lib/documents";
import type { DownloadItem, OntologyDocument } from "../lib/manifests";

interface Props {
  documents: OntologyDocument[];
  guidanceBySlug?: Record<string, { order: number; reason: string }>;
}

const { documents, guidanceBySlug = {} } = Astro.props;

type MetadataItem = {
  label: string;
  title?: string;
  value?: string | number | null;
  body?: string;
  href?: string;
};

const toManifestation = (
  item: DownloadItem,
  kind: "pdf" | "tex",
  role: DocumentAuthorityRole,
): DocumentManifestation => ({
  kind,
  sitePath: item.path,
  role,
  title: item.title,
  bytes: item.bytes,
  sha256: item.sha256,
  sourceId: item.source?.id,
  sourcePath: item.source?.source_path,
  sourceCommit: item.source?.source_commit,
  generatedAt: item.source?.generated_at,
});

const buildSupplementalMetadata = (document: OntologyDocument): MetadataItem[] => {
  const items: MetadataItem[] = [];
  if (document.tex?.source?.source_authority_status) {
    items.push({
      label: "TeX authority",
      value: document.tex.source.source_authority_status,
    });
  }
  if (document.tex?.source?.claim_status) {
    items.push({
      label: "Claim status",
      value: document.tex.source.claim_status,
    });
  }
  if (document.tex?.source?.research_status) {
    items.push({
      label: "Research status",
      value: document.tex.source.research_status,
    });
  }
  if (document.tex?.source?.ontology_promotion_status) {
    items.push({
      label: "Ontology status",
      value: document.tex.source.ontology_promotion_status,
    });
  }
  return items;
};

const presentationDocuments: DocumentRecord[] = documents.map((document) => {
  const guidance = guidanceBySlug[document.slug];
  const manifestations: DocumentManifestation[] = [];
  if (document.pdf) {
    manifestations.push(toManifestation(document.pdf, "pdf", "readable_derivative"));
  }
  if (document.tex) {
    manifestations.push(toManifestation(document.tex, "tex", "registered_source"));
  }
  return {
    id: `ontology:${document.slug}`,
    slug: document.slug,
    title: document.title,
    category: "research",
    collection: "canonical ontology package",
    summary: `${guidance?.reason ?? "Use the PDF for reading."} Use the TeX file for source inspection when comparing authority-bearing text, source commits, and registry metadata.`,
    status:
      document.tex?.source?.approval_status ?? document.pdf?.source?.approval_status ?? "approved",
    authorityScope:
      document.tex?.source?.source_authority_status ??
      "registered TeX source with a human-readable PDF derivative",
    readingOrder: guidance?.order,
    manifestations,
  };
});

const metadataByDocumentId = Object.fromEntries(
  documents.map((document) => [
    `ontology:${document.slug}`,
    buildSupplementalMetadata(document),
  ]),
) as Record<string, MetadataItem[]>;
---

<DocumentCollection
  eyebrow="Canonical ontology package"
  title="PDF readers and TeX sources"
  description="TeX files are the registered source-authority artifacts. PDFs are generated human-readable derivatives for direct reading."
  documents={presentationDocuments}
  metadataByDocumentId={metadataByDocumentId}
  ordered
  showCollection={false}
/>
